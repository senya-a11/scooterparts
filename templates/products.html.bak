  </div>
</footer>

<!-- ── PREORDER CHOICE MODAL ── -->
<div id="preorderModal" style="display:none;position:fixed;inset:0;z-index:600;background:rgba(0,0,0,.75);backdrop-filter:blur(8px);align-items:center;justify-content:center;">
  <div style="background:var(--bg2);border:1px solid rgba(255,255,255,.08);border-radius:24px;padding:2rem;max-width:440px;width:calc(100% - 2rem);box-shadow:0 32px 96px rgba(0,0,0,.6);">

    <!-- Header -->
    <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1.5rem">
      <div>
        <div style="font-family:var(--font-d);font-size:1.125rem;font-weight:800;line-height:1.2" id="preorderModalTitle">Выберите тип заказа</div>
        <div style="font-size:.8125rem;color:var(--text2);margin-top:.375rem" id="preorderModalSubtitle"></div>
      </div>
      <button id="preorderModalClose" style="width:32px;height:32px;border-radius:50%;background:var(--surface2);border:none;color:var(--text2);cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-left:1rem">✕</button>
    </div>

    <!-- Step 1: in_stock vs preorder -->
    <div id="poStep1">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:1.25rem">
        <button id="chooseInStock" style="padding:1.125rem 1rem;border:1.5px solid var(--border);border-radius:16px;background:var(--surface);cursor:pointer;text-align:left;transition:all .18s;color:var(--text)">
          <div style="width:32px;height:32px;border-radius:8px;background:var(--green-dim);display:flex;align-items:center;justify-content:center;margin-bottom:.625rem">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div style="font-weight:700;font-size:.875rem;margin-bottom:.25rem">В наличии</div>
          <div style="font-size:.8rem;color:var(--green);font-weight:600" id="inStockPrice">—</div>
        </button>
        <button id="choosePreorder" style="padding:1.125rem 1rem;border:1.5px solid var(--border);border-radius:16px;background:var(--surface);cursor:pointer;text-align:left;transition:all .18s;color:var(--text)">
          <div style="width:32px;height:32px;border-radius:8px;background:var(--amber-dim);display:flex;align-items:center;justify-content:center;margin-bottom:.625rem">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--amber)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div style="font-weight:700;font-size:.875rem;margin-bottom:.25rem">Предзаказ</div>
          <div style="font-size:.8rem;color:var(--text2)">Выбор доставки →</div>
        </button>
      </div>
    </div>

    <!-- Step 2: auto vs air -->
    <div id="poStep2" style="display:none">
      <button id="poBackBtn" style="display:flex;align-items:center;gap:.375rem;font-size:.8125rem;color:var(--text2);background:none;border:none;cursor:pointer;padding:0;margin-bottom:1rem">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Назад
      </button>

      <!-- Prices summary bar -->
      <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:.875rem 1rem;margin-bottom:1rem;font-size:.8125rem">
        <div style="display:flex;justify-content:space-between;color:var(--text2);margin-bottom:.375rem">
          <span>Товар</span>
          <span style="color:var(--text)" id="poPriceBase">—</span>
        </div>
        <div style="display:flex;justify-content:space-between;color:var(--text2);margin-bottom:.375rem">
          <span>Доставка</span>
          <span id="poDeliveryPrice" style="color:var(--text2)">—</span>
        </div>
        <div style="display:flex;justify-content:space-between;font-weight:700;border-top:1px solid var(--border);padding-top:.375rem;margin-top:.25rem">
          <span>Итого</span>
          <span style="color:var(--blue)" id="poTotalPrice">—</span>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:1.25rem">
        <button id="chooseAuto" style="padding:1.125rem 1rem;border:1.5px solid var(--border);border-radius:16px;background:var(--surface);cursor:pointer;text-align:left;transition:all .18s;color:var(--text)">
          <div style="font-size:1.375rem;margin-bottom:.5rem">🚗</div>
          <div style="font-weight:700;font-size:.875rem;margin-bottom:.2rem">Авто</div>
          <div style="font-size:.75rem;color:var(--text2);margin-bottom:.375rem">Дольше · Дешевле</div>
          <div style="font-size:.875rem;font-weight:700;color:var(--text)" id="autoPrice">—</div>
        </button>
        <button id="chooseAir" style="padding:1.125rem 1rem;border:1.5px solid var(--border);border-radius:16px;background:var(--surface);cursor:pointer;text-align:left;transition:all .18s;color:var(--text)">
          <div style="font-size:1.375rem;margin-bottom:.5rem">✈️</div>
          <div style="font-weight:700;font-size:.875rem;margin-bottom:.2rem">Самолёт</div>
          <div style="font-size:.75rem;color:var(--text2);margin-bottom:.375rem">Быстрее · Дороже</div>
          <div style="font-size:.875rem;font-weight:700;color:var(--text)" id="airPrice">—</div>
        </button>
      </div>
    </div>

    <button id="preorderModalCancel" style="width:100%;padding:.75rem;background:none;border:1px solid var(--border);border-radius:12px;cursor:pointer;color:var(--text2);font-size:.875rem;transition:border-color .2s">Отмена</button>
  </div>
</div>

<div class="toast" id="toast"></div>

<!-- ── PRODUCT DETAIL MODAL ── -->
<div class="product-detail-modal" id="productDetailModal">
  <div class="product-detail-box">
    <div class="product-detail-header">
      <h2 class="modal-title">Детали товара</h2>
      <button class="modal-close" id="closeProductDetail">✕</button>
    </div>
    <div class="product-detail-content" id="productDetailContent"></div>
  </div>
</div>

<!-- ── GSAP ── -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/CustomEase.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/Draggable.min.js"></script>

<script nonce="{{ request.state.csp_nonce }}">
(function(){
  var c=document.getElementById("starfield"),ctx=c.getContext("2d");
  var W,H,stars=[],COUNT=160,TRAIL=30;
  function resize(){W=c.width=innerWidth;H=c.height=innerHeight;}
  function make(){
    var a=Math.random()*Math.PI*2,spd=Math.random()*.45+.08;
    return{x:Math.random()*W,y:Math.random()*H,vx:Math.cos(a)*spd,vy:Math.sin(a)*spd,r:Math.random()*1.1+.35,alpha:Math.random()*.5+.3,tw:Math.random()*Math.PI*2,tws:Math.random()*.01+.005,trail:[]};
  }
  function init(){resize();stars=Array.from({length:COUNT},make);}
  function draw(){
    var isLight=document.documentElement.getAttribute('data-theme')==='light';
    ctx.fillStyle=isLight?'rgba(247,244,239,.18)':'rgba(8,10,15,.22)';ctx.fillRect(0,0,W,H);
    for(var i=0;i<stars.length;i++){
      var s=stars[i];
      s.trail.push({x:s.x,y:s.y});
      if(s.trail.length>TRAIL)s.trail.shift();
      s.x+=s.vx;s.y+=s.vy;s.tw+=s.tws;
      if(s.x<-10)s.x=W+10;if(s.x>W+10)s.x=-10;
      if(s.y<-10)s.y=H+10;if(s.y>H+10)s.y=-10;
      for(var t=1;t<s.trail.length;t++){
        var p=t/s.trail.length,p2=p*p,tp=s.trail[t],tr=s.r*p*.6;
        if(tr<.05)continue;
        ctx.beginPath();ctx.arc(tp.x,tp.y,tr,0,Math.PI*2);
        ctx.fillStyle=isLight?'rgba(180,70,0,'+(p2*s.alpha*.4)+')':'rgba(110,205,255,'+(p2*s.alpha*.5)+')';ctx.fill();
      }
      var pulse=Math.sin(s.tw)*.2+.8,a=s.alpha*pulse;
      var g=ctx.createRadialGradient(s.x,s.y,0,s.x,s.y,s.r*4);
      g.addColorStop(0,isLight?'rgba(232,88,10,'+(a*.25)+')':'rgba(0,212,255,'+(a*.3)+')');
      g.addColorStop(1,isLight?'rgba(232,88,10,0)':'rgba(0,212,255,0)');
      ctx.beginPath();ctx.arc(s.x,s.y,s.r*4,0,Math.PI*2);ctx.fillStyle=g;ctx.fill();
      ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,Math.PI*2);
      ctx.fillStyle=isLight?'rgba(200,80,0,'+a+')':'rgba(215,248,255,'+a+')';ctx.fill();
    }
    requestAnimationFrame(draw);
  }
  window.addEventListener("resize",resize);
  init();draw();
})();
/* ════════════════════════════════════════
   NAV DRAWER — GSAP (from Nav.md)
════════════════════════════════════════ */
(function() {
  if (typeof gsap === 'undefined') return;

  gsap.registerPlugin(CustomEase);
  CustomEase.create("menuEase", "0.65, 0.01, 0.05, 0.99");

  const drawer    = document.getElementById('navDrawer');
  const overlay   = document.getElementById('navOverlay');
  const toggleBtn = document.getElementById('menuToggleBtn');
  const closeBtn  = document.getElementById('navCloseBtn');
  const bgPanels  = drawer.querySelectorAll('.nav-bg-panel');
  const menuLinks = drawer.querySelectorAll('.nav-menu-link');
  const menuItems = drawer.querySelectorAll('.nav-menu-item');
  const btnTexts  = toggleBtn.querySelectorAll('.menu-button-text p');
  const btnIcon   = toggleBtn.querySelector('.menu-button-icon');
  const fadeItems = [
    document.getElementById('navFadeItem1'),
    document.getElementById('navFadeItem2'),
  ].filter(Boolean);

  let isOpen = false;
  const tl = gsap.timeline({ paused: true });

  // Set initial states
  gsap.set(drawer, { display: 'none', xPercent: 0 });
  gsap.set(bgPanels, { xPercent: 101 });
  gsap.set(menuItems, { yPercent: 140, rotate: 8, opacity: 0 });
  gsap.set(fadeItems, { autoAlpha: 0, yPercent: 40 });
  gsap.set(overlay, { autoAlpha: 0, pointerEvents: 'none' });
  gsap.set(btnTexts[0], { yPercent: 0 });
  gsap.set(btnTexts[1], { yPercent: 100 });

  function openNav() {
    isOpen = true;
    drawer.setAttribute('data-nav', 'open');
    document.body.style.overflow = 'hidden';

    gsap.set(drawer, { display: 'flex' });

    gsap.timeline({ defaults: { ease: 'menuEase', duration: 0.7 } })
      .to(overlay, { autoAlpha: 1, duration: 0.5, onStart: () => { overlay.style.pointerEvents = 'all'; } })
      .to(bgPanels, { xPercent: 0, stagger: 0.1, duration: 0.6 }, '<')
      .to(btnTexts[0], { yPercent: -100, duration: 0.5 }, '<')
      .to(btnTexts[1], { yPercent: 0, duration: 0.5 }, '<+=0.12')
      .to(btnIcon, { rotate: 315, duration: 0.5 }, '<')
      .to(menuItems, { yPercent: 0, rotate: 0, opacity: 1, stagger: 0.06, duration: 0.55 }, '<+=0.3')
      .to(fadeItems, { autoAlpha: 1, yPercent: 0, stagger: 0.05, duration: 0.4 }, '<+=0.15');
  }

  function closeNav() {
    isOpen = false;
    drawer.setAttribute('data-nav', 'closed');
    overlay.style.pointerEvents = 'none';
    document.body.style.overflow = '';

    gsap.timeline({ defaults: { ease: 'menuEase', duration: 0.55 } })
      .to(overlay, { autoAlpha: 0, duration: 0.4 })
      .to(drawer, { xPercent: 110, duration: 0.5 }, '<')
      .to(btnTexts[0], { yPercent: 0, duration: 0.4 }, '<')
      .to(btnTexts[1], { yPercent: 100, duration: 0.4 }, '<')
      .to(btnIcon, { rotate: 0, duration: 0.4 }, '<')
      .set(drawer, { display: 'none', xPercent: 0 })
      .set(bgPanels, { xPercent: 101 })
      .set(menuItems, { yPercent: 140, rotate: 8, opacity: 0 })
      .set(fadeItems, { autoAlpha: 0, yPercent: 40 });
  }

  toggleBtn.addEventListener('click', () => { isOpen ? closeNav() : openNav(); });
  closeBtn.addEventListener('click', closeNav);
  overlay.addEventListener('click', closeNav);

  // Close on Escape
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && isOpen) closeNav();
  });

  // Close on nav link click
  menuLinks.forEach(link => {
    link.addEventListener('click', () => { if (isOpen) closeNav(); });
  });
})();

/* ════════════════════════════════════════
   STATE
════════════════════════════════════════ */
let currentUser=null, cart=[], allProducts=[], currentCat='all', searchTerm='';

const catPillsEl   = document.getElementById('catPills');
const productsGrid = document.getElementById('productsGrid');
const searchInput  = document.getElementById('searchInput');
const sortSelect   = document.getElementById('sortSelect');
const filterCount  = document.getElementById('filterCount');
const cartCount    = document.getElementById('cartCount');
const userMenu     = document.getElementById('userMenu');
const toast        = document.getElementById('toast');

function showToast(type, text) { toast.textContent=text; toast.className=`toast toast-${type} show`; setTimeout(()=>toast.classList.remove('show'),3200); }
function fmt(n) { return new Intl.NumberFormat('ru-RU').format(n); }

let catIcons = { batteries:'🔋', motors:'⚙️', electronics:'📱', brakes:'🛑', tires:'🛞', accessories:'🔧' };
let catNames = { batteries:'Аккумуляторы', motors:'Моторы', electronics:'Электроника', brakes:'Тормоза', tires:'Колёса', accessories:'Аксессуары' };
function getIcon(cat) { return catIcons[cat]||'📦'; }
function getName(cat) { return catNames[cat]||cat; }

/* ════════════════════════════════════════
   ANIMATED COUNTER
════════════════════════════════════════ */
function animateCounter(target) {
  const el = document.getElementById('counterVal');
  if (!el || target === 0) return;
  let startTime = null;
  const duration = 1400;
  function step(ts) {
    if (!startTime) startTime = ts;
    const progress = Math.min((ts - startTime) / duration, 1);
    const eased = 1 - Math.pow(1 - progress, 3);
    el.textContent = Math.floor(eased * target);
    if (progress < 1) requestAnimationFrame(step);
    else el.textContent = target;
  }
  requestAnimationFrame(step);
}

/* ════════════════════════════════════════
   CATEGORIES
════════════════════════════════════════ */
async function loadCategories() {
  try {
    const r = await fetch('/api/categories'); if (!r.ok) return;
    const { categories } = await r.json();
    categories.forEach(c => { catIcons[c.slug]=c.emoji; catNames[c.slug]=c.name; });
    catPillsEl.querySelectorAll('.cat-pill:not([data-cat="all"])').forEach(e=>e.remove());
    categories.forEach(c => {
      const pill = document.createElement('div');
      pill.className='cat-pill'; pill.dataset.cat=c.slug;
      pill.textContent=`${c.emoji} ${c.name}`;
      if (c.count) pill.textContent+=` (${c.count})`;
      catPillsEl.appendChild(pill);
    });
    const footerLinks = document.getElementById('footerCatLinks');
    if (footerLinks) footerLinks.innerHTML='<li><a href="/products">Все товары</a></li>'+categories.map(c=>`<li><a href="/products?category=${c.slug}">${c.emoji} ${c.name}</a></li>`).join('');
    attachPillListeners();
  } catch {}
}

function attachPillListeners() {
  catPillsEl.querySelectorAll('.cat-pill').forEach(pill => {
    pill.addEventListener('click', () => {
      catPillsEl.querySelectorAll('.cat-pill').forEach(p=>p.classList.remove('active'));
      pill.classList.add('active');
      currentCat = pill.dataset.cat;
      renderProducts();
    });
  });
}

/* ════════════════════════════════════════
   PRODUCTS
════════════════════════════════════════ */
async function loadProducts() {
  try {
    const r = await fetch('/api/products'); if (!r.ok) return;
    allProducts = await r.json();
    const inStockCount = allProducts.filter(p=>p.in_stock).length;
    animateCounter(inStockCount);
    renderProducts();
  } catch {}
}

function renderProducts() {
  let filtered = allProducts;
  if (currentCat!=='all') filtered=filtered.filter(p=>p.category===currentCat);
  if (searchTerm) { const q=searchTerm.toLowerCase(); filtered=filtered.filter(p=>p.name.toLowerCase().includes(q)||p.description.toLowerCase().includes(q)); }
  const sort=sortSelect.value;
  if(sort==='price-asc') filtered.sort((a,b)=>a.price-b.price);
  else if(sort==='price-desc') filtered.sort((a,b)=>b.price-a.price);
  else if(sort==='name') filtered.sort((a,b)=>a.name.localeCompare(b.name));

  filterCount.textContent=`${filtered.length} товар${filtered.length===1?'':'ов'}`;
  if(!filtered.length){ productsGrid.innerHTML=`<div class="state-box"><div class="state-icon">🔍</div><p>Ничего не найдено</p></div>`; return; }

  productsGrid.innerHTML = filtered.map((p, idx) => {
    const icon = getIcon(p.category);
    const hasImg = p.image_url && p.image_url.trim() &&
      (p.image_url.startsWith('/static/uploads/')||p.image_url.startsWith('http')||p.image_url.startsWith('data:image/'));
    const extraImgs = Array.isArray(p.images) && p.images.length > 0;

    let imgHtml = '';
    if (hasImg && extraImgs) {
      const allImgs = [p.image_url, ...p.images];
      const slides = allImgs.map((img,i)=>`<div class="card-slide${i===0?' active':''}"><img src="${img}" alt="${p.name}" loading="lazy" class="lazy-load"></div>`).join('');
      const dots = allImgs.map((_,i)=>`<span class="card-dot${i===0?' active':''}" data-dot-idx="${i}"></span>`).join('');
      imgHtml = `<div class="card-slider-wrap" data-current="0" data-total="${allImgs.length}">
        <div class="card-slides">${slides}</div>
        <button class="card-nav card-nav-prev" data-nav="-1">‹</button>
        <button class="card-nav card-nav-next" data-nav="1">›</button>
        <div class="card-dots">${dots}</div>
      </div>`;
    } else if (hasImg) {
      imgHtml = `<img src="${p.image_url}" alt="${p.name}" loading="lazy" class="lazy-load" onerror="this.parentElement.innerHTML='${icon}'">`;
    } else {
      imgHtml = icon;
    }

    let badges=[];
    if(p.featured) badges.push('<span class="product-badge badge-featured"><span class="badge-dot"></span>Популярный</span>');
    if(p.in_stock) badges.push('<span class="product-badge badge-stock"><span class="badge-dot"></span>В наличии</span>');
    else if(!p.preorder) badges.push('<span class="product-badge badge-out"><span class="badge-dot"></span>Нет в наличии</span>');
    if(p.preorder) badges.push('<span class="product-badge badge-preorder"><span class="badge-dot"></span>Предзаказ</span>');
    const badgesHtml = badges.length?`<div class="product-badges">${badges.join('')}</div>`:'';

    return `<div class="product-card" data-product-id="${p.id}" style="animation-delay:${Math.min(idx*.045,.4)}s;cursor:pointer">
      <div class="product-img">${imgHtml}</div>
      <div class="product-body">
        ${badgesHtml}
        <div class="product-cat">${getName(p.category)}</div>
        <div class="product-name">${p.name}</div>
        <div class="product-desc">${p.description}</div>
        <div class="product-footer">
          <span class="product-price">${fmt(p.price)} ₽</span>
          <button class="add-btn" id="addBtn_${p.id}" data-pid="${p.id}" ${!p.in_stock&&!p.preorder?'disabled':''}>
            ${p.in_stock||p.preorder?'В корзину':'Нет в наличии'}
          </button>
        </div>
      </div>
    </div>`;
  }).join('');

  initCardDrag();

  // ── CSP-safe delegation: product card open ──
  productsGrid.addEventListener('click', function(e) {
    // Card nav prev/next
    const navBtn = e.target.closest('[data-nav]');
    if (navBtn) {
      e.stopPropagation();
      const wrap = navBtn.closest('.card-slider-wrap');
      if (wrap) {
        const total = parseInt(wrap.dataset.total);
        const current = parseInt(wrap.dataset.current);
        const dir = parseInt(navBtn.dataset.nav);
        cardSliderUpdate(wrap, ((current + dir) + total) % total);
      }
      return;
    }
    // Card dot
    const dot = e.target.closest('[data-dot-idx]');
    if (dot) {
      e.stopPropagation();
      const wrap = dot.closest('.card-slider-wrap');
      if (wrap) cardSliderUpdate(wrap, parseInt(dot.dataset.dotIdx));
      return;
    }
    // Product card open (skip if clicking inside slider or add-btn)
    const card = e.target.closest('.product-card[data-product-id]');
    if (card && !e.target.closest('.card-slider-wrap') && !e.target.closest('.add-btn')) {
      openProductDetail(parseInt(card.dataset.productId));
    }
  });

  // ── CSP-safe: img lazy-load class ──
  productsGrid.querySelectorAll('img.lazy-load').forEach(img => {
    if (img.complete) img.classList.add('loaded');
    else img.addEventListener('load', () => img.classList.add('loaded'));
  });

  // Делегирование клика на кнопки «В корзину» (CSP-safe)
  productsGrid.querySelectorAll('.add-btn[data-pid]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const pid = parseInt(btn.dataset.pid);
      const prod = allProducts.find(p => p.id === pid) || {};
      addToCart(pid, prod.stock || 0, prod);
    });
  });
}

/* ════════════════════════════════════════
   CARD SLIDER
════════════════════════════════════════ */
function cardSliderNav(btn, direction) {
  const wrap = btn.closest('.card-slider-wrap');
  const total = parseInt(wrap.dataset.total);
  const current = parseInt(wrap.dataset.current);
  cardSliderUpdate(wrap, ((current + direction) + total) % total);
}
function cardSliderGoTo(dot, index) {
  cardSliderUpdate(dot.closest('.card-slider-wrap'), index);
}
function cardSliderUpdate(wrap, index) {
  wrap.dataset.current = index;
  wrap.querySelector('.card-slides').style.transform = `translateX(${-index*100}%)`;
  wrap.querySelectorAll('.card-dot').forEach((d,i)=>d.classList.toggle('active',i===index));
}
function initCardDrag() {
  document.querySelectorAll('.card-slider-wrap').forEach(wrap => {
    let startX = 0, dragged = false;
    wrap.addEventListener('pointerdown', e => { startX=e.clientX; dragged=false; });
    wrap.addEventListener('pointermove', e => { if(Math.abs(e.clientX-startX)>6) dragged=true; });
    wrap.addEventListener('pointerup', e => {
      if (!dragged) return;
      e.stopPropagation();
      const delta = e.clientX - startX;
      if (Math.abs(delta) > 40) {
        const total = parseInt(wrap.dataset.total);
        const current = parseInt(wrap.dataset.current);
        cardSliderUpdate(wrap, ((current + (delta<0?1:-1)) + total) % total);
      }
    });
  });
}

searchInput.addEventListener('input', ()=>{ searchTerm=searchInput.value; renderProducts(); });
sortSelect.addEventListener('change', renderProducts);

/* ════════════════════════════════════════
   ACTIVE ORDERS
════════════════════════════════════════ */
async function loadActiveOrders() {
  try {
    const r = await fetch('/api/orders/active-count'); if(!r.ok) return;
    const {count} = await r.json();
    document.getElementById('activeOrdersCount').textContent = count;
    document.getElementById('activeOrdersCountBig').textContent = count;
  } catch {}
  setTimeout(loadActiveOrders, 30000);
}

/* ════════════════════════════════════════
   AUTH
════════════════════════════════════════ */
async function checkAuth() {
  try {
    const r = await fetch('/api/me',{credentials:'include'});
    if(r.ok){currentUser=await r.json();updateAuthUI();loadCart();}
  } catch {}
}

function updateAuthUI() {
  userMenu.innerHTML='';
  if (currentUser) {
    const initial=(currentUser.username||'?')[0].toUpperCase();
    userMenu.innerHTML=`<div class="user-dropdown-wrap">
      <button class="user-btn" id="userMenuBtn"><div class="user-avatar">${initial}</div><span>${currentUser.username}</span><span>▾</span></button>
      <div class="user-dropdown" id="userDropdown">
        <div class="user-info-box"><div class="user-info-name">${currentUser.username}</div><div class="user-info-email">${currentUser.email}</div></div>
        ${currentUser.is_admin?'<a href="/admin" class="drop-item">⚙️ Панель admin</a>':''}
        <button class="drop-item danger" id="logoutBtnHeader">← Выйти</button>
      </div>
    </div>`;
    document.getElementById('userMenuBtn').addEventListener('click',e=>{e.stopPropagation();document.getElementById('userDropdown').classList.toggle('active');});
    const lb=document.getElementById('logoutBtnHeader');if(lb)lb.addEventListener('click',logout);
  } else {
    userMenu.innerHTML=`<button class="btn btn-primary btn-sm" id="headerLoginBtn">Войти</button>`;
    document.getElementById('headerLoginBtn').addEventListener('click',function(){
      window.location.href='/auth?next='+encodeURIComponent(window.location.pathname);
    });
  }
}
document.addEventListener('click',()=>document.getElementById('userDropdown')?.classList.remove('active'));
function logout(){fetch('/api/logout',{method:'POST',credentials:'include'}).finally(()=>{currentUser=null;cart=[];updateAuthUI();updateCartUI();showToast('success','Вы вышли');});}

/* ════════════════════════════════════════
   CART — только счётчик, страница: /cart
════════════════════════════════════════ */
async function loadCart(){
  try{ const r=await fetch('/api/cart',{credentials:'include'});
    if(r.ok){const data=await r.json();cart=data.items||[];updateCartUI();} }catch{}
}

function updateCartUI(){
  const count=cart.reduce((s,i)=>s+i.quantity,0);
  cartCount.textContent=count; cartCount.style.display=count>0?'flex':'none';
  // Синхронизируем состояние кнопок «В корзину»
  const cartProductIds = new Set(cart.map(i=>i.product.id));
  document.querySelectorAll('.add-btn[data-pid]').forEach(btn => {
    const pid = parseInt(btn.dataset.pid);
    const prod = allProducts.find(p=>p.id===pid);
    if (!prod) return;
    if (cartProductIds.has(pid)) {
      btn.textContent='✓ В корзине'; btn.disabled=true; btn.classList.add('add-btn-added');
    } else if (prod.in_stock || prod.preorder) {
      btn.textContent='В корзину'; btn.disabled=false; btn.classList.remove('add-btn-added');
    }
  });
}

// ── PREORDER MODAL LOGIC ──
let _poResolve = null;
let _poProduct = null;

function showPreorderModal(product) {
  return new Promise((resolve) => {
    _poResolve = resolve;
    _poProduct = product;
    const hasInStock = product.in_stock;
    const hasPreorder = product.preorder;
    const priceAuto = product.price_preorder_auto;
    const priceAir  = product.price_preorder_air;
    const basePrice = product.price || product.base_price || 0;

    document.getElementById('preorderModalTitle').textContent = product.name || 'Выберите тип заказа';
    document.getElementById('inStockPrice').textContent  = basePrice  ? fmt(Math.round(basePrice))  + ' ₽' : '—';
    document.getElementById('autoPrice').textContent     = priceAuto  ? fmt(Math.round(priceAuto))  + ' ₽' : 'Уточняйте';
    document.getElementById('airPrice').textContent      = priceAir   ? fmt(Math.round(priceAir))   + ' ₽' : 'Уточняйте';
    document.getElementById('poPriceBase').textContent   = basePrice  ? fmt(Math.round(basePrice))  + ' ₽' : '—';
    document.getElementById('poDeliveryPrice').textContent = '—';
    document.getElementById('poTotalPrice').textContent    = '—';
    // Reset delivery button highlights
    document.getElementById('chooseAuto').style.borderColor = 'var(--border)';
    document.getElementById('chooseAir').style.borderColor  = 'var(--border)';

    document.getElementById('chooseInStock').style.display  = hasInStock  ? '' : 'none';
    document.getElementById('choosePreorder').style.display = hasPreorder ? '' : 'none';

    if (hasInStock && hasPreorder) {
      document.getElementById('preorderModalSubtitle').textContent = 'Товар доступен по предзаказу и в наличии';
    } else if (hasPreorder) {
      document.getElementById('preorderModalSubtitle').textContent = 'Товар доступен только по предзаказу';
    } else {
      document.getElementById('preorderModalSubtitle').textContent = '';
    }

    if (!hasInStock && hasPreorder) {
      document.getElementById('poStep1').style.display = 'none';
      document.getElementById('poStep2').style.display = '';
    } else {
      document.getElementById('poStep1').style.display = '';
      document.getElementById('poStep2').style.display = 'none';
    }

    document.getElementById('preorderModal').style.display = 'flex';
  });
}

function closePreorderModal(result) {
  document.getElementById('preorderModal').style.display = 'none';
  if (_poResolve) { _poResolve(result); _poResolve = null; }
}

document.getElementById('preorderModalClose').addEventListener('click',  () => closePreorderModal(null));
document.getElementById('preorderModalCancel').addEventListener('click', () => closePreorderModal(null));
document.getElementById('preorderModal').addEventListener('click', e => {
  if (e.target === document.getElementById('preorderModal')) closePreorderModal(null);
});
document.getElementById('chooseInStock').addEventListener('click', () => closePreorderModal({ order_type:'in_stock', delivery_type:null }));
document.getElementById('choosePreorder').addEventListener('click', () => {
  document.getElementById('poStep1').style.display = 'none';
  document.getElementById('poStep2').style.display = '';
  document.getElementById('poDeliveryPrice').textContent = '—';
  document.getElementById('poTotalPrice').textContent = '—';
});
document.getElementById('poBackBtn').addEventListener('click', () => {
  document.getElementById('poStep1').style.display = '';
  document.getElementById('poStep2').style.display = 'none';
});
document.getElementById('chooseAuto').addEventListener('click', () => {
  const p = _poProduct;
  document.getElementById('chooseAuto').style.borderColor = 'var(--blue)';
  document.getElementById('chooseAir').style.borderColor  = 'var(--border)';
  const dp = p ? p.price_preorder_auto : null;
  const base = p ? (p.price||p.base_price||0) : 0;
  document.getElementById('poDeliveryPrice').textContent = dp ? fmt(Math.round(dp))+' ₽' : '—';
  document.getElementById('poTotalPrice').textContent    = (base||dp) ? fmt(Math.round((base||0)+(dp||0)))+' ₽' : '—';
  setTimeout(() => closePreorderModal({ order_type:'preorder', delivery_type:'auto' }), 220);
});
document.getElementById('chooseAir').addEventListener('click', () => {
  const p = _poProduct;
  document.getElementById('chooseAir').style.borderColor  = 'var(--blue)';
  document.getElementById('chooseAuto').style.borderColor = 'var(--border)';
  const dp = p ? p.price_preorder_air : null;
  const base = p ? (p.price||p.base_price||0) : 0;
  document.getElementById('poDeliveryPrice').textContent = dp ? fmt(Math.round(dp))+' ₽' : '—';
  document.getElementById('poTotalPrice').textContent    = (base||dp) ? fmt(Math.round((base||0)+(dp||0)))+' ₽' : '—';
  setTimeout(() => closePreorderModal({ order_type:'preorder', delivery_type:'air' }), 220);
});

async function addToCart(productId, stock, productData) {
  const prod = productData || allProducts.find(p=>p.id===productId) || {};
  if (!prod.in_stock && !prod.preorder) { showToast('error','Нет в наличии'); return; }

  let orderType = null, deliveryType = null;
  if (prod.in_stock && !prod.preorder) {
    orderType = 'in_stock';
  } else if (!prod.in_stock && prod.preorder) {
    // Только предзаказ — сразу показываем выбор доставки
    const choice = await showPreorderModal(prod);
    if (!choice) return;
    orderType    = choice.order_type;
    deliveryType = choice.delivery_type;
  } else {
    // Доступен и в наличии, и предзаказ
    const choice = await showPreorderModal(prod);
    if (!choice) return;
    orderType    = choice.order_type;
    deliveryType = choice.delivery_type;
  }

  try {
    const body = { product_id:productId, quantity:1, order_type:orderType };
    if (deliveryType) body.delivery_type = deliveryType;
    const r = await fetch('/api/cart', {
      method:'POST', credentials:'include',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify(body)
    });
    if (r.status===401) { window.location.href='/auth?next='+encodeURIComponent(window.location.pathname); return; }
    if (r.ok) {
      await loadCart();
      // Помечаем кнопку как добавленную
      const btn = document.getElementById(`addBtn_${productId}`);
      if (btn) { btn.textContent='✓ В корзине'; btn.disabled=true; btn.classList.add('add-btn-added'); }
      showToast('success','✓ Добавлено в корзину');
    }
    else { const d=await r.json(); showToast('error', d.detail||'Ошибка'); }
  } catch { showToast('error','Ошибка соединения'); }
}

async function removeFromCart(productId, specificationId){
  try{
    let url=`/api/cart/${productId}`;
    if(specificationId) url+=`?specification_id=${specificationId}`;
    const r=await fetch(url,{method:'DELETE',credentials:'include'});
    if(r.ok){ await loadCart(); showToast('success','Удалено из корзины'); }
  }catch{}
}

async function updateQuantity(productId, newQty, maxStock, specificationId){
  const qty=Math.max(1,Math.min(parseInt(newQty)||1, maxStock||999));
  try{
    const body={quantity:qty};
    if(specificationId) body.specification_id=specificationId;
    const r=await fetch(`/api/cart/${productId}`,{method:'PUT',credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    if(r.ok){ await loadCart(); }
    else { const d=await r.json(); showToast('error',d.detail||'Ошибка'); }
  }catch{ showToast('error','Ошибка соединения'); }
}

function updatePoSummary(deliveryPrice){
  const base = (_poProduct && (_poProduct.price || _poProduct.base_price)) || 0;
  const dp = deliveryPrice || 0;
  document.getElementById('poDeliveryPrice').textContent = dp ? fmt(Math.round(dp))+' ₽' : '—';
  document.getElementById('poTotalPrice').textContent    = (base||dp) ? fmt(Math.round(base+dp))+' ₽' : '—';
}

/* ════════════════════════════════════════
   PRODUCT DETAIL MODAL
════════════════════════════════════════ */
const productDetailModal   = document.getElementById('productDetailModal');
const closeProductDetailBtn = document.getElementById('closeProductDetail');
const productDetailContent  = document.getElementById('productDetailContent');
let currentDetailProduct=null, selectedSpec=null, detailQty=1;

const urlParams = new URLSearchParams(location.search);
const urlCat = urlParams.get('category');
if (urlCat) currentCat = urlCat;

async function openProductDetail(productId) {
  try {
    const r = await fetch(`/api/products/${productId}`); if(!r.ok) return showToast('error','Не удалось загрузить товар');
    const product = await r.json();
    currentDetailProduct=product; selectedSpec=null; detailQty=1;
    renderProductDetail(product);
    productDetailModal.classList.add('active');
    document.body.style.overflow='hidden';
    setTimeout(initModalSlider, 80);
  } catch { showToast('error','Ошибка загрузки товара'); }
}

function getModalImages(p) {
  const imgs=[];
  if(p.image_url&&p.image_url.trim()) imgs.push(p.image_url);
  if(p.images&&p.images.length) p.images.forEach(img=>{ if(img&&img.trim()&&!imgs.includes(img)) imgs.push(img); });
  return imgs;
}

function renderProductDetail(p) {
  const icon = getIcon(p.category);
  const src = selectedSpec || p;
  const allImages = getModalImages(src);
  if (!allImages.length && p.image_url) allImages.push(p.image_url);

  let galleryHtml='';
  if (allImages.length > 1) {
    const slides = allImages.map((img,i)=>`<div class="modal-slide" data-idx="${i}"><img src="${img}" alt="${p.name}" draggable="false"></div>`).join('');
    const dots = allImages.map((_,i)=>`<span class="modal-dot${i===0?' active':''}"></span>`).join('');
    galleryHtml=`<div class="modal-slider-outer" id="modalSliderOuter">
      <div class="modal-slides-viewport"><div class="modal-slides-track" id="modalSlidesTrack">${slides}</div></div>
      <button class="modal-slider-btn modal-slider-prev" id="modalPrev">‹</button>
      <button class="modal-slider-btn modal-slider-next" id="modalNext">›</button>
      <div class="modal-slider-dots" id="modalDots">${dots}</div>
      <div class="modal-slider-count"><span id="modalCurrentNum">1</span>&nbsp;/&nbsp;${allImages.length}</div>
    </div>`;
  } else if (allImages.length===1) {
    galleryHtml=`<div class="product-main-img"><img src="${allImages[0]}" alt="${p.name}" onerror="this.parentElement.innerHTML='${icon}'"></div>`;
  } else {
    galleryHtml=`<div class="product-main-img">${icon}</div>`;
  }

  const chars = selectedSpec?(selectedSpec.characteristics||[]):(p.characteristics||[]);
  const charsHtml = chars.length?`<div class="product-characteristics"><div class="char-title">📋 Характеристики</div><div class="char-list">${chars.map(c=>`<div class="char-item"><span class="char-name">${c.char_name}</span><span class="char-value">${c.char_value}</span></div>`).join('')}</div></div>`:'';
  const specsHtml = (p.has_specifications&&p.specifications?.length)?`<div class="specs-selector"><div class="specs-title">🔧 Выберите версию</div><div class="specs-grid">${p.specifications.map(spec=>`<div class="spec-option${selectedSpec?.id===spec.id?' active':''}" data-spec-id="${spec.id}"><div class="spec-name">${spec.name}</div><div class="spec-price">${fmt(spec.price)} ₽</div></div>`).join('')}</div></div>`:'';

  const currentPrice=selectedSpec?selectedSpec.price:p.price;
  const currentStock=selectedSpec?selectedSpec.stock:p.stock;
  // Учитываем preorder как у выбранной спецификации, так и у основного товара
  const isPreorderItem = selectedSpec ? (selectedSpec.preorder || false) : (p.preorder || false);
  const inStock = currentStock > 0 || isPreorderItem;

  productDetailContent.innerHTML=`
    <div class="product-gallery">${galleryHtml}</div>
    <div class="product-info">
      <div>
        <div class="product-detail-cat">${getName(p.category)}</div>
        <h2 class="product-detail-title">${p.name}${selectedSpec?` — ${selectedSpec.name}`:''}</h2>
        <div class="product-detail-price">${fmt(currentPrice)} ₽</div>
      </div>
      ${specsHtml}
      <div class="product-detail-desc"><strong>Описание:</strong><br>${selectedSpec?selectedSpec.description||p.description:p.description}</div>
      ${charsHtml}
      <div class="product-actions">
        <div class="qty-selector">
          <span class="qty-label">Кол-во:</span>
          <div class="qty-controls">
            <button class="qty-btn" data-qty="-1" ${!inStock?'disabled':''}>−</button>
            <input type="number" class="qty-input" value="${detailQty}" min="1" max="${isPreorderItem ? 999 : currentStock}" readonly>
            <button class="qty-btn" data-qty="1" ${!inStock?'disabled':''}>+</button>
          </div>
        </div>
        <button class="add-to-cart-btn" data-action="add-to-cart" ${!inStock?'disabled':''}>
          ${currentStock > 0 ? '🛒 Добавить в корзину' : isPreorderItem ? '⏳ Предзаказ' : '✕ Нет в наличии'}
        </button>
      </div>
    </div>`;
}

/* ════════════════════════════════════════
   GSAP MODAL SLIDER
════════════════════════════════════════ */
function initModalSlider() {
  const outer = document.getElementById('modalSliderOuter');
  if (!outer) return;
  const track  = document.getElementById('modalSlidesTrack');
  const slides = Array.from(track.querySelectorAll('.modal-slide'));
  const dots   = Array.from(document.getElementById('modalDots')?.querySelectorAll('.modal-dot') || []);
  const prevBtn = document.getElementById('modalPrev');
  const nextBtn = document.getElementById('modalNext');
  const numEl   = document.getElementById('modalCurrentNum');
  const total   = slides.length;
  if (!total) return;

  let current = 0;
  const W = outer.offsetWidth;
  gsap.set(track, { width: W * total });
  gsap.set(slides, { width: W, position: 'relative', display: 'inline-block' });
  gsap.set(track, { x: 0 });

  function goTo(idx, dir) {
    const next = ((idx % total) + total) % total;
    if (next === current && total > 1) return;
    gsap.to(track, { x: -next * W, duration: 0.55, ease: 'power3.inOut' });
    current = next;
    dots.forEach((d,i) => d.classList.toggle('active', i===current));
    if (numEl) numEl.textContent = current + 1;
  }

  if (typeof Draggable !== 'undefined') {
    gsap.registerPlugin(Draggable);
    let snapX = 0;
    Draggable.create(track, {
      type: 'x',
      bounds: { minX: -(total-1)*W, maxX: 0 },
      inertia: false,
      onDragStart() { snapX = gsap.getProperty(track,'x'); },
      onDragEnd() {
        const currentX = gsap.getProperty(track,'x');
        const delta = currentX - snapX;
        if (Math.abs(delta) > W * 0.2) {
          goTo(current + (delta < 0 ? 1 : -1));
        } else {
          gsap.to(track, { x: -current * W, duration: 0.4, ease: 'power2.out' });
        }
      }
    });
  } else {
    let startX = 0;
    outer.addEventListener('pointerdown', e => { startX=e.clientX; });
    outer.addEventListener('pointerup', e => {
      const delta = e.clientX - startX;
      if (Math.abs(delta) > 50) goTo(current + (delta<0?1:-1));
    });
  }

  prevBtn?.addEventListener('click', () => goTo(current-1, -1));
  nextBtn?.addEventListener('click', () => goTo(current+1, 1));
  dots.forEach((d,i) => d.addEventListener('click', () => goTo(i)));
}

function selectSpecification(specId) {
  if(!currentDetailProduct.specifications) return;
  selectedSpec=currentDetailProduct.specifications.find(s=>s.id===specId);
  detailQty=1; renderProductDetail(currentDetailProduct); setTimeout(initModalSlider,80);
}
function changeDetailQty(delta) {
  const item=selectedSpec||currentDetailProduct;
  const isPreorder = item.preorder || false;
  const maxQty = isPreorder ? 999 : (item.stock || 0);
  detailQty=Math.max(1,Math.min(detailQty+delta, maxQty));
  renderProductDetail(currentDetailProduct); setTimeout(initModalSlider,80);
}

async function addToCartFromDetail() {
  if(currentDetailProduct.has_specifications&&currentDetailProduct.specifications?.length&&!selectedSpec){showToast('error','Выберите версию товара');return;}
  const prod = selectedSpec || currentDetailProduct;
  const isPreorder = prod.preorder;
  const isInStock = prod.in_stock !== undefined ? prod.in_stock : (prod.stock > 0);

  if (!isInStock && !isPreorder) { showToast('error', 'Товар не в наличии'); return; }

  let orderType = null, deliveryType = null;
  if (isInStock && !isPreorder) {
    orderType = 'in_stock';
  } else {
    const choice = await showPreorderModal({ ...currentDetailProduct, ...prod });
    if (!choice) return;
    orderType = choice.order_type;
    deliveryType = choice.delivery_type;
  }

  try {
    const body = { product_id: currentDetailProduct.id, quantity: detailQty, order_type: orderType };
    if (selectedSpec) body.specification_id = selectedSpec.id;
    if (deliveryType) body.delivery_type = deliveryType;
    const r = await fetch('/api/cart', { method:'POST', credentials:'include', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
    if(r.status===401){productDetailModal.classList.remove('active');document.body.style.overflow='';window.location.href='/auth?next='+encodeURIComponent(window.location.pathname);return;}
    if(r.ok){await loadCart();productDetailModal.classList.remove('active');document.body.style.overflow='';showToast('success',`✓ Добавлено ${detailQty} шт. в корзину`);}
    else{const d=await r.json();showToast('error',d.detail||'Ошибка');}
  }catch{showToast('error','Ошибка соединения');}
}

// ── CSP-safe delegation for product detail modal ──
productDetailContent.addEventListener('click', function(e) {
  // spec-option
  const specOpt = e.target.closest('[data-spec-id]');
  if (specOpt) { selectSpecification(parseInt(specOpt.dataset.specId)); return; }
  // qty buttons
  const qtyBtn = e.target.closest('[data-qty]');
  if (qtyBtn && !qtyBtn.disabled) { changeDetailQty(parseInt(qtyBtn.dataset.qty)); return; }
  // add to cart
  const cartBtn = e.target.closest('[data-action="add-to-cart"]');
  if (cartBtn && !cartBtn.disabled) { addToCartFromDetail(); return; }
});

closeProductDetailBtn.addEventListener('click',()=>{productDetailModal.classList.remove('active');document.body.style.overflow='';});
productDetailModal.addEventListener('click',e=>{if(e.target===productDetailModal){productDetailModal.classList.remove('active');document.body.style.overflow='';}});

/* ════════════════════════════════════════
   INIT
════════════════════════════════════════ */
(async()=>{
  updateAuthUI();
  await loadCategories();
  await loadProducts();
  await loadActiveOrders();
  if(urlCat){catPillsEl.querySelectorAll('.cat-pill').forEach(p=>{p.classList.toggle('active',p.dataset.cat===urlCat);});}
  await checkAuth();
})();
</script>

<script nonce="{{ request.state.csp_nonce }}">
/* ══ THEME SYSTEM ══ */
(function(){
  var KEY='import_theme';
  function updateSegs(t){
    document.querySelectorAll('.theme-seg-btn').forEach(function(b){
      b.classList.toggle('seg-active', b.getAttribute('data-seg')===t);
    });
  }
  function applyTheme(t){
    document.documentElement.setAttribute('data-theme',t);
    localStorage.setItem(KEY,t);
    updateSegs(t);
    // legacy knob support
    document.querySelectorAll('.theme-pill-knob').forEach(function(k){
      k.style.transform = t==='light'?'translateX(44px)':'translateX(0)';
    });
  }
  applyTheme(localStorage.getItem(KEY)||'dark');
  window.importToggleTheme=function(forced){
    applyTheme(forced||(document.documentElement.getAttribute('data-theme')==='light'?'dark':'light'));
  };
  document.addEventListener('DOMContentLoaded',function(){
    applyTheme(localStorage.getItem(KEY)||'dark');
    document.querySelectorAll('.theme-seg-btn').forEach(function(b){
      b.addEventListener('click',function(){ window.importToggleTheme(b.getAttribute('data-seg')); });
    });
    // legacy pill
    document.querySelectorAll('.theme-pill').forEach(function(p){ p.addEventListener('click',window.importToggleTheme); });
  });
})();
</script>

<div class="cookie-banner" id="cookieBanner" role="dialog" aria-label="Уведомление об использовании Cookie" aria-live="polite">
  <div class="cookie-inner">
    <div class="cookie-icon" aria-hidden="true">&#127850;</div>
    <div class="cookie-text">
      <strong>Мы используем Cookie-файлы</strong>
      <p>Необходимые Cookie обеспечивают работу сайта (авторизация, корзина). С вашего согласия мы также используем аналитические Cookie. Подробнее — в <a href="/privacy-policy#cookies" target="_blank">Политике конфиденциальности</a>.</p>
    </div>
    <div class="cookie-actions">
      <button class="btn-ca" id="cookieAccept">Принять все</button>
      <button class="btn-cd" id="cookieDecline">Только необходимые</button>
      <button class="btn-cdet" id="cookieDetails">Подробнее</button>
    </div>
  </div>
</div>
<script src="/static/cookie-consent.js" defer></script>
</body>
</html>