<!-- ═══ SCRIPTS ═══ -->
<script nonce="{{ request.state.csp_nonce }}">
  document.body.classList.add('js-ready');
  (function(){
    var els=document.querySelectorAll('.reveal');
    if(!els.length||!('IntersectionObserver' in window)){els.forEach(function(e){e.classList.add('visible');});return;}
    var obs=new IntersectionObserver(function(entries){entries.forEach(function(e){if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}});},{threshold:0.08});
    els.forEach(function(e){obs.observe(e);});
  })();
</script>

<!-- CAROUSEL -->
<script nonce="{{ request.state.csp_nonce }}">
(function(){
  var track=document.getElementById('csTrack');
  var dotsEl=document.getElementById('csDots');
  var counter=document.getElementById('csCounter');
  if(!track)return;
  var slides=track.querySelectorAll('.cs-slide');
  var dots=dotsEl?dotsEl.querySelectorAll('.cs-dot'):[];
  var total=slides.length;
  var cur=0;
  var startX=0, isDragging=false, dragDx=0;

  function goTo(idx){
    cur=(idx+total)%total;
    track.style.transform='translateX(-'+cur*100+'%)';
    dots.forEach(function(d,i){d.classList.toggle('active',i===cur);});
    if(counter)counter.textContent=(cur+1)+' / '+total;
  }

  var prevBtn=document.getElementById('csPrev');
  var nextBtn=document.getElementById('csNext');
  prevBtn&&prevBtn.addEventListener('click',function(){goTo(cur-1);});
  nextBtn&&nextBtn.addEventListener('click',function(){goTo(cur+1);});
  dots.forEach(function(d){d.addEventListener('click',function(){goTo(parseInt(d.getAttribute('data-idx')));});});

  track.addEventListener('pointerdown',function(e){startX=e.clientX;isDragging=true;track.style.transition='none';});
  window.addEventListener('pointermove',function(e){if(!isDragging)return;dragDx=e.clientX-startX;track.style.transform='translateX(calc(-'+cur*100+'% + '+dragDx+'px))';});
  window.addEventListener('pointerup',function(){
    if(!isDragging)return;isDragging=false;
    track.style.transition='';
    if(dragDx<-50)goTo(cur+1);
    else if(dragDx>50)goTo(cur-1);
    else goTo(cur);
    dragDx=0;
  });

  var timer=setInterval(function(){goTo(cur+1);},5500);
  track.addEventListener('pointerenter',function(){clearInterval(timer);});
  track.addEventListener('pointerleave',function(){timer=setInterval(function(){goTo(cur+1);},5500);});
})();
</script>

<!-- GSAP + Lenis (progressive enhancement — CDN allowlisted in CSP) -->
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>
<script src="https://unpkg.com/lenis@1.1.14/dist/lenis.min.js"></script>

<script nonce="{{ request.state.csp_nonce }}">
try {
  if(typeof gsap!=='undefined'&&typeof ScrollTrigger!=='undefined'){gsap.registerPlugin(ScrollTrigger);}
  var isTouchOnly=('ontouchstart' in window)||(navigator.maxTouchPoints>0&&!window.matchMedia('(pointer:fine)').matches);
  if(isTouchOnly&&typeof Lenis!=='undefined'&&typeof gsap!=='undefined'&&typeof ScrollTrigger!=='undefined'){
    var lenis=new Lenis({duration:0.5,easing:function(t){return Math.min(1,1.001-Math.pow(2,-10*t))},smoothWheel:true,wheelMultiplier:1.4});
    lenis.on('scroll',ScrollTrigger.update);
    gsap.ticker.add(function(time){lenis.raf(time*1000);});
    gsap.ticker.lagSmoothing(0);
  } else if(typeof ScrollTrigger!=='undefined'){
    window.addEventListener('scroll',function(){ScrollTrigger.update();},{passive:true});
  }
} catch(e){}
</script>

<script nonce="{{ request.state.csp_nonce }}">
(function(){
  try {
    if(typeof gsap==='undefined'||typeof ScrollTrigger==='undefined')return;
    var LAYERS=[{layer:'1',yPercent:70},{layer:'2',yPercent:55},{layer:'3',yPercent:40},{layer:'4',yPercent:10}];
    document.querySelectorAll('[data-parallax-layers]').forEach(function(el){
      var tl=gsap.timeline({scrollTrigger:{trigger:el,start:'0% 0%',end:'100% 0%',scrub:0}});
      LAYERS.forEach(function(obj,i){tl.to(el.querySelectorAll('[data-parallax-layer="'+obj.layer+'"]'),{yPercent:obj.yPercent,ease:'none'},i===0?undefined:'<');});
    });
    ScrollTrigger.config({autoRefreshEvents:'visibilitychange,DOMContentLoaded,load'});
  } catch(e){console.warn('Parallax error:',e);}
})();
</script>

<script nonce="{{ request.state.csp_nonce }}">
(function(){
  var KEY='fmtun_theme';
  function updateSegs(t){document.querySelectorAll('.theme-seg-btn').forEach(function(b){b.classList.toggle('seg-active',b.getAttribute('data-seg')===t);});}
  function applyTheme(t){document.documentElement.setAttribute('data-theme',t);localStorage.setItem(KEY,t);updateSegs(t);document.querySelectorAll('.theme-pill-knob').forEach(function(k){k.style.transform=t==='light'?'translateX(44px)':'translateX(0)';});}
  applyTheme(localStorage.getItem(KEY)||'dark');
  window.importToggleTheme=function(forced){applyTheme(forced||(document.documentElement.getAttribute('data-theme')==='light'?'dark':'light'));};
  document.addEventListener('DOMContentLoaded',function(){
    applyTheme(localStorage.getItem(KEY)||'dark');
    document.querySelectorAll('.theme-seg-btn').forEach(function(b){b.addEventListener('click',function(){window.importToggleTheme(b.getAttribute('data-seg'));});});
    document.querySelectorAll('.theme-pill').forEach(function(p){p.addEventListener('click',window.importToggleTheme);});
  });
})();
</script>

