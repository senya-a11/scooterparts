<div class="toast" id="toast"></div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/CustomEase.min.js"></script>
<script nonce="{{ request.state.csp_nonce }}">
/* ════════════════════════════════════════
   STARFIELD (точно как products.html)
════════════════════════════════════════ */
(function(){
  var c=document.getElementById("starfield"),ctx=c.getContext("2d");
  var W,H,stars=[],COUNT = window.innerWidth < 768 ? 40 : 60,TRAIL=18;
  function resize(){W=c.width=innerWidth;H=c.height=innerHeight;}
  function make(){
    var a=Math.random()*Math.PI*2,spd=Math.random()*.3+.05;
    return{x:Math.random()*W,y:Math.random()*H,vx:Math.cos(a)*spd,vy:Math.sin(a)*spd,r:Math.random()*1.1+.35,alpha:Math.random()*.5+.3,tw:Math.random()*Math.PI*2,tws:Math.random()*.01+.005,trail:[]};
  }
  function init(){resize();stars=Array.from({length:COUNT},make);}
  function draw(){
    var isLight=document.documentElement.getAttribute('data-theme')==='light';
    ctx.fillStyle=isLight?'rgba(247,244,239,.18)':'rgba(8,10,15,.22)';ctx.fillRect(0,0,W,H);
    for(var i=0;i<stars.length;i++){
      var s=stars[i];
      s.trail.push({x:s.x,y:s.y});
      if(s.trail.length>TRAIL)s.trail.shift();
      s.x+=s.vx;s.y+=s.vy;s.tw+=s.tws;
      if(s.x<-10)s.x=W+10;if(s.x>W+10)s.x=-10;
      if(s.y<-10)s.y=H+10;if(s.y>H+10)s.y=-10;
      for(var t=1;t<s.trail.length;t++){
        var p=t/s.trail.length,p2=p*p,tp=s.trail[t],tr=s.r*p*.6;
        if(tr<.05)continue;
        ctx.beginPath();ctx.arc(tp.x,tp.y,tr,0,Math.PI*2);
        ctx.fillStyle=isLight?'rgba(180,70,0,'+(p2*s.alpha*.4)+')':'rgba(110,205,255,'+(p2*s.alpha*.5)+')';ctx.fill();
      }
      var pulse=Math.sin(s.tw)*.2+.8,a=s.alpha*pulse;
      ctx.beginPath();ctx.arc(s.x,s.y,s.r*2.5,0,Math.PI*2);
      ctx.fillStyle=isLight?'rgba(232,88,10,'+(a*.12)+')':'rgba(0,212,255,'+(a*.15)+')';ctx.fill();
      ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,Math.PI*2);
      ctx.fillStyle=isLight?'rgba(200,80,0,'+a+')':'rgba(215,248,255,'+a+')';ctx.fill();
    }
    requestAnimationFrame(draw);
  }
  // Fix ЗАМ-01: пауза при скрытой вкладке
  var _sfId=null,_sfStop=false;
  function draw2(){if(!_sfStop)_sfId=requestAnimationFrame(draw2);draw();}
  document.addEventListener('visibilitychange',function(){
    if(document.hidden){_sfStop=true;if(_sfId){cancelAnimationFrame(_sfId);_sfId=null;}}
    else{_sfStop=false;_sfId=requestAnimationFrame(draw2);}
  });
  window.addEventListener("resize",resize);
  init();_sfId=requestAnimationFrame(draw2);
})();
/* ════════════════════════════════════════
   NAV DRAWER — GSAP (точно как products.html)
════════════════════════════════════════ */
(function() {
  if (typeof gsap === 'undefined') return;
  gsap.registerPlugin(CustomEase);
  CustomEase.create("menuEase", "0.65, 0.01, 0.05, 0.99");
  const drawer    = document.getElementById('navDrawer');
  const overlay   = document.getElementById('navOverlay');
  const toggleBtn = document.getElementById('menuToggleBtn');
  const closeBtn  = document.getElementById('navCloseBtn');
  const bgPanels  = drawer.querySelectorAll('.nav-bg-panel');
  const menuLinks = drawer.querySelectorAll('.nav-menu-link');
  const menuItems = drawer.querySelectorAll('.nav-menu-item');
  const btnTexts  = toggleBtn.querySelectorAll('.menu-button-text p');
  const btnIcon   = toggleBtn.querySelector('.menu-button-icon');
  const fadeItems = [
    document.getElementById('navFadeItem1'),
    document.getElementById('navFadeItem2'),
  ].filter(Boolean);
  let isOpen = false;
  gsap.set(drawer, { display: 'none', xPercent: 0 });
  gsap.set(bgPanels, { xPercent: 101 });
  gsap.set(menuItems, { yPercent: 140, rotate: 8, opacity: 0 });
  gsap.set(fadeItems, { autoAlpha: 0, yPercent: 40 });
  gsap.set(overlay, { autoAlpha: 0, pointerEvents: 'none' });
  gsap.set(btnTexts[0], { yPercent: 0 });
  gsap.set(btnTexts[1], { yPercent: 100 });
  function openNav() {
    isOpen = true;
    drawer.setAttribute('data-nav', 'open');
    document.body.style.overflow = 'hidden';
    gsap.set(drawer, { display: 'flex' });
    gsap.timeline({ defaults: { ease: 'menuEase', duration: 0.7 } })
      .to(overlay, { autoAlpha: 1, duration: 0.5, onStart: () => { overlay.style.pointerEvents = 'all'; } })
      .to(bgPanels, { xPercent: 0, stagger: 0.1, duration: 0.6 }, '<')
      .to(btnTexts[0], { yPercent: -100, duration: 0.5 }, '<')
      .to(btnTexts[1], { yPercent: 0, duration: 0.5 }, '<+=0.12')
      .to(btnIcon, { rotate: 315, duration: 0.5 }, '<')
      .to(menuItems, { yPercent: 0, rotate: 0, opacity: 1, stagger: 0.06, duration: 0.55 }, '<+=0.3')
      .to(fadeItems, { autoAlpha: 1, yPercent: 0, stagger: 0.05, duration: 0.4 }, '<+=0.15');
  }
  function closeNav() {
    isOpen = false;
    drawer.setAttribute('data-nav', 'closed');
    overlay.style.pointerEvents = 'none';
    document.body.style.overflow = '';
    gsap.timeline({ defaults: { ease: 'menuEase', duration: 0.55 } })
      .to(overlay, { autoAlpha: 0, duration: 0.4 })
      .to(drawer, { xPercent: 110, duration: 0.5 }, '<')
      .to(btnTexts[0], { yPercent: 0, duration: 0.4 }, '<')
      .to(btnTexts[1], { yPercent: 100, duration: 0.4 }, '<')
      .to(btnIcon, { rotate: 0, duration: 0.4 }, '<')
      .set(drawer, { display: 'none', xPercent: 0 })
      .set(bgPanels, { xPercent: 101 })
      .set(menuItems, { yPercent: 140, rotate: 8, opacity: 0 })
      .set(fadeItems, { autoAlpha: 0, yPercent: 40 });
  }
  toggleBtn.addEventListener('click', () => { isOpen ? closeNav() : openNav(); });
  closeBtn.addEventListener('click', closeNav);
  overlay.addEventListener('click', closeNav);
  document.addEventListener('keydown', e => { if (e.key === 'Escape' && isOpen) closeNav(); });
  menuLinks.forEach(link => { link.addEventListener('click', () => { if (isOpen) closeNav(); }); });
})();
/* ════════════════════════════════════════
   THEME SYSTEM (точно как products.html)
════════════════════════════════════════ */
(function(){
  var KEY='import_theme';
  function updateSegs(t){
    document.querySelectorAll('.theme-seg-btn').forEach(function(b){
      b.classList.toggle('seg-active', b.getAttribute('data-seg')===t);
    });
  }
  function applyTheme(t){
    document.documentElement.setAttribute('data-theme',t);
    localStorage.setItem(KEY,t);
    updateSegs(t);
    document.querySelectorAll('.theme-pill-knob').forEach(function(k){
      k.style.transform = t==='light'?'translateX(44px)':'translateX(0)';
    });
  }
  applyTheme(localStorage.getItem(KEY)||'dark');
  window.importToggleTheme=function(forced){
    applyTheme(forced||(document.documentElement.getAttribute('data-theme')==='light'?'dark':'light'));
  };
  document.addEventListener('DOMContentLoaded',function(){
    applyTheme(localStorage.getItem(KEY)||'dark');
    document.querySelectorAll('.theme-seg-btn').forEach(function(b){
      b.addEventListener('click',function(){ window.importToggleTheme(b.getAttribute('data-seg')); });
    });
    document.querySelectorAll('.theme-pill').forEach(function(p){ p.addEventListener('click',window.importToggleTheme); });
  });
})();
</script>
<script nonce="{{ request.state.csp_nonce }}">

document.addEventListener('click', () => document.getElementById('userDropdown')?.classList.remove('active'));
function logout() {
  fetch('/api/logout', { method: 'POST', credentials: 'include' })
    .finally(() => { currentUser = null; cart = []; updateAuthUI(); renderCart(); showToast('success', 'Вы вышли'); });
}

/* ════════════════════════════════════════
   CART STATE & HELPERS
════════════════════════════════════════ */
let currentUser = null, cart = [];
const cartCount = document.getElementById('cartCount');
const toast = document.getElementById('toast');
const catIcons = { batteries:'🔋', motors:'⚙️', electronics:'📱', brakes:'🛑', tires:'🛞', accessories:'🔧' };
const catNames = { batteries:'Аккумуляторы', motors:'Моторы', electronics:'Электроника', brakes:'Тормоза', tires:'Колёса', accessories:'Аксессуары' };
function getIcon(cat) { return catIcons[cat] || '📦'; }
function fmt(n) { return new Intl.NumberFormat('ru-RU').format(Math.round(n)); }
function showToast(type, text) { toast.textContent=text; toast.className=`toast toast-${type} show`; setTimeout(()=>toast.classList.remove('show'),3200); }

async function checkAuth() {
  try {
    const r = await fetch('/api/me', { credentials: 'include' });
    if (r.ok) { currentUser = await r.json(); updateAuthUI(); loadCart(); }
    else { updateAuthUI(); renderEmpty(); }
  } catch { updateAuthUI(); renderEmpty(); }
}

function updateAuthUI() {
  const userMenu = document.getElementById('userMenu');
  if (!userMenu) return;
  userMenu.innerHTML = '';
  if (currentUser) {
    const initial = (currentUser.username || '?')[0].toUpperCase();
    userMenu.innerHTML = `<div class="user-dropdown-wrap">
      <button class="user-btn" id="userMenuBtn"><div class="user-avatar">${initial}</div><span>${currentUser.username}</span><span>▾</span></button>
      <div class="user-dropdown" id="userDropdown">
        <div class="user-info-box"><div class="user-info-name">${currentUser.username}</div><div class="user-info-email">${currentUser.email}</div></div>
        ${currentUser.is_admin ? '<a href="/admin" class="drop-item">⚙️ Панель admin</a>' : ''}
        <button class="drop-item danger" id="logoutBtnHeader">← Выйти</button>
      </div>
    </div>`;
    document.getElementById('userMenuBtn').addEventListener('click', e => {
      e.stopPropagation();
      document.getElementById('userDropdown').classList.toggle('active');
    });
    const lb = document.getElementById('logoutBtnHeader');
    if (lb) lb.addEventListener('click', logout);
  } else {
    userMenu.innerHTML = `<a href="/auth?next=/cart" class="btn btn-primary btn-sm">Войти</a>`;
  }
}

/* ════════════════════════════════════════
   CART LOAD & RENDER
════════════════════════════════════════ */
let deliverySettings = {};

async function loadDeliverySettings() {
  try {
    const r = await fetch('/api/delivery-settings');
    if (r.ok) deliverySettings = await r.json();
  } catch {}
}

async function loadCart() {
  try {
    const r = await fetch('/api/cart', { credentials: 'include' });
    if (r.ok) { const data = await r.json(); cart = data.items || []; renderCart(); }
    else if (r.status === 401) renderEmpty();
  } catch { renderEmpty(); }
}

function updateCartCount() {
  const count = cart.reduce((s, i) => s + i.quantity, 0);
  if (cartCount) { cartCount.textContent = count; cartCount.style.display = count > 0 ? 'flex' : 'none'; }
}

function renderEmpty() {
  const el = document.getElementById('cartItemsList');
  if (!el) return;
  updateCartCount();
  el.innerHTML = `<div class="cart-empty-state">
    <div class="empty-icon-wrap">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color:var(--text3)"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
    </div>
    <div class="empty-title">Корзина пуста</div>
    <div class="empty-desc">Добавьте товары из каталога, чтобы оформить заказ</div>
    <a href="/products" class="btn btn-primary">Перейти в каталог</a>
  </div>`;
  updateSummary();
}

function renderCart() {
  updateCartCount();
  if (!cart.length) { renderEmpty(); return; }
  const el = document.getElementById('cartItemsList');
  const colCount = document.getElementById('cartColCount');
  const n = cart.length;
  if (colCount) colCount.textContent = `${n} товар${n===1?'':n<5?'а':'ов'}`;

  el.innerHTML = cart.map(item => {
    const p = item.product;
    const isPreorder = item.order_type === 'preorder';
    const maxStock = isPreorder ? 999 : (p.stock || 0);
    const specId = item.specification_id || '';
    const hasImg = p.image_url && p.image_url.trim() &&
      (p.image_url.startsWith('/static/')||p.image_url.startsWith('http')||p.image_url.startsWith('data:image/'));
    const imgHtml = hasImg ? `<img src="${p.image_url}" alt="${p.name}" loading="lazy">` : `<span style="font-size:2rem">${getIcon(p.category)}</span>`;
    const badge = isPreorder
      ? `<span class="item-order-badge badge-preorder">📦 Предзаказ</span>`
      : `<span class="item-order-badge badge-in-stock">✓ В наличии</span>`;
    const priceAuto = p.price_preorder_auto;
    const priceAir  = p.price_preorder_air;
    const deliveryHtml = isPreorder ? `
      <div class="delivery-selector">
        <div class="delivery-sel-label">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          Тип доставки
        </div>
        <div class="delivery-opts">
          <button class="delivery-opt${item.delivery_type==='auto'?' selected':''}" data-delivery-pid="${p.id}" data-delivery-spec="${specId}" data-delivery-type="auto">
            <div class="del-opt-icon">🚗</div>
            <div class="del-opt-name">Авто</div>
            <div class="del-opt-price">${priceAuto ? fmt(priceAuto)+' ₽' : 'Уточняйте'}</div>
            ${(()=>{ const mn=deliverySettings.auto_days_min?.value, mx=deliverySettings.auto_days_max?.value; return (mn||mx)?`<div style="font-size:.68rem;color:var(--text3);margin-top:.15rem">${mn&&mx?mn+'–'+mx+' дн':mn?'от '+mn+' дн':mx?'до '+mx+' дн':''}</div>`:''; })()}
          </button>
          <button class="delivery-opt${item.delivery_type==='air'?' selected':''}" data-delivery-pid="${p.id}" data-delivery-spec="${specId}" data-delivery-type="air">
            <div class="del-opt-icon">✈️</div>
            <div class="del-opt-name">Самолёт</div>
            <div class="del-opt-price">${priceAir ? fmt(priceAir)+' ₽' : 'Уточняйте'}</div>
            ${(()=>{ const mn=deliverySettings.air_days_min?.value, mx=deliverySettings.air_days_max?.value; return (mn||mx)?`<div style="font-size:.68rem;color:var(--text3);margin-top:.15rem">${mn&&mx?mn+'–'+mx+' дн':mn?'от '+mn+' дн':mx?'до '+mx+' дн':''}</div>`:''; })()}
          </button>
        </div>
      </div>` : '';

    return `<div class="cart-item-row" data-pid="${p.id}" data-spec="${specId}">
      <div class="item-img">${imgHtml}</div>
      <div class="item-body">
        <div class="item-cat">${catNames[p.category]||p.category}</div>
        <div class="item-name" title="${p.name}">${p.name}</div>
        ${badge}
        <div style="display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin-bottom:.375rem">
          <span style="font-size:.7rem;padding:.15rem .45rem;border-radius:5px;font-family:var(--font-raj);font-weight:700;${isPreorder?'background:rgba(255,184,48,.1);color:var(--amber)':'background:rgba(0,214,143,.1);color:var(--green)'}">${isPreorder?'⏳ Предзаказ':'✓ В наличии'}</span>
          ${p.weight_kg?`<span style="font-size:.7rem;color:var(--text3)">⚖️ ${(parseFloat(p.weight_kg)*item.quantity).toFixed(2)} кг</span>`:''}
        </div>
        <div class="item-qty-row">
          <button class="qty-btn" data-qty-btn="minus" data-pid="${p.id}" data-spec="${specId}" data-max="${maxStock}" ${item.quantity<=1?'disabled':''}>−</button>
          <span class="qty-val">${item.quantity}</span>
          <button class="qty-btn" data-qty-btn="plus" data-pid="${p.id}" data-spec="${specId}" data-max="${maxStock}" ${item.quantity>=maxStock?'disabled':''}>+</button>
        </div>
        ${deliveryHtml}
      </div>
      <div class="item-right">
        <div class="item-total">${fmt(item.item_total)} ₽</div>
        <div class="item-unit-price">${fmt(p.base_price || p.price)} ₽ × ${item.quantity}</div>
        <button class="item-remove" data-remove-pid="${p.id}" data-remove-spec="${specId}" title="Удалить">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/></svg>
        </button>
      </div>
    </div>`;
  }).join('');

  attachCartListeners();
  updateSummary();
}

/* ════════════════════════════════════════
   EVENT DELEGATION (CSP-safe)
════════════════════════════════════════ */
function attachCartListeners() {
  const el = document.getElementById('cartItemsList');
  // Remove old listener by replacing with clone
  const fresh = el.cloneNode(true);
  el.parentNode.replaceChild(fresh, el);

  fresh.addEventListener('click', function(e) {
    const minusBtn = e.target.closest('[data-qty-btn="minus"]');
    if (minusBtn) {
      const pid = parseInt(minusBtn.dataset.pid);
      const spec = minusBtn.dataset.spec ? parseInt(minusBtn.dataset.spec) : null;
      const item = findItem(pid, spec);
      if (item && item.quantity > 1) updateQuantity(pid, item.quantity-1, parseInt(minusBtn.dataset.max)||999, spec);
      return;
    }
    const plusBtn = e.target.closest('[data-qty-btn="plus"]');
    if (plusBtn) {
      const pid = parseInt(plusBtn.dataset.pid);
      const spec = plusBtn.dataset.spec ? parseInt(plusBtn.dataset.spec) : null;
      const max = parseInt(plusBtn.dataset.max)||999;
      const item = findItem(pid, spec);
      if (item && item.quantity < max) updateQuantity(pid, item.quantity+1, max, spec);
      return;
    }
    const removeBtn = e.target.closest('[data-remove-pid]');
    if (removeBtn) {
      const pid = parseInt(removeBtn.dataset.removePid);
      const spec = removeBtn.dataset.removeSpec ? parseInt(removeBtn.dataset.removeSpec) : null;
      removeFromCart(pid, spec);
      return;
    }
    const delivBtn = e.target.closest('[data-delivery-type]');
    if (delivBtn) {
      const pid = parseInt(delivBtn.dataset.deliveryPid);
      const spec = delivBtn.dataset.deliverySpec ? parseInt(delivBtn.dataset.deliverySpec) : null;
      changeDelivery(pid, spec, delivBtn.dataset.deliveryType);
      return;
    }
  });
}

function findItem(pid, spec) {
  return cart.find(i => i.product.id === pid && (spec ? i.specification_id === spec : !i.specification_id));
}

/* ════════════════════════════════════════
   CART API OPERATIONS
════════════════════════════════════════ */
let _qtyUpdating = false;
async function updateQuantity(productId, newQty, maxStock, specificationId) {
  if (_qtyUpdating) return;
  _qtyUpdating = true;
  const qty = Math.max(1, Math.min(parseInt(newQty)||1, maxStock||999));
  try {
    const body = { quantity: qty };
    if (specificationId) body.specification_id = specificationId;
    const r = await fetch(`/api/cart/${productId}`, {
      method: 'PUT', credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    if (r.ok) { await loadCart(); }
    else { const d = await r.json(); showToast('error', d.detail||'Ошибка'); }
  } catch { showToast('error', 'Ошибка соединения'); }
  finally { _qtyUpdating = false; }
}

async function removeFromCart(productId, specificationId) {
  try {
    let url = `/api/cart/${productId}`;
    if (specificationId) url += `?specification_id=${specificationId}`;
    const r = await fetch(url, { method: 'DELETE', credentials: 'include' });
    if (r.ok) { await loadCart(); showToast('success', 'Удалено из корзины'); }
  } catch {}
}

async function changeDelivery(productId, specificationId, deliveryType) {
  // Optimistic UI update first
  const item = findItem(productId, specificationId);
  if (item) {
    item.delivery_type = deliveryType;
    const p = item.product;
    if (deliveryType === 'auto' && p.price_preorder_auto) item.item_total = p.price_preorder_auto * item.quantity;
    else if (deliveryType === 'air' && p.price_preorder_air) item.item_total = p.price_preorder_air * item.quantity;
    renderCart();
  }
  // Persist via PATCH endpoint
  try {
    const body = { delivery_type: deliveryType };
    if (specificationId) body.specification_id = specificationId;
    await fetch(`/api/cart/${productId}/delivery`, {
      method: 'PATCH', credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    // Reload to get server-calculated prices
    await loadCart();
  } catch {}
}

/* ════════════════════════════════════════
   SUMMARY
════════════════════════════════════════ */
function updateSummary() {
  const checkoutBtn = document.getElementById('checkoutBtn');
  const deliveryWarning = document.getElementById('deliveryWarning');
  const summaryDeliveryRow = document.getElementById('summaryDeliveryRow');

  if (!cart.length) {
    document.getElementById('summarySubtotal').textContent = '0 ₽';
    document.getElementById('summaryTotal').textContent = '0 ₽';
    if (summaryDeliveryRow) summaryDeliveryRow.style.display = 'none';
    if (checkoutBtn) { checkoutBtn.disabled = true; checkoutBtn.textContent = 'Оформить заказ →'; }
    if (deliveryWarning) deliveryWarning.style.display = 'none';
    return;
  }

  const baseSubtotal = cart.reduce((s, i) => s + (i.product.base_price||i.product.price) * i.quantity, 0);
  const total = cart.reduce((s, i) => s + i.item_total, 0);
  const deliveryCost = Math.max(0, total - baseSubtotal);
  const preorderItems = cart.filter(i => i.order_type === 'preorder');
  const missingDelivery = preorderItems.some(i => !i.delivery_type);

  document.getElementById('summarySubtotal').textContent = fmt(baseSubtotal) + ' ₽';
  document.getElementById('summaryTotal').textContent = fmt(total) + ' ₽';

  if (preorderItems.length > 0) {
    if (summaryDeliveryRow) summaryDeliveryRow.style.display = 'flex';
    document.getElementById('summaryDelivery').textContent = missingDelivery ? 'Не выбрана' : (deliveryCost > 0 ? '+' + fmt(deliveryCost) + ' ₽' : '0 ₽');
  } else {
    if (summaryDeliveryRow) summaryDeliveryRow.style.display = 'none';
  }

  if (checkoutBtn) {
    checkoutBtn.disabled = missingDelivery || !cart.length;
    checkoutBtn.textContent = missingDelivery ? '⚠ Выберите тип доставки' : 'Оформить заказ →';
  }
  if (deliveryWarning) deliveryWarning.style.display = missingDelivery ? 'block' : 'none';
}

/* ════════════════════════════════════════
   CHECKOUT
════════════════════════════════════════ */
document.getElementById('checkoutBtn').addEventListener('click', async function() {
  if (!currentUser) { window.location.href = '/auth?next=/cart'; return; }
  const address = (document.getElementById('checkoutAddress').value || '').trim();
  const comment = (document.getElementById('checkoutComment').value || '').trim();
  this.disabled = true; this.textContent = 'Оформляем...';
  try {
    const r = await fetch('/api/orders', {
      method: 'POST', credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ delivery_address: address, comment: comment })
    });
    if (r.status === 401) { window.location.href = '/auth?next=/cart'; return; }
    const data = await r.json();
    if (r.ok) {
      cart = [];
      renderCart();
      showToast('success', `✓ Заказ #${data.order_id} оформлен!`);
      setTimeout(() => { window.location.href = '/tracking'; }, 1800);
    } else {
      showToast('error', data.detail || 'Ошибка при оформлении');
      this.disabled = false; this.textContent = 'Оформить заказ →';
    }
  } catch {
    showToast('error', 'Ошибка соединения');
    this.disabled = false; this.textContent = 'Оформить заказ →';
  }
});


/* ════════════════════════════════════════
   THEME SYSTEM
════════════════════════════════════════ */
(function(){
  var KEY='import_theme';
  function applyTheme(t){
    document.documentElement.setAttribute('data-theme',t);
    localStorage.setItem(KEY,t);
    document.querySelectorAll('.theme-seg-btn').forEach(function(b){
      b.classList.toggle('seg-active', b.getAttribute('data-seg')===t);
    });
  }
  applyTheme(localStorage.getItem(KEY)||'dark');
  window.importToggleTheme=function(forced){
    applyTheme(forced||(document.documentElement.getAttribute('data-theme')==='light'?'dark':'light'));
  };
  document.addEventListener('DOMContentLoaded',function(){
    applyTheme(localStorage.getItem(KEY)||'dark');
    document.querySelectorAll('.theme-seg-btn').forEach(function(b){
      b.addEventListener('click',function(){ window.importToggleTheme(b.getAttribute('data-seg')); });
    });
    document.querySelectorAll('.theme-pill').forEach(function(p){ p.addEventListener('click',window.importToggleTheme); });
    // ← ГЛАВНЫЙ FIX: запускаем авторизацию и загрузку корзины
    checkAuth();
  });
})();
</script>
<div class="cookie-banner" id="cookieBanner" role="dialog" aria-label="Cookie" aria-live="polite">
  <div class="cookie-inner">
    <div class="cookie-icon" aria-hidden="true">🍪</div>
    <div class="cookie-text">
      <strong>Мы используем Cookie-файлы</strong>
      <p>Необходимые Cookie обеспечивают работу сайта. С вашего согласия мы также используем аналитические Cookie.</p>
    </div>
    <div class="cookie-actions">
      <button class="btn-ca" id="cookieAccept">Принять все</button>
      <button class="btn-cd" id="cookieDecline">Только необходимые</button>
    </div>
  </div>
</div>
<script src="/static/cookie-consent.js" defer></script>
</body>
</html>
