<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex">
  <link rel="apple-touch-icon" sizes="180x180" href="/static/favicon/apple-touch-icon.png?v=5">
  <link rel="icon" type="image/png" sizes="32x32" href="/static/favicon/favicon-32x32.png?v=5">
  <link rel="shortcut icon" href="/static/favicon/favicon.ico?v=5">
  <meta name="theme-color" content="#000000">
  <title>Корзина — Fm TuN</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
  <script src="/static/csrf-init.js"></script>
  <style nonce="{{ request.state.csp_nonce }}">
    /* ── PP Neue Corp Tight (для меню) ── */
    @font-face {
      font-family: 'PP Neue Corp Tight';
      src: url('https://cdn.prod.website-files.com/673af51dea86ab95d124c3ee/673b0f5784f7060c0ac05534_PPNeueCorp-TightUltrabold.otf') format('opentype');
      font-weight: 700;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'PP Neue Montreal';
      src: url('https://cdn.prod.website-files.com/6819ed8312518f61b84824df/6819ed8312518f61b84825ba_PPNeueMontreal-Medium.woff2') format('woff2');
      font-weight: 500;
      font-style: normal;
      font-display: swap;
    }

    :root {
      --blue:#00D4FF; --blue-dim:rgba(0,212,255,0.12); --blue-mid:rgba(0,212,255,0.4); --blue-glow:rgba(0,212,255,0.25);
      --bg:#080A0F; --bg2:#0D1018; --bg3:#111520;
      --surface:#161C26; --surface2:#1E2635;
      --border:rgba(255,255,255,0.06); --border-hover:rgba(0,212,255,0.2);
      --text:#F0F4F8; --text2:#7B8599; --text3:#3E4560;
      --green:#00E5A0; --green-dim:rgba(0,229,160,0.12);
      --red:#FF4757; --red-dim:rgba(255,71,87,0.12);
      --amber:#FFB020; --amber-dim:rgba(255,176,32,0.12);
      --radius:10px; --radius-lg:16px; --radius-xl:24px;
      --font-d:'Syne',sans-serif; --font-raj:'Rajdhani',sans-serif; --font-b:'DM Sans',sans-serif;
      --font-menu:'PP Neue Corp Tight',sans-serif; --font-mono:'PP Neue Montreal',sans-serif;
      --ease:cubic-bezier(0.16,1,0.3,1); --ease-f:cubic-bezier(0.4,0,0.2,1);
      --ease-menu:cubic-bezier(0.65,0.01,0.05,0.99);
    }


    /* ══════════════════════════════════════
       LIGHT THEME
    ══════════════════════════════════════ */
    [data-theme="light"] {
      --blue:#E8580A;--blue-dim:rgba(232,88,10,.1);--blue-mid:rgba(232,88,10,.4);--blue-glow:rgba(232,88,10,.22);
      --bg:#F7F4EF;--bg2:#EDE9E3;--bg3:#E4E0D8;
      --surface:#D8D3CA;--surface2:#CBC5BB;
      --border:rgba(0,0,0,.08);--border-h:rgba(232,88,10,.28);--border-hover:rgba(232,88,10,.28);
      --text:#1C1208;--text2:#6B5D4F;--text3:#A89080;
      --green:#1A7A52;--green-dim:rgba(26,122,82,.1);
      --red:#CC2200;--red-dim:rgba(204,34,0,.1);
      --amber:#B8720A;--amber-dim:rgba(184,114,10,.1);
    }
    [data-theme="light"] .nav-close-btn { color:var(--blue)!important; border-color:var(--blue)!important; }
    [data-theme="light"] .page-header-bg { background:radial-gradient(ellipse,rgba(232,88,10,0.06) 0%,transparent 70%); }
    [data-theme="light"] .page-header-bg2 { background:radial-gradient(ellipse,rgba(232,88,10,0.03) 0%,transparent 70%); }
    [data-theme="light"] .page-header::after { background:linear-gradient(90deg,transparent,rgba(232,88,10,0.25),transparent); }
    [data-theme="light"] .header,
    [data-theme="light"] .imp-header { background:rgba(247,244,239,.92)!important; border-bottom-color:rgba(0,0,0,.1)!important; }
    [data-theme="light"] .nav-bg-panel.p1,
    [data-theme="light"] .nav-bg-panel.first { background:var(--blue); }
    [data-theme="light"] .nav-bg-panel.p2,
    [data-theme="light"] .nav-bg-panel.second { background:#fff8f3; }
    [data-theme="light"] .nav-bg-panel.p3,
    [data-theme="light"] .nav-bg-panel:not(.first):not(.second):not(.p1):not(.p2) { background:#faf6f1; border-color:rgba(232,88,10,.12); }
    [data-theme="light"] .imp-nav-bg2 { background:#fff8f3; }
    [data-theme="light"] .imp-nav-bg3 { background:#faf6f1; border-color:rgba(232,88,10,.12); }
    [data-theme="light"] .nav-link-heading,
    [data-theme="light"] .nav-menu-heading,
    [data-theme="light"] .imp-nav-heading { color:#1C1208; }
    [data-theme="light"] .nav-text-link,
    [data-theme="light"] .nav-social-link { color:#6B5D4F; }
    [data-theme="light"] .nav-p-small,
    [data-theme="light"] .nav-footer-label { color:#A89080; }
    [data-theme="light"] .filter-bar { background:rgba(247,244,239,.92); border-bottom-color:rgba(0,0,0,.1); }
    [data-theme="light"] .filter-select{background-color:rgba(255,255,255,.9);border-color:rgba(0,0,0,.15);color:var(--text);}
    [data-theme="light"] .search-input{background:rgba(255,255,255,.9);border-color:rgba(0,0,0,.15);color:var(--text);}
    [data-theme="light"] .search-input::placeholder{color:rgba(0,0,0,.4);}
    [data-theme="light"] .logo-bolt,
    [data-theme="light"] .imp-logo-bolt { background:linear-gradient(135deg,#FFD700,#FFA500)!important; -webkit-background-clip:text!important; -webkit-text-fill-color:transparent!important; background-clip:text!important; filter:drop-shadow(0 0 8px rgba(255,180,0,.45))!important; box-shadow:none!important; }
    [data-theme="light"] .eyebrow-dot { background:var(--blue); box-shadow:0 0 8px var(--blue); }
    [data-theme="light"] .product-card { background:rgba(232,225,215,.7)!important; }
    [data-theme="light"] .adv-card { background:rgba(232,225,215,.5)!important; }
    [data-theme="light"] .team-card { background:rgba(220,213,203,.6)!important; }
    [data-theme="light"] .section-dark { background:rgba(237,233,227,.9); border-color:rgba(0,0,0,.07); }
    [data-theme="light"] .footer { background:var(--bg2); border-color:rgba(0,0,0,.08); }
    [data-theme="light"] .footer-bar { background:var(--bg2); border-color:rgba(0,0,0,.08); }
    [data-theme="light"] body { background:var(--bg); }
    [data-theme="light"] .doc-card { background:rgba(232,225,215,.6); }
    [data-theme="light"] .doc-card-header { background:linear-gradient(135deg,rgba(232,88,10,.06) 0%,transparent 55%); }
    [data-theme="light"] .highlight-box { background:var(--surface); border-left-color:var(--blue); }
    [data-theme="light"] .active-orders-banner { background:rgba(247,244,239,.95); border-top-color:rgba(0,0,0,.08); }
    [data-theme="light"] .cart-btn { color:var(--text2); border-color:rgba(0,0,0,.12); }
    [data-theme="light"] .advantages { background:var(--bg2); }
    html { transition: background-color .25s ease; }
    body { transition: background-color .25s ease, color .25s ease; }

    /* Theme toggle pill */
    .theme-toggle-row { display:flex; align-items:center; justify-content:space-between; padding:0 2em; margin-bottom:1.5em; }
    .theme-row-label { font-family:var(--fr,'Rajdhani',sans-serif); font-size:.7rem; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:rgba(255,255,255,.38); transition:color .25s; }
    [data-theme="light"] .theme-row-label { color:rgba(28,18,8,.38); }
    .theme-pill { position:relative; width:80px; height:36px; background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.12); border-radius:100px; cursor:pointer; display:flex; align-items:center; padding:0 4px; transition:background .25s,border-color .25s; }
    [data-theme="light"] .theme-pill { background:rgba(232,88,10,.1); border-color:rgba(232,88,10,.3); }
    .theme-pill:hover { border-color:rgba(232,88,10,.5); }
    .theme-pill-knob { position:absolute; width:28px; height:28px; background:#fff; border-radius:50%; box-shadow:0 2px 8px rgba(0,0,0,.3); transition:transform .3s cubic-bezier(.16,1,.3,1),background .25s; left:4px; }
    [data-theme="light"] .theme-pill-knob { background:#E8580A; box-shadow:0 2px 12px rgba(232,88,10,.4); }
    .theme-icon { position:absolute; font-size:14px; line-height:1; transition:opacity .25s; pointer-events:none; }
    .theme-icon-moon { left:10px; opacity:1; }
    .theme-icon-sun  { right:8px; opacity:.38; }
    [data-theme="light"] .theme-icon-moon { opacity:.38; }
    [data-theme="light"] .theme-icon-sun  { opacity:1; }

        
    /* ── Theme Segment Control ── */
    .theme-seg{display:flex;align-items:center;justify-content:space-between;padding:.875rem 2rem;border-bottom:1px solid rgba(255,255,255,.06);}
    [data-theme="light"] .theme-seg{border-bottom-color:rgba(0,0,0,.07);}
    .theme-seg-label{font-family:var(--fr,'Rajdhani',sans-serif);font-size:.62rem;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.28);transition:color .25s;}
    [data-theme="light"] .theme-seg-label{color:rgba(0,0,0,.28);}
    .theme-seg-ctrl{display:flex;gap:3px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:8px;padding:3px;transition:background .25s,border-color .25s;}
    [data-theme="light"] .theme-seg-ctrl{background:rgba(0,0,0,.04);border-color:rgba(0,0,0,.08);}
    .theme-seg-btn{display:inline-flex;align-items:center;gap:.4rem;padding:.35rem .75rem;font-family:var(--fr,'Rajdhani',sans-serif);font-size:.68rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;border:none;border-radius:5px;cursor:pointer;background:transparent;color:rgba(255,255,255,.32);transition:color .2s,background .2s;line-height:1;}
    [data-theme="light"] .theme-seg-btn{color:rgba(0,0,0,.3);}
    .theme-seg-btn svg{flex-shrink:0;transition:opacity .2s;}
    .theme-seg-btn.seg-active{color:var(--blue);background:var(--blue-dim);}
    [data-theme="light"] .theme-seg-btn.seg-active{color:var(--blue);background:var(--blue-dim);}

    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth;overflow-x:hidden}
    body{
      font-family:var(--font-b);background:var(--bg);color:var(--text);
      line-height:1.6;min-height:100vh;display:flex;flex-direction:column;
      -webkit-font-smoothing:antialiased;overflow-x:hidden;
    }

    /* ── STARFIELD ── */
    #starfield{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none;image-rendering:pixelated}

    .container{max-width:1280px;margin:0 auto;padding:0 1.5rem;position:relative;z-index:1}
    ::-webkit-scrollbar{width:5px} ::-webkit-scrollbar-track{background:var(--bg2)} ::-webkit-scrollbar-thumb{background:var(--surface2);border-radius:3px}

    /* ══════════════════════════════════════
       HEADER
    ══════════════════════════════════════ */
    .header{
      position:fixed;top:0;left:0;right:0;
      background:rgba(0,0,0,0.75);
      backdrop-filter:blur(12px);
      border-bottom:1px solid var(--border);
      z-index:200;padding-top:0;
    }
    .header-inner{
      display:flex;align-items:center;justify-content:space-between;
      height:64px;gap:1rem;
    }
    .logo{
      display:flex;align-items:center;gap:10px;
      font-family:var(--font-d);font-size:1.25rem;font-weight:800;
      color:var(--text);text-decoration:none;letter-spacing:0.08em;
    }
    .logo-bolt{width:32px;height:32px;display:flex;align-items:center;justify-content:center;font-size:22px;background:linear-gradient(135deg,#FFD700,#FFA500);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;filter:drop-shadow(0 0 8px rgba(255,190,0,.55))}
    .logo-text span{color:var(--blue)}
    .header-actions{display:flex;align-items:center;gap:0.75rem}

    /* ── MENU BUTTON (both mobile + desktop) ── */
    .menu-button{
      display:flex;align-items:center;gap:0.625rem;
      background:transparent;border:1px solid var(--border);
      color:var(--text);cursor:pointer;
      padding:0.5rem 0.875rem;border-radius:var(--radius);
      font-family:var(--font-mono),var(--font-b);
      font-size:0.875rem;letter-spacing:0.06em;
      transition:border-color 0.2s,background 0.2s;
      overflow:hidden;
    }
    .menu-button:hover{border-color:var(--border-hover);background:rgba(0,212,255,0.04)}

    /* hide old inline nav links on all sizes */
    .nav{ display:none !important; }

    .menu-button-text{
      display:flex;flex-direction:column;
      align-items:flex-end;
      height:1.1em;overflow:hidden;
    }
    .menu-button-text p{
      font-size:0.875em;font-family:var(--font-mono),var(--font-b);
      letter-spacing:0.08em;text-transform:uppercase;margin:0;line-height:1.1;
    }
    /* Fix Bug4: prevent second line (Закрыть) from showing before GSAP init */
    .menu-button-text p:nth-child(2){transform:translateY(100%);} /* hidden below overflow */
    .menu-button-icon{
      width:0.9em;height:0.9em;
      transition:transform 0.4s cubic-bezier(0.65,0.05,0,1);
      flex-shrink:0;
    }
    .menu-button:hover .menu-button-icon{transform:rotate(90deg)}

    .btn{display:inline-flex;align-items:center;justify-content:center;gap:.5rem;padding:.625rem 1.25rem;font-family:var(--font-d);font-size:.875rem;font-weight:700;border-radius:var(--radius);border:none;cursor:pointer;text-decoration:none;transition:all .2s var(--ease-f);white-space:nowrap;letter-spacing:0.03em}
    .btn-primary{background:var(--blue);color:#000;box-shadow:0 0 24px var(--blue-glow)}
    .btn-primary:hover{transform:translateY(-1px);box-shadow:0 0 36px rgba(0,212,255,.5)}
    .btn-ghost{background:transparent;color:var(--text2);border:1px solid var(--border)}
    .btn-ghost:hover{color:var(--text);border-color:var(--border-hover);background:rgba(0,212,255,.04)}
    .btn-sm{padding:.375rem .875rem;font-size:.8125rem}
    .cart-btn{position:relative;display:flex;align-items:center;justify-content:center;width:40px;height:40px;color:var(--text2);border:1px solid var(--border);border-radius:var(--radius);background:transparent;text-decoration:none;transition:color .2s,border-color .2s,background .2s;flex-shrink:0}
    .cart-btn:hover{color:var(--text);border-color:var(--border-hover);background:rgba(0,212,255,.04)}
    .cart-count{position:absolute;top:-8px;right:-8px;background:var(--red);color:white;font-size:.6rem;font-weight:700;min-width:18px;height:18px;border-radius:9px;padding:0 4px;display:none;align-items:center;justify-content:center;pointer-events:none}

    /* ══════════════════════════════════════
       NAV DRAWER (from Nav.md, restyled)
    ══════════════════════════════════════ */
    .nav-overlay{
      position:fixed;inset:0;background:rgba(0,0,0,0.6);
      z-index:300;cursor:pointer;
      opacity:0;pointer-events:none;
      backdrop-filter:blur(2px);
    }
    .nav-drawer{
      position:fixed;right:0;top:0;bottom:0;
      width:38em;max-width:100vw;
      z-index:400;
      display:none;
      flex-direction:column;
    }
    /* Three layered bg panels (from Nav.md) */
    .nav-drawer-bg{position:absolute;inset:0;z-index:0}
    .nav-bg-panel{
      position:absolute;inset:0;
      border-top-left-radius:1.5em;
      border-bottom-left-radius:1.5em;
    }
    .nav-bg-panel.p1{background:var(--blue)}
    .nav-bg-panel.p2{background:#0a1a20}
    .nav-bg-panel.p3{background:#000000;border:1px solid rgba(0,212,255,0.12)}

    .nav-drawer-inner{
      position:relative;z-index:1;
      display:flex;flex-direction:column;justify-content:space-between;
      height:100%;
      padding:4rem 0 2.5rem;
    }

    /* ── Close button inside drawer ── */
    .nav-close-row{
      display:flex;justify-content:flex-end;
      padding:0 2em;
      margin-bottom:2em;
    }
    .nav-close-btn{
      background:none;border:1px solid var(--border);color:var(--text2);
      width:2.5em;height:2.5em;border-radius:50%;cursor:pointer;
      font-size:1rem;display:flex;align-items:center;justify-content:center;
      transition:all 0.2s;
    }
    .nav-close-btn:hover{border-color:var(--blue);color:var(--blue)}

    /* ── Menu list ── */
    .nav-menu-list{
      list-style:none;padding:0;margin:0;
      display:flex;flex-direction:column;width:100%;
    }
    .nav-menu-item{
      position:relative;overflow:hidden;
    }
    .nav-menu-link{
      display:flex;align-items:baseline;justify-content:flex-end;gap:.5em;
      width:100%;
      padding:0.6em 2em;
      text-decoration:none;color:var(--text);
      position:relative;text-align:right;
    }
    .nav-menu-heading{
      font-family:var(--font-menu);
      font-size:4.5em;
      font-weight:700;
      line-height:0.85;
      text-transform:uppercase;
      letter-spacing:-0.02em;
      transition:transform 0.55s cubic-bezier(0.65,0.05,0,1);
      position:relative;z-index:1;
      color:var(--text);
    }
    .nav-menu-eyebrow{
      font-family:var(--font-raj);
      font-size:0.75em;
      letter-spacing:0.25em;
      text-transform:uppercase;
      color:var(--blue);
      position:relative;z-index:1;
    }
    .nav-menu-link-bg{
      position:absolute;inset:0;
      background:rgba(0,212,255,0.06);
      transform:scale3d(1,0,1);
      transform-origin:50% 100%;
      transition:transform 0.55s cubic-bezier(0.65,0.05,0,1);
      z-index:0;
    }
    .nav-menu-link:hover .nav-menu-heading{
      transform:translateY(-1em);
      transition-delay:0.08s;
      color:var(--blue);
    }
    .nav-menu-link:hover .nav-menu-link-bg{transform:scale3d(1,1,1)}
    .nav-menu-link.active .nav-menu-heading{color:var(--blue)}
    .nav-menu-link.active .nav-menu-eyebrow{opacity:1}

    /* ── Drawer footer ── */
    .nav-drawer-footer{
      padding:0 2em;
      display:flex;flex-direction:column;gap:1em;
      border-top:1px solid rgba(255,255,255,0.06);
      padding-top:1.5em;margin:0 2em;
    }
    .nav-footer-label{
      font-family:var(--font-raj);
      font-size:0.7rem;letter-spacing:0.2em;
      text-transform:uppercase;color:var(--text3);
    }
    .nav-socials{display:flex;gap:1.5em;flex-wrap:wrap}
    .nav-social-link{
      font-size:0.875rem;color:var(--text2);
      text-decoration:none;
      position:relative;
      transition:color 0.2s;
    }
    .nav-social-link::after{
      content:'';position:absolute;left:0;bottom:0;
      width:100%;height:1px;background:var(--blue);
      transform:scaleX(0);transform-origin:right center;
      transition:transform 0.4s cubic-bezier(0.65,0.05,0,1);
    }
    .nav-social-link:hover{color:var(--text)}
    .nav-social-link:hover::after{transform:scaleX(1);transform-origin:left center}

    @media(max-width:767px){
      .nav-drawer{width:100%}
      .nav-bg-panel{border-radius:0}
      .nav-menu-heading{font-size:3.5em}
      .nav-menu-link{padding:0.5em 1.25em}
    }
    @media(max-width:479px){
      .nav-menu-heading{font-size:2.75em}
    }

    /* ══════════════════════════════════════
       PAGE HEADER (no scan-line)
    ══════════════════════════════════════ */
    .page-header{padding-top:5.5rem;padding-bottom:2.5rem;position:relative;overflow:hidden;z-index:1}
    .page-header::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(0,212,255,0.3),transparent)}
    .page-header-bg{position:absolute;top:-100px;left:-100px;width:700px;height:500px;background:radial-gradient(ellipse,rgba(0,212,255,0.06) 0%,transparent 70%);pointer-events:none}
    .page-header-bg2{position:absolute;top:-50px;right:-100px;width:400px;height:400px;background:radial-gradient(ellipse,rgba(0,212,255,0.025) 0%,transparent 70%);pointer-events:none}
    .page-header-inner{display:flex;align-items:flex-end;justify-content:space-between;gap:2rem;flex-wrap:wrap}

    .page-eyebrow{display:inline-flex;align-items:center;gap:.5rem;font-family:var(--font-raj);font-size:.75rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--blue);margin-bottom:1rem;padding:.35rem 1rem;background:var(--blue-dim);border:1px solid rgba(0,212,255,.2);border-radius:100px}
    .eyebrow-dot{width:6px;height:6px;border-radius:50%;background:var(--blue);box-shadow:0 0 8px var(--blue);animation:dotBlink 1.5s ease-in-out infinite}
    @keyframes dotBlink{0%,100%{opacity:1}50%{opacity:0.3}}
    .page-title{font-family:var(--font-d);font-size:clamp(1.75rem,4vw,2.75rem);font-weight:800;letter-spacing:-.04em;line-height:1.1;margin-bottom:.375rem}
    .page-desc{font-family:var(--font-raj);font-size:.9rem;color:var(--text2);letter-spacing:.05em}

    .page-counter{display:flex;flex-direction:column;align-items:flex-end}
    .counter-val{font-family:var(--font-raj);font-size:clamp(2.5rem,5vw,4rem);font-weight:700;color:var(--blue);line-height:1;letter-spacing:0.02em;text-shadow:0 0 30px rgba(0,212,255,.3)}
    .counter-label{font-family:var(--font-raj);font-size:.7rem;color:var(--text3);text-transform:uppercase;letter-spacing:.15em;margin-top:.25rem}

    
    /* ════════════════════════════════════════
       CART PAGE STYLES
    ════════════════════════════════════════ */
    [data-theme="light"] .cart-item-row{background:rgba(232,225,215,.5);border-color:rgba(0,0,0,.08)}
    [data-theme="light"] .cart-item-row:hover{background:rgba(232,225,215,.85)}
    [data-theme="light"] .order-summary{background:rgba(232,225,215,.5);border-color:rgba(0,0,0,.08)}
    [data-theme="light"] .delivery-opt{background:rgba(255,255,255,.7);border-color:rgba(0,0,0,.1)}
    [data-theme="light"] .delivery-opt.selected{border-color:var(--blue);background:var(--blue-dim)}
    [data-theme="light"] .checkout-form input,[data-theme="light"] .checkout-form textarea{background:rgba(255,255,255,.85);border-color:rgba(0,0,0,.15);color:var(--text)}
    [data-theme="light"] .step-dot{background:rgba(0,0,0,.08);color:var(--text3)}
    [data-theme="light"] .step-dot.active-dot{background:var(--blue-dim);color:var(--blue)}

    /* ── TOAST ── */
    .toast{position:fixed;bottom:1.5rem;right:1.5rem;padding:.75rem 1.25rem;border-radius:var(--radius-lg);font-family:var(--font-raj);font-size:.9375rem;font-weight:700;letter-spacing:.04em;z-index:9000;opacity:0;transform:translateY(12px);transition:all .3s var(--ease);pointer-events:none;max-width:320px}
    .toast.show{opacity:1;transform:translateY(0)}
    .toast-success{background:var(--green-dim);border:1px solid rgba(0,229,160,.3);color:var(--green)}
    .toast-error{background:var(--red-dim);border:1px solid rgba(255,71,87,.3);color:var(--red)}
    .toast-info{background:var(--blue-dim);border:1px solid rgba(0,212,255,.3);color:var(--blue)}

    /* ── CART PAGE LAYOUT ── */
    .cart-page{flex:1;padding-top:96px;padding-bottom:5rem;position:relative;z-index:1;min-height:calc(100vh - 64px)}
    .cart-page-header{margin-bottom:2rem}
    .cart-page-eyebrow{font-family:var(--font-raj);font-size:.75rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--blue);margin-bottom:.5rem;display:flex;align-items:center;gap:.5rem}
    .cart-page-title{font-family:var(--font-d);font-size:clamp(1.75rem,4vw,2.5rem);font-weight:800;letter-spacing:-.04em;line-height:1.1}

    /* Steps */
    .cart-steps{display:flex;align-items:center;gap:0;margin-bottom:2.5rem;user-select:none}
    .step-item{display:flex;align-items:center;gap:.625rem;opacity:.38}
    .step-item.step-active{opacity:1}
    .step-dot{width:28px;height:28px;border-radius:50%;background:var(--surface2);display:flex;align-items:center;justify-content:center;font-family:var(--font-raj);font-size:.725rem;font-weight:700;letter-spacing:.03em;flex-shrink:0;transition:all .2s}
    .step-item.step-active .step-dot{background:var(--blue-dim);color:var(--blue);border:1px solid rgba(0,212,255,.3);box-shadow:0 0 12px rgba(0,212,255,.2)}
    .step-label{font-family:var(--font-raj);font-size:.8rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text2)}
    .step-item.step-active .step-label{color:var(--text)}
    .step-sep{width:40px;height:1px;background:var(--border);margin:0 .25rem;flex-shrink:0}

    /* Two-column layout */
    .cart-layout{display:grid;grid-template-columns:1fr 360px;gap:2rem;align-items:start}
    @media(max-width:900px){.cart-layout{grid-template-columns:1fr}}

    /* Items column */
    .cart-col-heading{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem}
    .cart-col-title{font-family:var(--font-d);font-size:1.25rem;font-weight:800;letter-spacing:-.02em}
    .cart-col-count{font-family:var(--font-raj);font-size:.8rem;color:var(--text2);letter-spacing:.08em}

    /* Item row — reference-style */
    .cart-item-row{
      display:grid;grid-template-columns:88px 1fr auto;gap:1.25rem;align-items:start;
      background:var(--surface);border:1px solid var(--border);
      border-radius:var(--radius-lg);padding:1.25rem;
      transition:border-color .2s,background .2s;margin-bottom:.75rem;
      animation:rowIn .35s var(--ease) both;
    }
    @keyframes rowIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
    .cart-item-row:nth-child(2){animation-delay:.05s}
    .cart-item-row:nth-child(3){animation-delay:.1s}
    .cart-item-row:nth-child(n+4){animation-delay:.15s}
    .cart-item-row:hover{border-color:rgba(255,255,255,.1)}

    .item-img{width:88px;height:88px;border-radius:var(--radius);background:var(--surface2);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:2rem;overflow:hidden;flex-shrink:0}
    .item-img img{width:100%;height:100%;object-fit:cover}

    .item-body{min-width:0}
    .item-cat{font-family:var(--font-raj);font-size:.7rem;color:var(--text2);letter-spacing:.12em;text-transform:uppercase;margin-bottom:.25rem}
    .item-name{font-family:var(--font-d);font-size:.9375rem;font-weight:700;line-height:1.3;margin-bottom:.375rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .item-order-badge{display:inline-block;font-size:.7rem;padding:.15rem .5rem;border-radius:100px;font-family:var(--font-raj);font-weight:700;letter-spacing:.05em;margin-bottom:.5rem}
    .badge-in-stock{background:var(--green-dim);color:var(--green);border:1px solid rgba(0,229,160,.25)}
    .badge-preorder{background:var(--amber-dim);color:var(--amber);border:1px solid rgba(255,176,32,.25)}

    /* Qty controls */
    .item-qty-row{display:flex;align-items:center;gap:.5rem;margin-top:.375rem}
    .qty-btn{width:30px;height:30px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;color:var(--text);cursor:pointer;font-size:1rem;font-weight:700;display:flex;align-items:center;justify-content:center;transition:all .15s;line-height:1;flex-shrink:0}
    .qty-btn:hover:not([disabled]){background:var(--blue-dim);border-color:rgba(0,212,255,.3);color:var(--blue)}
    .qty-btn[disabled]{opacity:.3;cursor:not-allowed}
    .qty-val{min-width:32px;text-align:center;font-family:var(--font-raj);font-size:1rem;font-weight:700;letter-spacing:.04em}

    /* Delivery selector inline */
    .delivery-selector{margin-top:.875rem}
    .delivery-sel-label{font-family:var(--font-raj);font-size:.68rem;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--amber);margin-bottom:.5rem;display:flex;align-items:center;gap:.375rem}
    .delivery-opts{display:flex;gap:.5rem}
    .delivery-opt{flex:1;padding:.625rem .625rem;border:1.5px solid var(--border);border-radius:10px;background:var(--surface2);cursor:pointer;transition:all .18s;text-align:left}
    .delivery-opt:hover{border-color:rgba(255,255,255,.14)}
    .delivery-opt.selected{border-color:var(--blue);background:var(--blue-dim);box-shadow:0 0 10px rgba(0,212,255,.1)}
    .del-opt-icon{font-size:1.1rem;margin-bottom:.25rem}
    .del-opt-name{font-family:var(--font-raj);font-size:.775rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--text);transition:color .18s}
    .del-opt-price{font-size:.725rem;color:var(--text2);margin-top:.1rem;transition:color .18s}
    .delivery-opt.selected .del-opt-name{color:var(--blue)}
    .delivery-opt.selected .del-opt-price{color:rgba(0,212,255,.6)}

    /* Right: price + remove */
    .item-right{display:flex;flex-direction:column;align-items:flex-end;gap:.5rem;flex-shrink:0;padding-top:.125rem}
    .item-total{font-family:var(--font-d);font-size:1.0625rem;font-weight:800;letter-spacing:-.01em;white-space:nowrap}
    .item-unit-price{font-size:.75rem;color:var(--text2);font-family:var(--font-raj);white-space:nowrap;text-align:right}
    .item-remove{background:none;border:none;color:var(--text3);cursor:pointer;padding:.25rem;transition:color .15s;border-radius:6px;display:flex;align-items:center}
    .item-remove:hover{color:var(--red)}

    /* Empty state */
    .cart-empty-state{text-align:center;padding:5rem 2rem}
    .empty-icon-wrap{width:80px;height:80px;border-radius:50%;background:var(--surface);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem}
    .empty-title{font-family:var(--font-d);font-size:1.5rem;font-weight:800;margin-bottom:.5rem}
    .empty-desc{color:var(--text2);font-size:.9375rem;margin-bottom:1.5rem}

    /* Order summary panel */
    .order-summary{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-xl);padding:1.5rem;position:sticky;top:88px}
    .summary-title{font-family:var(--font-d);font-size:1.125rem;font-weight:800;letter-spacing:-.02em;margin-bottom:1.25rem;padding-bottom:.875rem;border-bottom:1px solid var(--border)}
    .summary-row{display:flex;align-items:baseline;justify-content:space-between;gap:1rem;margin-bottom:.625rem}
    .summary-row-label{font-size:.875rem;color:var(--text2)}
    .summary-row-val{font-family:var(--font-raj);font-size:.9375rem;font-weight:700;color:var(--text)}
    .summary-sep{height:1px;background:var(--border);margin:.875rem 0}
    .summary-total-row{display:flex;align-items:center;justify-content:space-between;gap:1rem}
    .summary-total-label{font-family:var(--font-d);font-size:.9375rem;font-weight:800}
    .summary-total-val{font-family:var(--font-d);font-size:1.375rem;font-weight:800;color:var(--blue);text-shadow:0 0 20px rgba(0,212,255,.25)}
    .delivery-warning{background:rgba(255,176,32,.08);border:1px solid rgba(255,176,32,.2);border-radius:var(--radius);padding:.625rem .875rem;font-size:.8rem;color:var(--amber);margin:.875rem 0;display:none}

    /* Checkout */
    .checkout-section{margin-top:1.125rem;border-top:1px solid var(--border);padding-top:1.125rem}
    .checkout-section-title{font-family:var(--font-raj);font-size:.7rem;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--text3);margin-bottom:.75rem}
    .checkout-form{display:flex;flex-direction:column;gap:.5rem}
    .checkout-form input,.checkout-form textarea{width:100%;padding:.625rem .875rem;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);color:var(--text);font-family:var(--font-b);font-size:.875rem;outline:none;transition:border-color .2s;resize:none}
    .checkout-form input::placeholder,.checkout-form textarea::placeholder{color:var(--text3)}
    .checkout-form input:focus,.checkout-form textarea:focus{border-color:var(--blue);box-shadow:0 0 0 2px var(--blue-dim)}
    .checkout-btn{width:100%;padding:.875rem;margin-top:1rem;font-size:.9375rem;font-family:var(--font-d);font-weight:800;letter-spacing:.02em;border-radius:var(--radius-lg)}

    @media(max-width:560px){
      .cart-item-row{grid-template-columns:68px 1fr auto;gap:.875rem;padding:1rem}
      .item-img{width:68px;height:68px}
      .delivery-opts{flex-direction:column}
      .step-sep{width:24px}
      .step-label{display:none}
    }

    /* ── FOOTER ── */
    .footer{background:var(--bg2);border-top:1px solid var(--border);padding:3rem 0 0;position:relative;z-index:1}
    .footer-grid{display:grid;grid-template-columns:1.5fr repeat(3,1fr);gap:3rem;padding-bottom:3rem}
    .footer-brand-desc{font-size:.875rem;color:var(--text2);line-height:1.7;margin-top:1rem;max-width:280px}
    .footer-col-title{font-family:var(--font-raj);font-size:.7rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--text3);margin-bottom:1rem}
    .footer-links{list-style:none;display:flex;flex-direction:column;gap:.5rem}
    .footer-links a{font-size:.875rem;color:var(--text2);text-decoration:none;transition:color .2s}
    .footer-links a:hover{color:var(--blue)}
    .footer-bottom{border-top:1px solid var(--border);padding:1.25rem 0;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}
    .footer-bottom span,.footer-bottom a{font-family:var(--font-raj);font-size:.8rem;color:var(--text3);text-decoration:none;transition:color .2s;letter-spacing:.05em}
    .footer-bottom a:hover{color:var(--blue)}
    .footer-legal{display:flex;gap:1.5rem;flex-wrap:wrap}
    @media(max-width:768px){.footer-grid{grid-template-columns:1fr 1fr;gap:2rem}}
    @media(max-width:480px){.footer-grid{grid-template-columns:1fr}}

    /* ── USER DROPDOWN ── */
    .user-dropdown-wrap{position:relative}
    .user-btn{display:flex;align-items:center;gap:.5rem;background:var(--surface);border:1px solid var(--border);color:var(--text);padding:.375rem .875rem .375rem .5rem;border-radius:var(--radius);cursor:pointer;font-family:var(--font-b);font-size:.875rem;transition:all .2s;white-space:nowrap}
    .user-btn:hover{border-color:var(--border-hover)}
    .user-avatar{width:28px;height:28px;background:linear-gradient(135deg,var(--blue),#0099CC);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:.8125rem;font-weight:700;color:#000;flex-shrink:0}
    .user-dropdown{position:absolute;right:0;top:calc(100% + .5rem);background:var(--bg3);border:1px solid var(--border-hover);border-radius:var(--radius-lg);padding:.5rem;min-width:200px;box-shadow:0 12px 40px rgba(0,0,0,.6);opacity:0;pointer-events:none;transform:translateY(-6px);transition:all .2s var(--ease);z-index:500}
    .user-dropdown.active{opacity:1;pointer-events:auto;transform:translateY(0)}
    .user-info-box{padding:.5rem .75rem .75rem;border-bottom:1px solid var(--border);margin-bottom:.25rem}
    .user-info-name{font-family:var(--font-d);font-size:.875rem;font-weight:700;color:var(--text);margin-bottom:.125rem}
    .user-info-email{font-size:.75rem;color:var(--text2)}
    .drop-item{display:flex;align-items:center;gap:.5rem;width:100%;padding:.5rem .75rem;background:none;border:none;border-radius:7px;color:var(--text2);cursor:pointer;font-family:var(--font-b);font-size:.875rem;text-decoration:none;transition:all .2s}
    .drop-item:hover{background:rgba(255,255,255,.06);color:var(--text)}
    .drop-item.danger{color:var(--red)}.drop-item.danger:hover{background:var(--red-dim);color:var(--red)}
    [data-theme="light"] .user-btn{background:rgba(255,255,255,.8);border-color:rgba(0,0,0,.12)}
    [data-theme="light"] .user-dropdown{background:var(--bg3);border-color:rgba(232,88,10,.28)}
    [data-theme="light"] .drop-item:hover{background:rgba(0,0,0,.04)}

    /* ── Performance: GPU compositing for animated elements ── */
    .nav-bg-panel,.nav-overlay,.menu-button-icon{will-change:transform,opacity;}
    #starfield{will-change:transform;}
  
    @media(prefers-reduced-motion:reduce){
      *,*::before,*::after{animation-duration:.01ms!important;animation-iteration-count:1!important;transition-duration:.01ms!important;}
      #starfield{display:none!important;}
    }
</style>
</head>
<body>

<!-- ── STARFIELD ── -->
<canvas id="starfield"></canvas>

<!-- ══════════════════════════════════════
     HEADER
══════════════════════════════════════ -->
<header class="header">
  <div class="container">
    <div class="header-inner">
      <a href="/" class="logo">
        <div class="logo-bolt">&#9889;</div>
        <span class="logo-text">Fm <span>TuN</span></span>
      </a>
      <div class="header-actions">
        <a href="/cart" class="cart-btn" id="cartBtn" aria-label="Корзина">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          <span class="cart-count" id="cartCount">0</span>
        </a>
        <div class="user-dropdown-wrap" id="userMenu"></div>
        <button class="menu-button" id="menuToggleBtn" aria-label="Открыть меню">
          <div class="menu-button-text">
            <p>Меню</p>
            <p>Закрыть</p>
          </div>
          <svg class="menu-button-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="none">
            <path d="M7.33333 16L7.33333 0L8.66667 0L8.66667 16L7.33333 16Z" fill="currentColor"/>
            <path d="M16 8.66667L0 8.66667L0 7.33333L16 7.33333L16 8.66667Z" fill="currentColor"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- ══════════════════════════════════════
     NAV DRAWER
══════════════════════════════════════ -->
<div id="navOverlay" class="nav-overlay"></div>
<div id="navDrawer" class="nav-drawer" data-nav="closed">
  <!-- Layered bg panels -->
  <div class="nav-drawer-bg">
    <div class="nav-bg-panel p1"></div>
    <div class="nav-bg-panel p2"></div>
    <div class="nav-bg-panel p3"></div>
  </div>

  <div class="nav-drawer-inner">
    <div>
      <div class="nav-close-row">
        <button class="nav-close-btn" id="navCloseBtn" aria-label="Закрыть">✕</button>
      </div>
      <div class="theme-seg">
        <p class="theme-seg-label">Тема</p>
        <div class="theme-seg-ctrl" role="group">
          <button class="theme-seg-btn seg-dark" data-seg="dark"><svg width="11" height="11" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M11 7.5A5 5 0 0 1 4.5 1a5.5 5.5 0 1 0 6.5 6.5Z" fill="currentColor"/></svg>Тёмная</button>
          <button class="theme-seg-btn seg-light" data-seg="light"><svg width="11" height="11" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="6" cy="6" r="2.2" fill="currentColor"/><path d="M6 .8V2.4M6 9.6v1.6M.8 6H2.4M9.6 6h1.6M2.34 2.34l1.13 1.13M8.53 8.53l1.13 1.13M9.66 2.34 8.53 3.47M3.47 8.53 2.34 9.66" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>Светлая</button>
        </div>
      </div>
      <ul class="nav-menu-list" id="navMenuList">
        <li class="nav-menu-item">
          <a href="/" class="nav-menu-link">
            <p class="nav-menu-heading">Главная</p>
            <p class="nav-menu-eyebrow">01</p>
            <div class="nav-menu-link-bg"></div>
          </a>
        </li>
        <li class="nav-menu-item">
          <a href="/products" class="nav-menu-link">
            <p class="nav-menu-heading">Каталог</p>
            <p class="nav-menu-eyebrow">02</p>
            <div class="nav-menu-link-bg"></div>
          </a>
        </li>
        <li class="nav-menu-item">
          <a href="/about" class="nav-menu-link">
            <p class="nav-menu-heading">О нас</p>
            <p class="nav-menu-eyebrow">03</p>
            <div class="nav-menu-link-bg"></div>
          </a>
        </li>
        <li class="nav-menu-item">
          <a href="/tracking" class="nav-menu-link">
            <p class="nav-menu-heading" style="color:var(--blue)">Заказы</p>
            <p class="nav-menu-eyebrow">04</p>
            <div class="nav-menu-link-bg"></div>
          </a>
        </li>
      </ul>
    </div>

    <div class="nav-drawer-footer">
      <p class="nav-footer-label" id="navFadeItem1">Контакты</p>
      <div class="nav-socials" id="navFadeItem2">
        <a href="tel:+78001234567" class="nav-social-link">+7 (800) 123-45-67</a>
        <a href="mailto:info@fmtun.ru">info@fmtun.ru</a>
        <a href="https://t.me/fmtun" class="nav-social-link">Telegram</a>
      </div>
    </div>
  </div>
</div>


<!-- ══════════════════════════════════════
     CART PAGE CONTENT
══════════════════════════════════════ -->
<main class="cart-page">
  <div class="container">

    <div class="cart-page-header">
      <div class="cart-page-eyebrow">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        Корзина
      </div>
      <h1 class="cart-page-title">Ваш заказ</h1>
    </div>

    <!-- Step breadcrumb -->
    <div class="cart-steps">
      <div class="step-item step-active">
        <div class="step-dot">01</div>
        <span class="step-label">Корзина</span>
      </div>
      <div class="step-sep"></div>
      <div class="step-item">
        <div class="step-dot">02</div>
        <span class="step-label">Доставка</span>
      </div>
      <div class="step-sep"></div>
      <div class="step-item">
        <div class="step-dot">03</div>
        <span class="step-label">Оплата</span>
      </div>
    </div>

    <div class="cart-layout">

      <!-- Items column -->
      <div>
        <div class="cart-col-heading">
          <span class="cart-col-title">Товары</span>
          <span class="cart-col-count" id="cartColCount">0 товаров</span>
        </div>
        <div id="cartItemsList"></div>
      </div>

      <!-- Order summary -->
      <div class="order-summary" id="orderSummary">
        <div class="summary-title">Итого к оплате</div>
        <div class="summary-row">
          <span class="summary-row-label">Подытог</span>
          <span class="summary-row-val" id="summarySubtotal">0 ₽</span>
        </div>
        <div class="summary-row" id="summaryDeliveryRow" style="display:none">
          <span class="summary-row-label">Доставка</span>
          <span class="summary-row-val" id="summaryDelivery">—</span>
        </div>
        <div class="summary-sep"></div>
        <div class="summary-total-row">
          <span class="summary-total-label">Всего</span>
          <span class="summary-total-val" id="summaryTotal">0 ₽</span>
        </div>
        <div class="delivery-warning" id="deliveryWarning">
          ⚠️ Выберите тип доставки для всех товаров по предзаказу
        </div>
        <div class="checkout-section">
          <div class="checkout-section-title">Оформить заказ</div>
          <div class="checkout-form">
            <input type="text" id="checkoutAddress" placeholder="Адрес доставки (необязательно)" maxlength="200">
            <textarea id="checkoutComment" placeholder="Комментарий к заказу" rows="2" maxlength="500"></textarea>
          </div>
        </div>
        <button class="btn btn-primary checkout-btn" id="checkoutBtn" disabled>
          Оформить заказ →
        </button>
        <a href="/products" class="btn btn-ghost" style="width:100%;margin-top:1.5rem;justify-content:center">
          ← Продолжить покупки
        </a>
      </div>

    </div>
  </div>
</main>

