<script nonce="{{ request.state.csp_nonce }}">
/* ════════════════════════════
   STARFIELD (идентично auth.html)
════════════════════════════ */
(function(){
  var c = document.getElementById('starfield'), ctx = c.getContext('2d');
  var W, H, stars = [], COUNT = window.innerWidth < 768 ? 55 : 90, TRAIL = 12;
  var _FPS = 1000/24, _lastT = 0, _sfId = null, _sfStop = false;
  function resize(){ W = c.width = innerWidth; H = c.height = innerHeight; }
  function make(){
    var a = Math.random()*Math.PI*2, spd = Math.random()*.14+.03;
    return {x:Math.random()*W, y:Math.random()*H, vx:Math.cos(a)*spd, vy:Math.sin(a)*spd,
      r:Math.random()*1.1+.35, alpha:Math.random()*.5+.3,
      tw:Math.random()*Math.PI*2, tws:Math.random()*.008+.003, trail:[]};
  }
  function init(){ resize(); stars = Array.from({length:COUNT}, make); }
  function draw(now){
    if(now - _lastT < _FPS){ if(!_sfStop) _sfId = requestAnimationFrame(draw); return; }
    _lastT = now;
    ctx.fillStyle = 'rgba(8,10,15,.28)'; ctx.fillRect(0,0,W,H);
    for(var i = 0; i < stars.length; i++){
      var s = stars[i];
      s.trail.push({x:s.x, y:s.y}); if(s.trail.length > TRAIL) s.trail.shift();
      s.x += s.vx; s.y += s.vy; s.tw += s.tws;
      if(s.x < -10) s.x = W+10; if(s.x > W+10) s.x = -10;
      if(s.y < -10) s.y = H+10; if(s.y > H+10) s.y = -10;
      for(var t = 1; t < s.trail.length; t++){
        var p = s.trail[t-1], q = s.trail[t], frac = t/s.trail.length;
        ctx.beginPath(); ctx.moveTo(p.x,p.y); ctx.lineTo(q.x,q.y);
        ctx.strokeStyle = 'rgba(0,212,255,'+(s.alpha*frac*.35)+')';
        ctx.lineWidth = s.r*frac; ctx.stroke();
      }
      var tw = Math.sin(s.tw)*.5+.5;
      ctx.beginPath(); ctx.arc(s.x,s.y,s.r*(1+tw*.3),0,Math.PI*2);
      ctx.fillStyle = 'rgba(180,230,255,'+(s.alpha*(.6+tw*.4))+')'; ctx.fill();
    }
    if(!_sfStop) _sfId = requestAnimationFrame(draw);
  }
  document.addEventListener('visibilitychange', function(){
    if(document.hidden){ _sfStop=true; if(_sfId){cancelAnimationFrame(_sfId);_sfId=null;} }
    else{ _sfStop=false; _sfId=requestAnimationFrame(draw); }
  });
  window.addEventListener('resize', resize);
  init(); _sfId = requestAnimationFrame(draw);
})();

/* ════════════════════════════
   NAV DRAWER — GSAP
════════════════════════════ */
try {
(function(){
  if(typeof gsap==='undefined') return;
  var ease = 'power3.inOut';
  try {
    if(typeof CustomEase !== 'undefined'){
      gsap.registerPlugin(CustomEase);
      CustomEase.create('menuEase','0.65, 0.01, 0.05, 0.99');
      ease = 'menuEase';
    }
  } catch(e2){};
  var drawer=document.getElementById('navDrawer'),
      overlay=document.getElementById('navOverlay'),
      toggleBtn=document.getElementById('menuToggleBtn'),
      closeBtn=document.getElementById('navCloseBtn'),
      bgPanels=drawer.querySelectorAll('.nav-bg-panel'),
      menuLinks=drawer.querySelectorAll('.nav-menu-link'),
      menuItems=drawer.querySelectorAll('.nav-menu-item'),
      btnTexts=toggleBtn.querySelectorAll('.menu-button-text p'),
      btnIcon=toggleBtn.querySelector('.menu-button-icon'),
      fadeItems=[document.getElementById('navFadeItem1'),document.getElementById('navFadeItem2')].filter(Boolean),
      isOpen=false;

  gsap.set(drawer,{display:'none',xPercent:0});
  gsap.set(bgPanels,{xPercent:101});
  gsap.set(menuItems,{yPercent:140,rotate:8,opacity:0});
  gsap.set(fadeItems,{autoAlpha:0,yPercent:40});
  gsap.set(overlay,{autoAlpha:0,pointerEvents:'none'});
  if(btnTexts[0]) gsap.set(btnTexts[0],{yPercent:0});
  if(btnTexts[1]) gsap.set(btnTexts[1],{yPercent:100});

  function openNav(){
    isOpen=true; drawer.setAttribute('data-nav','open'); document.body.style.overflow='hidden';
    gsap.set(drawer,{display:'flex'});
    gsap.timeline({defaults:{ease:ease,duration:.7}})
      .to(overlay,{autoAlpha:1,duration:.5,onStart:function(){overlay.style.pointerEvents='all';}})
      .to(bgPanels,{xPercent:0,stagger:.1,duration:.6},'<')
      .to(btnTexts[0],{yPercent:-100,duration:.5},'<')
      .to(btnTexts[1],{yPercent:0,duration:.5},'<+=.12')
      .to(btnIcon,{rotate:315,duration:.5},'<')
      .to(menuItems,{yPercent:0,rotate:0,opacity:1,stagger:.06,duration:.55},'<+=.3')
      .to(fadeItems,{autoAlpha:1,yPercent:0,stagger:.05,duration:.4},'<+=.15');
  }
  function closeNav(){
    isOpen=false; drawer.setAttribute('data-nav','closed');
    overlay.style.pointerEvents='none'; document.body.style.overflow='';
    gsap.timeline({defaults:{ease:ease,duration:.55}})
      .to(overlay,{autoAlpha:0,duration:.4})
      .to(drawer,{xPercent:110,duration:.5},'<')
      .to(btnTexts[0],{yPercent:0,duration:.4},'<')
      .to(btnTexts[1],{yPercent:100,duration:.4},'<')
      .to(btnIcon,{rotate:0,duration:.4},'<')
      .set(drawer,{display:'none',xPercent:0})
      .set(bgPanels,{xPercent:101})
      .set(menuItems,{yPercent:140,rotate:8,opacity:0})
      .set(fadeItems,{autoAlpha:0,yPercent:40});
  }
  toggleBtn.addEventListener('click',function(){ isOpen?closeNav():openNav(); });
  closeBtn.addEventListener('click',closeNav);
  overlay.addEventListener('click',closeNav);
  document.addEventListener('keydown',function(e){ if(e.key==='Escape'&&isOpen) closeNav(); });
  menuLinks.forEach(function(l){ l.addEventListener('click',function(){ if(isOpen) closeNav(); }); });
})();
} catch(e) { /* GSAP nav error suppressed on mobile */ }

/* ════════════════════════════
   DOCUMENT TABS
════════════════════════════ */
(function(){
  var tabs     = document.querySelectorAll('.sidebar-tab');
  var sections = document.querySelectorAll('.doc-section');
  var slugs    = {terms:'/legal?doc=terms',privacy:'/legal?doc=privacy',cookies:'/legal?doc=cookies',offer:'/legal?doc=offer',returns:'/legal?doc=returns'};
  var titles   = {terms:'Пользовательское соглашение — Fm TuN',privacy:'Политика конфиденциальности — Fm TuN',cookies:'Политика Cookie — Fm TuN',offer:'Договор оферты — Fm TuN',returns:'Возврат и обмен — Fm TuN'};

  function activate(d){
    tabs.forEach(function(t){ t.classList.remove('active'); });
    sections.forEach(function(s){ s.classList.remove('active'); });
    var tab = document.querySelector('.sidebar-tab[data-doc="'+d+'"]');
    var sec = document.getElementById('doc-'+d);
    if(tab) tab.classList.add('active');
    if(sec) sec.classList.add('active');
    document.title = titles[d] || 'Документы — Fm TuN';
  }

  tabs.forEach(function(tab){
    tab.addEventListener('click', function(){
      var d = tab.dataset.doc;
      activate(d);
      if(history.replaceState) history.replaceState(null,'', slugs[d]||'/legal');
    });
  });

  // внутренние ссылки между разделами (например, из privacy → cookies)
  document.addEventListener('click', function(e){
    var el = e.target.closest('[data-doc-link]');
    if(el){ e.preventDefault(); activate(el.getAttribute('data-doc-link')); }
  });

  // определить начальный раздел из URL
  var param = new URLSearchParams(window.location.search).get('doc');
  var path  = window.location.pathname;
  var init  = 'terms';
  if(param && slugs[param])              init = param;
  else if(path.includes('privacy'))      init = 'privacy';
  else if(path.includes('cookie'))       init = 'cookies';
  else if(path.includes('offer'))        init = 'offer';
  else if(path.includes('returns'))      init = 'returns';
  activate(init);
})();
</script>

<script nonce="{{ request.state.csp_nonce }}">
/* ════════════════════════════
   THEME SYSTEM
════════════════════════════ */
(function(){
  var KEY = 'fmtun_theme';
  function applyTheme(t){
    document.documentElement.setAttribute('data-theme', t);
    localStorage.setItem(KEY, t);
    document.querySelectorAll('.theme-seg-btn').forEach(function(b){
      b.classList.toggle('seg-active', b.getAttribute('data-seg')===t);
    });
  }
  applyTheme(localStorage.getItem(KEY)||'dark');
  window.importToggleTheme = function(f){
    applyTheme(f||(document.documentElement.getAttribute('data-theme')==='light'?'dark':'light'));
  };
  document.addEventListener('DOMContentLoaded', function(){
    applyTheme(localStorage.getItem(KEY)||'dark');
    document.querySelectorAll('.theme-seg-btn').forEach(function(b){
      b.addEventListener('click', function(){ window.importToggleTheme(b.getAttribute('data-seg')); });
    });
    var r1 = document.getElementById('cookieResetBtn');
    var r2 = document.getElementById('cookieResetBtnCookies');
    if(r1) r1.addEventListener('click', function(){ if(window.cookieConsent) window.cookieConsent.reset(); });
    if(r2) r2.addEventListener('click', function(){ if(window.cookieConsent) window.cookieConsent.reset(); });
  });
})();
</script>
<script src="/static/cookie-consent.js" defer></script>
</body>
</html>
