<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="next-url" content="{{ next_url|default('/') }}">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Fm TuN ‚ÄĒ –ź–≤—ā–ĺ—Ä–ł–∑–į—Ü–ł—Ź</title>
  <link rel="apple-touch-icon" sizes="180x180" href="/static/favicon/apple-touch-icon.png?v=6">
  <link rel="icon" type="image/svg+xml" href="/static/favicon/favicon.svg?v=6">
  <link rel="icon" type="image/png" sizes="512x512" href="/static/favicon/favicon-512x512.png?v=6">
  <link rel="icon" type="image/png" sizes="32x32" href="/static/favicon/favicon-32x32.png?v=6">
  <link rel="icon" type="image/png" sizes="16x16" href="/static/favicon/favicon-16x16.png?v=6">
  <link rel="shortcut icon" href="/static/favicon/favicon.ico?v=6">
  <meta name="theme-color" content="#080A0F">
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/Flip.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/CustomEase.min.js"></script>
  <style nonce="{{ request.state.csp_nonce }}">
    @font-face{font-family:'PP Neue Corp Tight';src:url('https://cdn.prod.website-files.com/673af51dea86ab95d124c3ee/673b0f5784f7060c0ac05534_PPNeueCorp-TightUltrabold.otf') format('opentype');font-weight:700;font-display:swap;}
    :root{
      --blue:#00D4FF;--blue-dim:rgba(0,212,255,.12);--blue-glow:rgba(0,212,255,.25);
      --bg:#080A0F;--bg2:#0D1018;--bg3:#111520;--surface:#161C26;--surface2:#1E2635;
      --border:rgba(255,255,255,.06);--border-h:rgba(0,212,255,.2);
      --text:#F0F4F8;--text2:#7B8599;--text3:#3E4560;
      --green:#00E5A0;--red:#FF4757;--red-dim:rgba(255,71,87,.12);
      --r:10px;--rl:16px;
      --fd:'Syne',sans-serif;--fr:'Rajdhani',sans-serif;--fb:'DM Sans',sans-serif;
      --fn:'PP Neue Corp Tight','Syne',sans-serif;
      --ease:cubic-bezier(.16,1,.3,1);
    }

    /* ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
       LIGHT THEME
    ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź */
    [data-theme="light"] {
      --blue:#E8580A;--blue-dim:rgba(232,88,10,.1);--blue-mid:rgba(232,88,10,.4);--blue-glow:rgba(232,88,10,.22);
      --bg:#F7F4EF;--bg2:#EDE9E3;--bg3:#E4E0D8;
      --surface:#D8D3CA;--surface2:#CBC5BB;
      --border:rgba(0,0,0,.08);--border-h:rgba(232,88,10,.28);--border-hover:rgba(232,88,10,.28);
      --text:#1C1208;--text2:#6B5D4F;--text3:#A89080;
      --green:#1A7A52;--green-dim:rgba(26,122,82,.1);
      --red:#CC2200;--red-dim:rgba(204,34,0,.1);
      --amber:#B8720A;--amber-dim:rgba(184,114,10,.1);
    }
    [data-theme="light"] .header,
    [data-theme="light"] .imp-header { background:rgba(247,244,239,.92)!important; border-bottom-color:rgba(0,0,0,.1)!important; }
    [data-theme="light"] #starfield { opacity:0; }
    [data-theme="light"] .nav-bg-panel.p1,
    [data-theme="light"] .nav-bg-panel.first { background:var(--blue); }
    [data-theme="light"] .nav-bg-panel.p2,
    [data-theme="light"] .nav-bg-panel.second { background:#fff8f3; }
    [data-theme="light"] .nav-bg-panel.p3,
    [data-theme="light"] .nav-bg-panel:not(.first):not(.second):not(.p1):not(.p2) { background:#faf6f1; border-color:rgba(232,88,10,.12); }
    [data-theme="light"] .imp-nav-bg2 { background:#fff8f3; }
    [data-theme="light"] .imp-nav-bg3 { background:#faf6f1; border-color:rgba(232,88,10,.12); }
    [data-theme="light"] .nav-link-heading,
    [data-theme="light"] .nav-menu-heading,
    [data-theme="light"] .imp-nav-heading { color:#1C1208; }
    [data-theme="light"] .nav-text-link,
    [data-theme="light"] .nav-social-link { color:#6B5D4F; }
    [data-theme="light"] .nav-p-small,
    [data-theme="light"] .nav-footer-label { color:#A89080; }
    [data-theme="light"] .filter-bar { background:rgba(247,244,239,.92); border-bottom-color:rgba(0,0,0,.1); }
    [data-theme="light"] .logo-bolt,
    [data-theme="light"] .imp-logo-bolt { background:linear-gradient(135deg,#FFD700,#FFA500)!important; -webkit-background-clip:text!important; -webkit-text-fill-color:transparent!important; background-clip:text!important; filter:drop-shadow(0 0 8px rgba(255,180,0,.45))!important; box-shadow:none!important; }
    [data-theme="light"] .eyebrow-dot { background:var(--blue); box-shadow:0 0 8px var(--blue); }
    [data-theme="light"] .product-card { background:rgba(232,225,215,.7)!important; }
    [data-theme="light"] .adv-card { background:rgba(232,225,215,.5)!important; }
    [data-theme="light"] .team-card { background:rgba(220,213,203,.6)!important; }
    [data-theme="light"] .section-dark { background:rgba(237,233,227,.9); border-color:rgba(0,0,0,.07); }
    [data-theme="light"] .footer { background:var(--bg2); border-color:rgba(0,0,0,.08); }
    [data-theme="light"] .footer-bar { background:var(--bg2); border-color:rgba(0,0,0,.08); }
    [data-theme="light"] body { background:var(--bg); }
    [data-theme="light"] .doc-card { background:rgba(232,225,215,.6); }
    [data-theme="light"] .doc-card-header { background:linear-gradient(135deg,rgba(232,88,10,.06) 0%,transparent 55%); }
    [data-theme="light"] .highlight-box { background:var(--surface); border-left-color:var(--blue); }
    [data-theme="light"] .active-orders-banner { background:rgba(247,244,239,.95); border-top-color:rgba(0,0,0,.08); }
    [data-theme="light"] .cart-drawer { background:var(--bg3); border-left-color:rgba(0,0,0,.1); }
    [data-theme="light"] .user-dropdown { background:var(--bg3); }
    [data-theme="light"] .advantages { background:var(--bg2); }
    html { transition: background-color .25s ease; }
    body { transition: background-color .25s ease, color .25s ease; }

    /* Theme toggle pill */
    .theme-toggle-row { display:flex; align-items:center; justify-content:space-between; padding:0 2em; margin-bottom:1.5em; }
    .theme-row-label { font-family:var(--fr,'Rajdhani',sans-serif); font-size:.7rem; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:rgba(255,255,255,.38); transition:color .25s; }
    [data-theme="light"] .theme-row-label { color:rgba(28,18,8,.38); }
    .theme-pill { position:relative; width:80px; height:36px; background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.12); border-radius:100px; cursor:pointer; display:flex; align-items:center; padding:0 4px; transition:background .25s,border-color .25s; }
    [data-theme="light"] .theme-pill { background:rgba(232,88,10,.1); border-color:rgba(232,88,10,.3); }
    .theme-pill:hover { border-color:rgba(232,88,10,.5); }
    .theme-pill-knob { position:absolute; width:28px; height:28px; background:#fff; border-radius:50%; box-shadow:0 2px 8px rgba(0,0,0,.3); transition:transform .3s cubic-bezier(.16,1,.3,1),background .25s; left:4px; }
    [data-theme="light"] .theme-pill-knob { background:#E8580A; box-shadow:0 2px 12px rgba(232,88,10,.4); }
    .theme-icon { position:absolute; font-size:14px; line-height:1; transition:opacity .25s; pointer-events:none; }
    .theme-icon-moon { left:10px; opacity:1; }
    .theme-icon-sun  { right:8px; opacity:.38; }
    [data-theme="light"] .theme-icon-moon { opacity:.38; }
    [data-theme="light"] .theme-icon-sun  { opacity:1; }

        
    /* ‚ĒÄ‚ĒÄ Theme Segment Control ‚ĒÄ‚ĒÄ */
    .theme-seg{display:flex;align-items:center;justify-content:space-between;padding:.875rem 2rem;border-bottom:1px solid rgba(255,255,255,.06);}
    [data-theme="light"] .theme-seg{border-bottom-color:rgba(0,0,0,.07);}
    .theme-seg-label{font-family:var(--fr,'Rajdhani',sans-serif);font-size:.62rem;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.28);transition:color .25s;}
    [data-theme="light"] .theme-seg-label{color:rgba(0,0,0,.28);}
    .theme-seg-ctrl{display:flex;gap:3px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:8px;padding:3px;transition:background .25s,border-color .25s;}
    [data-theme="light"] .theme-seg-ctrl{background:rgba(0,0,0,.04);border-color:rgba(0,0,0,.08);}
    .theme-seg-btn{display:inline-flex;align-items:center;gap:.4rem;padding:.35rem .75rem;font-family:var(--fr,'Rajdhani',sans-serif);font-size:.68rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;border:none;border-radius:5px;cursor:pointer;background:transparent;color:rgba(255,255,255,.32);transition:color .2s,background .2s;line-height:1;}
    [data-theme="light"] .theme-seg-btn{color:rgba(0,0,0,.3);}
    .theme-seg-btn svg{flex-shrink:0;transition:opacity .2s;}
    .theme-seg-btn.seg-active{color:var(--blue);background:var(--blue-dim);}
    [data-theme="light"] .theme-seg-btn.seg-active{color:var(--blue);background:var(--blue-dim);}

    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    html{height:100%;} body{min-height:100%;overflow-x:hidden;}
    body{font-family:var(--fb);background:var(--bg);color:var(--text);line-height:1.6;-webkit-font-smoothing:antialiased;display:flex;flex-direction:column;min-height:100vh;}
    #starfield{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none}
    .header{position:fixed;top:0;left:0;right:0;background:rgba(0,0,0,.78);backdrop-filter:blur(24px);border-bottom:1px solid var(--border);z-index:200}
    .header-inner{display:flex;align-items:center;justify-content:space-between;height:64px;padding:0 1.5rem}
    .logo{display:flex;align-items:center;gap:10px;font-family:var(--fd);font-size:1.25rem;font-weight:800;color:var(--text);text-decoration:none;letter-spacing:.08em}
    .logo-bolt{width:32px;height:32px;display:flex;align-items:center;justify-content:center;font-size:22px;background:linear-gradient(135deg,#FFD700,#FFA500);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;filter:drop-shadow(0 0 8px rgba(255,190,0,.55))}
    .logo-text span{color:var(--blue)}
    .header-back{display:flex;align-items:center;gap:.4rem;font-family:var(--fr);font-size:.8rem;font-weight:600;color:var(--text2);text-decoration:none;letter-spacing:.08em;text-transform:uppercase;transition:color .2s;cursor:pointer}
    .header-back:hover{color:var(--blue)}
    /* ‚ĒÄ‚ĒÄ AUTH PAGE: unified full-screen layout ‚ĒÄ‚ĒÄ */
    .auth-page{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;flex:1;padding-top:calc(64px + 2.5rem);padding-bottom:3rem;justify-content:center;}
    .auth-left{width:100%;max-width:520px;display:flex;align-items:center;justify-content:center;padding:3rem 2rem;overflow-y:auto;position:relative;z-index:2;}
    .auth-left-inner{width:100%;max-width:460px;background:rgba(6,8,14,.85);padding:2.5rem;border-radius:1.5rem;border:1px solid rgba(255,255,255,.08);box-shadow:0 24px 80px rgba(0,0,0,.6),0 0 0 1px rgba(0,212,255,.05);}
    [data-theme="light"] .auth-left-inner{background:rgba(247,244,239,.96);border-color:rgba(0,0,0,.1);box-shadow:0 24px 80px rgba(0,0,0,.12),0 0 0 1px rgba(232,88,10,.05);}

    .auth-heading{font-family:var(--fd);font-size:clamp(1.35rem,2vw,1.85rem);font-weight:800;letter-spacing:-.02em;line-height:1.1;margin-bottom:1.75rem}
    .auth-heading .accent{color:transparent;background:linear-gradient(135deg,#00D4FF 0%,#7ff3ff 50%,#00D4FF 100%);background-size:200% auto;-webkit-background-clip:text;background-clip:text;animation:gradShift 3s ease-in-out infinite}
    @keyframes gradShift{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}

    /* ‚ĒÄ‚ĒÄ –Ę–ź–Ď–ę: —Ą–ł–ļ—Ā –ľ–ĺ–Ī–į–Ļ–Ľ ‚ĒÄ‚ĒÄ */
    .tabs-nav{
      display:flex;align-items:center;margin-bottom:2rem;position:relative;
      background:var(--bg2);border:1px solid var(--border);border-radius:var(--rl);
      padding:4px;width:100%; /* –∑–į–Ĺ–ł–ľ–į–Ķ—ā –≤—Ā—é –ī–ĺ—Ā—ā—É–Ņ–Ĺ—É—é —ą–ł—Ä–ł–Ĺ—É */
    }
    [data-flip-button="bg"]{position:absolute;background:var(--surface2);border:1px solid var(--border-h);border-radius:calc(var(--rl) - 2px);inset:4px;z-index:0;pointer-events:none}
    [data-flip-button="button"]{
      position:relative;z-index:1;
      flex:1; /* –ļ–į–∂–ī–į—Ź –ļ–Ĺ–ĺ–Ņ–ļ–į –∑–į–Ĺ–ł–ľ–į–Ķ—ā —Ä–į–≤–Ĺ—É—é –ī–ĺ–Ľ—é */
      padding:.45rem .5rem;
      font-family:var(--fr);font-size:.82rem;font-weight:600;letter-spacing:.04em;
      text-transform:uppercase;color:var(--text2);background:none;border:none;
      cursor:pointer;transition:color .2s;border-radius:calc(var(--rl) - 2px);
      white-space:nowrap;text-align:center;
    }
    [data-flip-button="button"].active,[data-flip-button="button"]:hover{color:var(--text)}

    .tab-content-wrap{position:relative;min-height:36em}
    [data-tabs="content-item"]{position:absolute;inset:0;opacity:0;pointer-events:none}
    [data-tabs="content-item"].active{opacity:1;pointer-events:all}
    .form-group{margin-bottom:1.25rem}
    .form-label{display:block;font-family:var(--fr);font-size:.75rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--text2);margin-bottom:.5rem}
    .form-input{width:100%;background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:.75rem 1rem;font-family:var(--fb);font-size:.95rem;color:var(--text);outline:none;transition:border-color .2s,box-shadow .2s;cursor:text}
    .form-input:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(0,212,255,.08)}
    .form-input::placeholder{color:var(--text3)}
    .form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
    .form-footer{font-size:.85rem;color:var(--text2);margin-top:1.25rem;text-align:center}
    .form-link{color:var(--blue);text-decoration:none;transition:opacity .2s;cursor:pointer}
    .form-link:hover{opacity:.75}
    .restore-hint{font-size:.875rem;color:var(--text2);line-height:1.6;margin-bottom:1.5rem;padding:1rem;background:var(--blue-dim);border:1px solid rgba(0,212,255,.12);border-radius:var(--r)}
    .btn-submit{width:100%;margin-top:1.5rem;padding:.875rem;font-family:var(--fr);font-size:1rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#080A0F;background:linear-gradient(135deg,var(--blue),#0099CC);border:none;border-radius:var(--r);cursor:pointer;transition:opacity .2s,transform .15s;box-shadow:0 4px 24px rgba(0,212,255,.2)}
    .btn-submit:hover{opacity:.9;transform:translateY(-1px)}
    .input-wrap{position:relative}
    .input-wrap .form-input{padding-right:3rem}
    .pw-toggle{position:absolute;right:.875rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text3);transition:color .2s,opacity .2s;padding:0;display:flex;align-items:center;justify-content:center;width:20px;height:20px}
    .pw-toggle:hover{color:var(--blue)}
    .pw-toggle svg{width:18px;height:18px;display:block}
    .pw-toggle .eye-slash{display:none}
    .pw-toggle.revealed .eye-open{display:none}
    .pw-toggle.revealed .eye-slash{display:block}
    /* animation panel - full screen background behind form */
    .auth-right{position:fixed;inset:64px 0 0 0;z-index:0;display:flex;align-items:center;justify-content:center;overflow:hidden;pointer-events:none;}
    .visual-bg{position:absolute;inset:0;background:radial-gradient(ellipse at 60% 40%,rgba(0,212,255,.04) 0%,transparent 60%)}
    .visual-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(0,212,255,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(0,212,255,.025) 1px,transparent 1px);background-size:50px 50px;mask-image:radial-gradient(ellipse 70% 80% at 50% 50%,black 0%,transparent 100%)}
    .visual-orb{position:absolute;border-radius:50%;filter:blur(60px);animation:orbPulse 6s ease-in-out infinite}
    .visual-orb--1{width:600px;height:600px;background:radial-gradient(circle,rgba(0,212,255,.05),transparent 70%);top:5%;right:10%}
    .visual-orb--2{width:400px;height:400px;background:radial-gradient(circle,rgba(0,100,200,.04),transparent 70%);bottom:10%;left:20%;animation-delay:-3s}
    @keyframes orbPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.12)}}
    .visual-corner{position:absolute;width:2.5em;height:2.5em;border-color:rgba(0,212,255,.18);border-style:solid}
    .visual-corner--tl{top:1.5rem;left:1.5rem;border-width:1px 0 0 1px}
    .visual-corner--br{bottom:1.5rem;right:1.5rem;border-width:0 1px 1px 0}

    /* ‚ĒÄ‚ĒÄ looping words (same as index preloader) ‚ĒÄ‚ĒÄ */
    .visual-content{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);z-index:2;pointer-events:none;}
    .lw-wrap{position:relative;display:flex;align-items:center;justify-content:center;}
    .lw-clip{overflow:hidden;height:1.25em;display:flex;align-items:center;justify-content:center;min-width:8em;}
    #auth-lw-track{display:flex;flex-direction:column;align-items:center;}
    .lw-item{display:flex;align-items:center;justify-content:center;padding:.1em 0;}
    .lw-text{font-family:var(--fn);font-size:clamp(2rem,4vw,4.5rem);font-weight:700;letter-spacing:.2em;text-transform:uppercase;white-space:nowrap;color:transparent;background:linear-gradient(90deg,var(--blue),#F0F4F8,var(--blue));background-size:200%;-webkit-background-clip:text;background-clip:text;}
    #auth-lw-selector{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);pointer-events:none;}
    .lw-corner{position:absolute;width:20px;height:13px;border-color:rgba(0,212,255,.7);border-style:solid;}
    .lw-corner.tl{top:0;left:0;border-width:1.5px 0 0 1.5px}
    .lw-corner.tr{top:0;right:0;border-width:1.5px 1.5px 0 0}
    .lw-corner.bl{bottom:0;left:0;border-width:0 0 1.5px 1.5px}
    .lw-corner.br{bottom:0;right:0;border-width:0 1.5px 1.5px 0}

    @media(max-width:900px){
      html,body{overflow:auto}
      .auth-page{flex-direction:column-reverse}
      .auth-left{width:100%;}
      .auth-left{padding:2rem 1.25rem;justify-content:center;overflow:visible}
      .auth-right{display:none;}  /* hide animation on mobile */
      .tab-content-wrap{min-height:32em}
      .form-row{grid-template-columns:1fr}
      .visual-words{height:1.8em}
      .visual-word{font-size:clamp(1rem,5vw,1.2rem)}

      /* –ú–ĺ–Ī–į–Ļ–Ľ: –Ķ—Č—Ď –ľ–Ķ–Ĺ—Ć—ą–Ķ —ą—Ä–ł—Ą—ā –≤ —ā–į–Ī–į—Ö –Ķ—Ā–Ľ–ł —Ā–ĺ–≤—Ā–Ķ–ľ —É–∑–ļ–ĺ */
      [data-flip-button="button"]{font-size:.72rem;letter-spacing:.02em;padding:.4rem .3rem;}
    }

    @media(max-width:360px){
      [data-flip-button="button"]{font-size:.65rem;padding:.38rem .2rem;}
    }
    /* ‚ĒÄ‚ĒÄ AUTH FOOTER ‚ĒÄ‚ĒÄ */
    .auth-footer{background:var(--bg2);border-top:1px solid var(--border);padding:1.25rem 2rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;position:relative;z-index:10;}
    .auth-footer span{font-family:var(--fr);font-size:.8rem;color:var(--text3);letter-spacing:.05em;}
    .auth-footer-links{display:flex;gap:1.5rem;flex-wrap:wrap;}
    .auth-footer-links a{font-family:var(--fr);font-size:.8rem;color:var(--text3);text-decoration:none;transition:color .2s;letter-spacing:.05em;}
    .auth-footer-links a:hover{color:var(--blue);}
  </style>
<script src="/static/csrf-init.js"></script>
</head>
<body>
<canvas id="starfield"></canvas>
<header class="header">
  <div class="header-inner">
    <a href="/" class="logo"><div class="logo-bolt">&#9889;</div><span class="logo-text">Fm <span>TuN</span></span></a>
    <a href="{{ next_url|default('/') }}" class="header-back">‚Üź –Ě–į–∑–į–ī</a>

  </div>
</header>
<div class="auth-page">
  <div class="auth-left">
    <div class="auth-left-inner">
      <h1 class="auth-heading" data-tabs-fade>–í—Ö–ĺ–ī –≤ <span class="accent">Fm TuN</span></h1>
      <nav class="tabs-nav" data-flip-button="wrap">
        <div data-flip-button="bg"></div>
        <button class="active" data-flip-button="button" data-tabs="button">–í—Ö–ĺ–ī</button>
        <button data-flip-button="button" data-tabs="button">–†–Ķ–≥–ł—Ā—ā—Ä–į—Ü–ł—Ź</button>
        <button data-flip-button="button" data-tabs="button">–í–ĺ—Ā—Ā—ā–į–Ĺ–ĺ–≤–Ľ–Ķ–Ĺ–ł–Ķ</button>
      </nav>
      <div class="tab-content-wrap" data-tabs="content-wrap">
        <div data-tabs="content-item">
          <div data-tabs-fade class="form-group"><label class="form-label">–õ–ĺ–≥–ł–Ĺ</label><input class="form-input" type="text" placeholder="username" autocomplete="username"></div>
          <div data-tabs-fade class="form-group"><label class="form-label">–ü–į—Ä–ĺ–Ľ—Ć</label><div class="input-wrap"><input class="form-input" type="password" placeholder="‚ÄĘ‚ÄĘ‚ÄĘ‚ÄĘ‚ÄĘ‚ÄĘ‚ÄĘ‚ÄĘ" autocomplete="current-password"><button class="pw-toggle" type="button" aria-label="–ü–ĺ–ļ–į–∑–į—ā—Ć –Ņ–į—Ä–ĺ–Ľ—Ć"><svg class="eye-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/><circle cx="12" cy="12" r="3"/></svg><svg class="eye-slash" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-6.5 0-10-8-10-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c6.5 0 10 8 10 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg></button></div></div>
          <div data-tabs-fade class="form-footer"><a href="#" class="form-link" id="toRestore">–ó–į–Ī—č–Ľ–ł –Ņ–į—Ä–ĺ–Ľ—Ć?</a></div>
          <button data-tabs-fade class="btn-submit">–í–ĺ–Ļ—ā–ł ‚Üí</button>
          <div data-tabs-fade class="form-footer" style="margin-top:.75rem">–Ě–Ķ—ā –į–ļ–ļ–į—É–Ĺ—ā–į? <a href="#" class="form-link" id="toRegister">–ó–į—Ä–Ķ–≥–ł—Ā—ā—Ä–ł—Ä–ĺ–≤–į—ā—Ć—Ā—Ź</a></div>
        </div>
        <div data-tabs="content-item">
          <div data-tabs-fade class="form-row">
            <div class="form-group"><label class="form-label">–ė–ľ—Ź</label><input class="form-input" type="text" placeholder="–ź–Ľ–Ķ–ļ—Ā–Ķ–Ļ"></div>
            <div class="form-group"><label class="form-label">–§–į–ľ–ł–Ľ–ł—Ź</label><input class="form-input" type="text" placeholder="–ė–≤–į–Ĺ–ĺ–≤"></div>
          </div>
          <div data-tabs-fade class="form-group"><label class="form-label">Email</label><input class="form-input" type="email" placeholder="you@example.com"></div>
          <div data-tabs-fade class="form-group"><label class="form-label">–õ–ĺ–≥–ł–Ĺ</label><input class="form-input" type="text" placeholder="username"></div>
          <div data-tabs-fade class="form-group"><label class="form-label">–ü–į—Ä–ĺ–Ľ—Ć</label><div class="input-wrap"><input class="form-input" type="password" placeholder="–ú–ł–Ĺ–ł–ľ—É–ľ 8 —Ā–ł–ľ–≤–ĺ–Ľ–ĺ–≤"><button class="pw-toggle" type="button" aria-label="–ü–ĺ–ļ–į–∑–į—ā—Ć –Ņ–į—Ä–ĺ–Ľ—Ć"><svg class="eye-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/><circle cx="12" cy="12" r="3"/></svg><svg class="eye-slash" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-6.5 0-10-8-10-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c6.5 0 10 8 10 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg></button></div></div>
          <label data-tabs-fade style="display:flex;align-items:flex-start;gap:.625rem;margin:.5rem 0 .75rem;cursor:pointer;">
            <input type="checkbox" id="authPrivacyCb" required style="width:16px;height:16px;margin-top:2px;accent-color:#00D4FF;flex-shrink:0;">
            <span style="font-size:.775rem;color:#7B8599;line-height:1.5;">–Į –Ņ—Ä–ł–Ĺ–ł–ľ–į—é <a href="/privacy-policy" target="_blank" style="color:#00D4FF;text-decoration:none;">–ü–ĺ–Ľ–ł—ā–ł–ļ—É –ļ–ĺ–Ĺ—Ą–ł–ī–Ķ–Ĺ—Ü–ł–į–Ľ—Ć–Ĺ–ĺ—Ā—ā–ł</a> –ł –ī–į—é —Ā–ĺ–≥–Ľ–į—Ā–ł–Ķ –Ĺ–į –ĺ–Ī—Ä–į–Ī–ĺ—ā–ļ—É –Ņ–Ķ—Ä—Ā–ĺ–Ĺ–į–Ľ—Ć–Ĺ—č—Ö –ī–į–Ĺ–Ĺ—č—Ö –≤ —Ā–ĺ–ĺ—ā–≤–Ķ—ā—Ā—ā–≤–ł–ł —Ā 152-–§–ó</span>
          </label>
          <button data-tabs-fade class="btn-submit">–°–ĺ–∑–ī–į—ā—Ć –į–ļ–ļ–į—É–Ĺ—ā ‚Üí</button>
          <div data-tabs-fade class="form-footer">–£–∂–Ķ –Ķ—Ā—ā—Ć –į–ļ–ļ–į—É–Ĺ—ā? <a href="#" class="form-link" id="toLogin">–í–ĺ–Ļ—ā–ł</a></div>
        </div>
        <div data-tabs="content-item">
          <div data-tabs-fade class="form-group"><label class="form-label">Email</label><input class="form-input" type="email" placeholder="you@example.com"></div>
          <div data-tabs-fade class="restore-hint">–í–≤–Ķ–ī–ł—ā–Ķ email, —É–ļ–į–∑–į–Ĺ–Ĺ—č–Ļ –Ņ—Ä–ł —Ä–Ķ–≥–ł—Ā—ā—Ä–į—Ü–ł–ł ‚ÄĒ –ľ—č –ĺ—ā–Ņ—Ä–į–≤–ł–ľ —Ā—Ā—č–Ľ–ļ—É –ī–Ľ—Ź —Ā–Ī—Ä–ĺ—Ā–į –Ņ–į—Ä–ĺ–Ľ—Ź.</div>
          <div data-tabs-fade class="form-footer">–í—Ā–Ņ–ĺ–ľ–Ĺ–ł–Ľ–ł –Ņ–į—Ä–ĺ–Ľ—Ć? <a href="#" class="form-link" id="toLoginRestore">–í–ĺ–Ļ—ā–ł</a></div>
          <button data-tabs-fade class="btn-submit">–ě—ā–Ņ—Ä–į–≤–ł—ā—Ć —Ā—Ā—č–Ľ–ļ—É ‚Üí</button>
        </div>
      </div>
    </div>
  </div>
  <div class="auth-right">
    <div class="visual-bg"></div>
    <div class="visual-grid"></div>
    <div class="visual-orb visual-orb--1"></div>
    <div class="visual-orb visual-orb--2"></div>
    <div class="visual-corner visual-corner--tl"></div>
    <div class="visual-corner visual-corner--br"></div>
    <div class="visual-content">
      <div class="lw-wrap">
        <div class="lw-clip">
          <div id="auth-lw-track">
            <div class="lw-item"><span class="lw-text" id="alw0">–ö–į—á–Ķ—Ā—ā–≤–ĺ</span></div>
            <div class="lw-item"><span class="lw-text" id="alw1">–°–ļ–ĺ—Ä–ĺ—Ā—ā—Ć</span></div>
            <div class="lw-item"><span class="lw-text" id="alw2">–ď–į—Ä–į–Ĺ—ā–ł—Ź</span></div>
            <div class="lw-item"><span class="lw-text" id="alw3">Fm TuN</span></div>
          </div>
        </div>
        <div id="auth-lw-selector">
          <div class="lw-corner tl"></div><div class="lw-corner tr"></div>
          <div class="lw-corner bl"></div><div class="lw-corner br"></div>
        </div>
      </div>
    </div>
  </div>
</div>
<script nonce="{{ request.state.csp_nonce }}">
// ‚ĒÄ‚ĒÄ FIX 1: —Ä–Ķ–≥–ł—Ā—ā—Ä–ł—Ä—É–Ķ–ľ –Ņ–Ľ–į–≥–ł–Ĺ—č GSAP –ī–ĺ –ł—Ā–Ņ–ĺ–Ľ—Ć–∑–ĺ–≤–į–Ĺ–ł—Ź ‚ĒÄ‚ĒÄ
gsap.registerPlugin(Flip, CustomEase);

(function(){
  var c=document.getElementById('starfield'),ctx=c.getContext('2d');
  var W,H,stars=[],COUNT=window.innerWidth<768?55:90,TRAIL=12;
  var _FPS=1000/24,_lastT=0;
  function resize(){W=c.width=innerWidth;H=c.height=innerHeight;}
  function make(){var a=Math.random()*Math.PI*2,spd=Math.random()*.14+.03;return{x:Math.random()*W,y:Math.random()*H,vx:Math.cos(a)*spd,vy:Math.sin(a)*spd,r:Math.random()*1.1+.35,alpha:Math.random()*.5+.3,tw:Math.random()*Math.PI*2,tws:Math.random()*.008+.003,trail:[]};}
  function init(){resize();stars=Array.from({length:COUNT},make);}
  function draw(now){
    if(now-_lastT<_FPS){if(!_sfStop)_sfId=requestAnimationFrame(draw);return;}
    _lastT=now;
    ctx.fillStyle='rgba(8,10,15,.28)';ctx.fillRect(0,0,W,H);
    for(var i=0;i<stars.length;i++){
      var s=stars[i];s.trail.push({x:s.x,y:s.y});if(s.trail.length>TRAIL)s.trail.shift();
      s.x+=s.vx;s.y+=s.vy;s.tw+=s.tws;
      if(s.x<-10)s.x=W+10;if(s.x>W+10)s.x=-10;if(s.y<-10)s.y=H+10;if(s.y>H+10)s.y=-10;
      for(var t=1;t<s.trail.length;t++){var p=s.trail[t-1],q=s.trail[t],frac=t/s.trail.length;ctx.beginPath();ctx.moveTo(p.x,p.y);ctx.lineTo(q.x,q.y);ctx.strokeStyle='rgba(0,212,255,'+(s.alpha*frac*.35)+')';ctx.lineWidth=s.r*frac;ctx.stroke();}
      var tw=Math.sin(s.tw)*.5+.5;ctx.beginPath();ctx.arc(s.x,s.y,s.r*(1+tw*.3),0,Math.PI*2);ctx.fillStyle='rgba(180,230,255,'+(s.alpha*(0.6+tw*.4))+')';ctx.fill();
    }
    if(!_sfStop)_sfId=requestAnimationFrame(draw);
  }
  // Fix –ó–ź–ú-01: –Ņ–į—É–∑–į starfield –Ņ—Ä–ł —Ā–ļ—Ä—č—ā–ĺ–Ļ –≤–ļ–Ľ–į–ī–ļ–Ķ
  var _sfId=null,_sfStop=false;
  document.addEventListener('visibilitychange',function(){
    if(document.hidden){_sfStop=true;if(_sfId){cancelAnimationFrame(_sfId);_sfId=null;}}
    else{_sfStop=false;_sfId=requestAnimationFrame(draw);}
  });
  window.addEventListener('resize',resize);init();_sfId=requestAnimationFrame(draw);
})();

function initFlipButtons(){
  document.querySelectorAll('[data-flip-button="wrap"]').forEach(function(wrapper){
    var buttons=wrapper.querySelectorAll('[data-flip-button="button"]');
    var bg=wrapper.querySelector('[data-flip-button="bg"]');
    buttons.forEach(function(btn){
      btn.addEventListener('mouseenter',function(){var s=Flip.getState(bg);this.appendChild(bg);Flip.from(s,{duration:.4});});
      btn.addEventListener('focus',function(){var s=Flip.getState(bg);this.appendChild(bg);Flip.from(s,{duration:.4});});
      btn.addEventListener('mouseleave',function(){var s=Flip.getState(bg);wrapper.querySelector('.active').appendChild(bg);Flip.from(s,{duration:.4});});
      btn.addEventListener('blur',function(){var s=Flip.getState(bg);wrapper.querySelector('.active').appendChild(bg);Flip.from(s,{duration:.4});});
    });
  });
}

function initTabSystem(){
  var buttons=document.querySelectorAll('[data-flip-button="button"]');
  var wrap=document.querySelector('[data-tabs="content-wrap"]');
  var items=wrap.querySelectorAll('[data-tabs="content-item"]');
  var activeBtn=buttons[0],activeItem=items[0],animating=false;
  function switchTab(i,init){
    if(!init&&(animating||buttons[i]===activeBtn))return;
    animating=true;
    var out=activeItem,inn=items[i];
    var tl=gsap.timeline({defaults:{ease:'power3.inOut'},onComplete:function(){if(!init)out.classList.remove('active');activeItem=inn;animating=false;}});
    inn.classList.add('active');
    tl.to(out.querySelectorAll('[data-tabs-fade]'),{y:'-2em',autoAlpha:0},0)
      .fromTo(inn.querySelectorAll('[data-tabs-fade]'),{y:'2em',autoAlpha:0},{y:'0em',autoAlpha:1,stagger:.07},0.35);
    activeBtn&&activeBtn.classList.remove('active');
    buttons[i].classList.add('active');activeBtn=buttons[i];
  }
  switchTab(0,true);
  buttons.forEach(function(b,i){b.addEventListener('click',function(){switchTab(i);});});
  items[0].classList.add('active');buttons[0].classList.add('active');
  var toReg=document.getElementById('toRegister');
  var toLgn=document.getElementById('toLogin');
  var toRst=document.getElementById('toRestore');
  var toLgnR=document.getElementById('toLoginRestore');
  if(toReg)toReg.addEventListener('click',function(e){e.preventDefault();switchTab(1);});
  if(toLgn)toLgn.addEventListener('click',function(e){e.preventDefault();switchTab(0);});
  if(toRst)toRst.addEventListener('click',function(e){e.preventDefault();switchTab(2);});
  if(toLgnR)toLgnR.addEventListener('click',function(e){e.preventDefault();switchTab(0);});
}

function initWords(){
  var track=document.getElementById('auth-lw-track');
  var selector=document.getElementById('auth-lw-selector');
  var spans=['alw0','alw1','alw2','alw3'].map(function(id){return document.getElementById(id);});
  if(!track||!selector||typeof gsap==='undefined'||!spans[0])return;

  var itemH=track.children[0].getBoundingClientRect().height||60;
  gsap.set(selector,{height:itemH});

  function trackY(idx){return -(idx*itemH)+itemH*0;}
  function bracketTo(idx,animate){
    var w=spans[idx].getBoundingClientRect().width+20;
    if(animate)gsap.to(selector,{width:w,duration:.4,ease:'power2.out'});
    else gsap.set(selector,{width:w});
  }
  function goTo(idx,onDone){
    bracketTo(idx,true);
    gsap.to(track,{y:trackY(idx),duration:1.05,ease:'elastic.out(1,.82)',onComplete:onDone||null});
  }

  // –ü–Ľ–į–≤–Ĺ—č–Ļ —Ü–ł–ļ–Ľ: 0‚Üí1‚Üí2‚Üí3‚Üí0‚Üí...
  var current=0;
  bracketTo(0,false);
  gsap.set(track,{y:trackY(0)});
  // –¶–≤–Ķ—ā –≥—Ä–į–ī–ł–Ķ–Ĺ—ā–į ‚ÄĒ –į–Ĺ–ł–ľ–į—Ü–ł—Ź
  spans.forEach(function(s){
    gsap.to(s,{backgroundPosition:'200% center',duration:3,ease:'none',repeat:-1});
  });

  function loop(){
    var next=(current+1)%spans.length;
    goTo(next,function(){
      current=next;
      gsap.delayedCall(1.8,loop);
    });
  }
  gsap.delayedCall(1.4,loop);
}

// ‚ĒÄ‚ĒÄ NEXT URL from template or query param ‚ĒÄ‚ĒÄ
var NEXT_URL = (function(){
  var meta = document.querySelector('meta[name="next-url"]');
  if(meta) return meta.content || '/';
  var p = new URLSearchParams(location.search).get('next');
  return p || '/';
})();

// ‚ĒÄ‚ĒÄ Toast helper ‚ĒÄ‚ĒÄ
function authToast(type, msg) {
  var el = document.getElementById('authToast');
  if(!el){ el=document.createElement('div'); el.id='authToast';
    el.style.cssText='position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(1rem);padding:.75rem 1.5rem;border-radius:100px;font-size:.875rem;opacity:0;pointer-events:none;transition:all .3s;z-index:9999;white-space:nowrap;font-family:var(--fd)';
    document.body.appendChild(el); }
  el.textContent=msg;
  el.style.background=type==='error'?'rgba(255,71,87,.15)':'rgba(0,229,160,.15)';
  el.style.color=type==='error'?'#FF4757':'#00E5A0';
  el.style.border='1px solid '+(type==='error'?'rgba(255,71,87,.3)':'rgba(0,229,160,.3)');
  el.style.opacity='1'; el.style.transform='translateX(-50%) translateY(0)';
  setTimeout(function(){ el.style.opacity='0'; el.style.transform='translateX(-50%) translateY(1rem)'; },3500);
}

document.addEventListener('DOMContentLoaded',function(){
  // pw-toggle: show/hide password
  document.querySelectorAll('.pw-toggle').forEach(function(btn){
    btn.addEventListener('click',function(){
      var inp=this.closest('.input-wrap').querySelector('.form-input');
      var show=inp.type==='password';
      inp.type=show?'text':'password';
      this.classList.toggle('revealed',show);
    });
  });
  initTabSystem();initFlipButtons();initWords();

  // ‚ĒÄ‚ĒÄ Get all tab content items ‚ĒÄ‚ĒÄ
  var tabs = document.querySelectorAll('[data-tabs="content-item"]');
  var loginTab = tabs[0], regTab = tabs[1];

  // ‚ĒÄ‚ĒÄ LOGIN ‚ĒÄ‚ĒÄ
  var loginBtn = loginTab.querySelector('.btn-submit');
  loginBtn.addEventListener('click', async function(){
    var username = loginTab.querySelector('input[type="text"]').value.trim();
    var password = loginTab.querySelector('input[type="password"]').value;
    if(!username || !password){ authToast('error','–ó–į–Ņ–ĺ–Ľ–Ĺ–ł—ā–Ķ –≤—Ā–Ķ –Ņ–ĺ–Ľ—Ź'); return; }
    loginBtn.disabled=true; loginBtn.textContent='–í—Ö–ĺ–ī–ł–ľ‚Ä¶';
    try{
      var r = await fetch('/api/login',{method:'POST',credentials:'include',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({username:username,password:password})});
      var d = await r.json();
      if(r.ok){ authToast('success','–Ē–ĺ–Ī—Ä–ĺ –Ņ–ĺ–∂–į–Ľ–ĺ–≤–į—ā—Ć!');
        setTimeout(function(){ window.location.href=NEXT_URL; },600); }
      else{ authToast('error',d.detail||'–Ě–Ķ–≤–Ķ—Ä–Ĺ—č–Ļ –Ľ–ĺ–≥–ł–Ĺ –ł–Ľ–ł –Ņ–į—Ä–ĺ–Ľ—Ć'); loginBtn.disabled=false; loginBtn.textContent='–í–ĺ–Ļ—ā–ł ‚Üí'; }
    }catch(e){ authToast('error','–ě—ą–ł–Ī–ļ–į —Ā–ĺ–Ķ–ī–ł–Ĺ–Ķ–Ĺ–ł—Ź'); loginBtn.disabled=false; loginBtn.textContent='–í–ĺ–Ļ—ā–ł ‚Üí'; }
  });

  // ‚ĒÄ‚ĒÄ REGISTER ‚ĒÄ‚ĒÄ
  var regBtn = regTab.querySelector('.btn-submit');
  regBtn.addEventListener('click', async function(){
    var inputs = regTab.querySelectorAll('.form-input');
    var fname = inputs[0].value.trim(), lname = inputs[1].value.trim(),
        email = inputs[2].value.trim(), username = inputs[3].value.trim(),
        password = inputs[4].value;
    if(!fname||!email||!username||!password){ authToast('error','–ó–į–Ņ–ĺ–Ľ–Ĺ–ł—ā–Ķ –≤—Ā–Ķ –Ņ–ĺ–Ľ—Ź'); return; }
    if(!document.getElementById('authPrivacyCb').checked){ authToast('error','–ü—Ä–ł–ľ–ł—ā–Ķ –Ņ–ĺ–Ľ–ł—ā–ł–ļ—É –ļ–ĺ–Ĺ—Ą–ł–ī–Ķ–Ĺ—Ü–ł–į–Ľ—Ć–Ĺ–ĺ—Ā—ā–ł'); return; }
    if(password.length<8){ authToast('error','–ü–į—Ä–ĺ–Ľ—Ć –ľ–ł–Ĺ–ł–ľ—É–ľ 8 —Ā–ł–ľ–≤–ĺ–Ľ–ĺ–≤'); return; }
    regBtn.disabled=true; regBtn.textContent='–°–ĺ–∑–ī–į—Ď–ľ‚Ä¶';
    try{
      var r = await fetch('/api/register',{method:'POST',credentials:'include',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({username:username,email:email,full_name:(fname+' '+lname).trim(),password:password,privacy_accepted:true})});
      var d = await r.json();
      if(r.ok){ authToast('success','–ź–ļ–ļ–į—É–Ĺ—ā —Ā–ĺ–∑–ī–į–Ĺ! –í—Ö–ĺ–ī–ł–ľ‚Ä¶');
        // auto-login
        var lr = await fetch('/api/login',{method:'POST',credentials:'include',headers:{'Content-Type':'application/json'},
          body:JSON.stringify({username:username,password:password})});
        if(lr.ok){ /* cookie set by server */ }
        setTimeout(function(){ window.location.href=NEXT_URL; },800); }
      else{ authToast('error',d.detail||'–ě—ą–ł–Ī–ļ–į —Ä–Ķ–≥–ł—Ā—ā—Ä–į—Ü–ł–ł'); regBtn.disabled=false; regBtn.textContent='–°–ĺ–∑–ī–į—ā—Ć –į–ļ–ļ–į—É–Ĺ—ā ‚Üí'; }
    }catch(e){ authToast('error','–ě—ą–ł–Ī–ļ–į —Ā–ĺ–Ķ–ī–ł–Ĺ–Ķ–Ĺ–ł—Ź'); regBtn.disabled=false; regBtn.textContent='–°–ĺ–∑–ī–į—ā—Ć –į–ļ–ļ–į—É–Ĺ—ā ‚Üí'; }
  });
});
</script>
<script nonce="{{ request.state.csp_nonce }}">
/* ‚ēź‚ēź THEME SYSTEM ‚ēź‚ēź */
(function(){
  var KEY='fmtun_theme';
  function updateSegs(t){
    document.querySelectorAll('.theme-seg-btn').forEach(function(b){
      b.classList.toggle('seg-active', b.getAttribute('data-seg')===t);
    });
  }
  function applyTheme(t){
    document.documentElement.setAttribute('data-theme',t);
    localStorage.setItem(KEY,t);
    updateSegs(t);
    // legacy knob support
    document.querySelectorAll('.theme-pill-knob').forEach(function(k){
      k.style.transform = t==='light'?'translateX(44px)':'translateX(0)';
    });
  }
  applyTheme(localStorage.getItem(KEY)||'dark');
  window.importToggleTheme=function(forced){
    applyTheme(forced||(document.documentElement.getAttribute('data-theme')==='light'?'dark':'light'));
  };
  document.addEventListener('DOMContentLoaded',function(){
    applyTheme(localStorage.getItem(KEY)||'dark');
    document.querySelectorAll('.theme-seg-btn').forEach(function(b){
      b.addEventListener('click',function(){ window.importToggleTheme(b.getAttribute('data-seg')); });
    });
    // legacy pill
    document.querySelectorAll('.theme-pill').forEach(function(p){ p.addEventListener('click',window.importToggleTheme); });
  });
})();
</script>

