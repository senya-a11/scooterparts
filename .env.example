# ══════════════════════��════════════════════════════
# ScooterParts — шаблон переменных окружения
# Скопируйте этот файл в .env и заполните значения
# НЕ КОММИТЬТЕ .env с реальными значениями в git!
# ═══════════════════════════════════════════════════

# ── База данных ──
# Для локальной разработки (docker-compose):
DATABASE_URL=postgresql://user:password@db:5432/scooterparts
# Для Render.com / VPS — используйте полный URL с credentials из панели управления

# ── Безопасность ──
# Генерируйте: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ЗАМЕНИТЕ_НА_СЛУЧАЙНУЮ_СТРОКУ_64_СИМВОЛА

# ── Администратор ──
# Минимум 12 символов. Генерируйте: python -c "import secrets; print(secrets.token_urlsafe(24))"
ADMIN_PASSWORD=ЗАМЕНИТЕ_НА_НАДЁЖНЫЙ_ПАРОЛЬ_МИНИМУМ_12_СИМВОЛОВ

# ── Окружение ──
# production | development (в development отключается secure-флаг у cookies и открывается /docs)
ENVIRONMENT=production

# ── CORS ──
# Через запятую, без пробелов. Укажите реальный домен сайта.
ALLOWED_ORIGINS=https://fmtun.ru

# ── Rate Limiting ──
AUTH_RATE_LIMIT=10       # Попыток входа в минуту с одного IP
GLOBAL_RATE_LIMIT=120    # Общих запросов в минуту с одного IP

# ── Эквайринг ЮKassa ──
# Получите в личном кабинете https://yookassa.ru/my/shop-settings/paymentservice
PAYMENT_SHOP_ID=ваш_shop_id
PAYMENT_SECRET_KEY=ваш_секретный_ключ_yukassa
PAYMENT_CALLBACK_URL=https://fmtun.ru/api/payment/callback
# PAYMENT_API_KEY — то же что PAYMENT_SHOP_ID для ЮKassa
PAYMENT_API_KEY=ваш_shop_id

# ── Email-уведомления ──
# Для Яндекс.Почта: включите SMTP в настройках на mail.yandex.ru → Все настройки → Почтовые программы
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=ваш_email@yandex.ru
SMTP_PASS=пароль_приложения_из_яндекс
SMTP_FROM=ваш_email@yandex.ru

# ── URL сайта (используется в email и Telegram-уведомлениях) ──
BASE_URL=https://fmtun.ru

# ── Telegram-уведомления ──
# Инструкция: создайте бота через @BotFather, получите токен
# Узнайте ваш chat_id: напишите боту @userinfobot
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxYZ
TELEGRAM_ADMIN_CHAT_ID=123456789

# ── Яндекс.Метрика ──
# Создайте счётчик на https://metrika.yandex.ru
# YM_COUNTER_ID=12345678

# ── Видео на главной (VK Video embed URL) ──
# Пример: https://vk.com/video_ext.php?oid=-XXXXXX&id=XXXXXX&hash=XXXXXX
# VIDEO_URL=
