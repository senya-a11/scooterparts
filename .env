# ═══════════════════════════════════════════════════
# ScooterParts — переменные окружения
# Скопируйте этот файл в .env и заполните значения
# ═══════════════════════════════════════════════════

# ── База данных ──
# Для локальной разработки:
DATABASE_URL=postgresql://hub:PBcwd7OlLG3CYqHgpnrEIWS2bq2S0HNQ@dpg-d6olobua2pns738gu940-a.oregon-postgres.render.com/hub_emfr
# ── Безопасность ──
# Генерируйте: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=d3cfac0ee5f875bed3af44489f02c891

# ── Администратор ──
ADMIN_PASSWORD=admin

# ── CORS ──
# Через запятую, без пробелов
ALLOWED_ORIGINS=https://scooterparts.onrender.com

# ── Rate Limiting ──
AUTH_RATE_LIMIT=10       # Попыток входа в минуту с одного IP
GLOBAL_RATE_LIMIT=120    # Общих запросов в минуту с одного IP

# ── Эквайринг (заглушка — заполните после выбора провайдера) ──
# Для ЮKassa:
# PAYMENT_API_KEY=your_yookassa_shop_id
# PAYMENT_SHOP_ID=your_yookassa_shop_id
# PAYMENT_SECRET_KEY=your_yookassa_secret_key

# Для Тинькофф:
# PAYMENT_API_KEY=your_tinkoff_terminal_key
# PAYMENT_SHOP_ID=your_tinkoff_terminal_key
# PAYMENT_SECRET_KEY=your_tinkoff_password

# Для Stripe:
# PAYMENT_API_KEY=sk_live_...
# PAYMENT_SHOP_ID=your_stripe_account_id
# PAYMENT_SECRET_KEY=whsec_...  (webhook secret)

PAYMENT_CALLBACK_URL=https://scooterparts.onrender.com/api/payment/callback

# ── Email-уведомления ──
# Render бесплатный план блокирует SMTP — используйте Resend HTTP API:
# 1. Зарегистрируйтесь на resend.com (бесплатно: 3000 писем/мес)
# 2. Создайте API Key → вставьте ниже
# 3. В Resend добавьте домен ИЛИ используйте onboarding@resend.dev для тестов
EMAIL_API_KEY=your_resend_api_key_here
SMTP_FROM=fm.tun@yandex.ru
BASE_URL=https://scooterparts.onrender.com
# SMTP (только для локальной разработки, на Render заблокирован):
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=587
# SMTP_USER=fm.tun@yandex.ru
# SMTP_PASS=tacapmlmgązhyenx

# ── Telegram-уведомления (получать уведомления о заказах в Telegram) ──
# Инструкция: создайте бота через @BotFather, получите токен
# Узнайте ваш chat_id: напишите боту @userinfobot
# TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxYZ
# TELEGRAM_ADMIN_CHAT_ID=123456789

# ── Яндекс.Метрика ──
# Создайте счётчик на https://metrika.yandex.ru и вставьте ID
# YM_COUNTER_ID=12345678
