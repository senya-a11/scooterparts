<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="apple-touch-icon" sizes="180x180" href="/static/favicon/apple-touch-icon.png?v=6">
  <link rel="icon" type="image/svg+xml" href="/static/favicon/favicon.svg?v=6">
  <link rel="icon" type="image/png" sizes="32x32" href="/static/favicon/favicon-32x32.png?v=6">
  <link rel="shortcut icon" href="/static/favicon/favicon.ico?v=6">
  <meta name="theme-color" content="#080A0F">
  <title>Документы — Fm TuN</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/CustomEase.min.js"></script>
  <style nonce="{{ request.state.csp_nonce }}">
    @font-face{font-family:'PP Neue Corp Tight';src:url('https://cdn.prod.website-files.com/673af51dea86ab95d124c3ee/673b0f5784f7060c0ac05534_PPNeueCorp-TightUltrabold.otf') format('opentype');font-weight:700;font-display:swap;}
    @font-face{font-family:'PP Neue Montreal';src:url('https://cdn.prod.website-files.com/6819ed8312518f61b84824df/6819ed8312518f61b84825ba_PPNeueMontreal-Medium.woff2') format('woff2');font-weight:500;font-display:swap;}

    :root{
      --blue:#00D4FF;--blue-dim:rgba(0,212,255,.12);--blue-glow:rgba(0,212,255,.25);
      --bg:#080A0F;--bg2:#0D1018;--bg3:#111520;
      --surface:#161C26;--surface2:#1E2635;
      --border:rgba(255,255,255,.06);--border-h:rgba(0,212,255,.2);
      --text:#F0F4F8;--text2:#7B8599;--text3:#3E4560;
      --green:#00E5A0;--green-dim:rgba(0,229,160,.12);
      --red:#FF4757;--red-dim:rgba(255,71,87,.12);
      --amber:#FFB020;--amber-dim:rgba(255,176,32,.12);
      --r:10px;--rl:16px;--rxl:24px;
      --fd:'Syne',sans-serif;--fr:'Rajdhani',sans-serif;--fb:'DM Sans',sans-serif;
      --fn:'PP Neue Corp Tight','Syne',sans-serif;
      --fmono:'PP Neue Montreal',sans-serif;
      --ease:cubic-bezier(.16,1,.3,1);--easef:cubic-bezier(.4,0,.2,1);
    }

    /* ── LIGHT THEME ── */
    [data-theme="light"]{
      --blue:#E8580A;--blue-dim:rgba(232,88,10,.1);--blue-glow:rgba(232,88,10,.22);
      --bg:#F7F4EF;--bg2:#EDE9E3;--bg3:#E4E0D8;
      --surface:#D8D3CA;--surface2:#CBC5BB;
      --border:rgba(0,0,0,.08);--border-h:rgba(232,88,10,.28);
      --text:#1C1208;--text2:#6B5D4F;--text3:#A89080;
      --green:#1A7A52;--green-dim:rgba(26,122,82,.1);
      --red:#CC2200;--red-dim:rgba(204,34,0,.1);
      --amber:#B8720A;--amber-dim:rgba(184,114,10,.1);
    }
    [data-theme="light"] .header{background:rgba(247,244,239,.92)!important;border-bottom-color:rgba(0,0,0,.1)!important;}
    [data-theme="light"] #starfield{opacity:0;}
    [data-theme="light"] .nav-bg-panel.p1{background:var(--blue);}
    [data-theme="light"] .nav-bg-panel.p2{background:#fff8f3;}
    [data-theme="light"] .nav-bg-panel.p3{background:#faf6f1;border-color:rgba(232,88,10,.12);}
    [data-theme="light"] .logo-bolt{background:linear-gradient(135deg,#FFD700,#FFA500)!important;-webkit-background-clip:text!important;-webkit-text-fill-color:transparent!important;background-clip:text!important;filter:drop-shadow(0 0 8px rgba(255,180,0,.45))!important;box-shadow:none!important;}
    [data-theme="light"] .doc-card{background:rgba(232,225,215,.7);}
    [data-theme="light"] .doc-card-header{background:linear-gradient(135deg,rgba(232,88,10,.06) 0%,transparent 55%);}
    [data-theme="light"] .highlight-box{background:var(--surface);border-left-color:var(--blue);}
    [data-theme="light"] .warn-box{background:rgba(184,114,10,.08);}
    [data-theme="light"] .success-box{background:rgba(26,122,82,.08);}
    [data-theme="light"] .footer{background:var(--bg2);border-color:rgba(0,0,0,.08);}
    [data-theme="light"] body{background:var(--bg);}
    [data-theme="light"] .cookie-table th{background:rgba(0,0,0,.04);}
    [data-theme="light"] .nav-close-btn{color:var(--blue)!important;border-color:var(--blue)!important;}
    [data-theme="light"] .nav-menu-heading,.nav-menu-heading{color:var(--text);}
    html{transition:background-color .25s;scroll-behavior:smooth;overflow-x:hidden;}
    body{transition:background-color .25s,color .25s;font-family:var(--fb);background:var(--bg);color:var(--text);line-height:1.6;min-height:100vh;display:flex;flex-direction:column;-webkit-font-smoothing:antialiased;overflow-x:hidden;}
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}

    /* ── STARFIELD ── */
    #starfield{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none;}

    ::-webkit-scrollbar{width:5px;}
    ::-webkit-scrollbar-track{background:var(--bg2);}
    ::-webkit-scrollbar-thumb{background:var(--surface2);border-radius:3px;}

    .container{max-width:1280px;margin:0 auto;padding:0 1.5rem;position:relative;z-index:1;}

    /* ── THEME SEG ── */
    .theme-seg{display:flex;align-items:center;justify-content:space-between;padding:.875rem 2rem;border-bottom:1px solid rgba(255,255,255,.06);}
    [data-theme="light"] .theme-seg{border-bottom-color:rgba(0,0,0,.07);}
    .theme-seg-label{font-family:var(--fr);font-size:.62rem;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.28);}
    [data-theme="light"] .theme-seg-label{color:rgba(0,0,0,.28);}
    .theme-seg-ctrl{display:flex;gap:3px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:8px;padding:3px;}
    [data-theme="light"] .theme-seg-ctrl{background:rgba(0,0,0,.04);border-color:rgba(0,0,0,.08);}
    .theme-seg-btn{display:inline-flex;align-items:center;gap:.4rem;padding:.35rem .75rem;font-family:var(--fr);font-size:.68rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;border:none;border-radius:5px;cursor:pointer;background:transparent;color:rgba(255,255,255,.32);transition:color .2s,background .2s;line-height:1;}
    [data-theme="light"] .theme-seg-btn{color:rgba(0,0,0,.3);}
    .theme-seg-btn.seg-active{color:var(--blue);background:var(--blue-dim);}

    /* ── HEADER ── */
    .header{position:fixed;top:0;left:0;right:0;background:rgba(0,0,0,.78);backdrop-filter:blur(24px) saturate(1.6);border-bottom:1px solid var(--border);z-index:200;}
    .header-inner{display:flex;align-items:center;justify-content:space-between;height:64px;padding:0 1.5rem;}
    .logo{display:flex;align-items:center;gap:10px;font-family:var(--fd);font-size:1.25rem;font-weight:800;color:var(--text);text-decoration:none;letter-spacing:.08em;flex-shrink:0;}
    .logo-bolt{width:32px;height:32px;display:flex;align-items:center;justify-content:center;font-size:22px;background:linear-gradient(135deg,#FFD700,#FFA500);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;filter:drop-shadow(0 0 8px rgba(255,190,0,.55));}
    .logo-text span{color:var(--blue);}
    .header-actions{display:flex;align-items:center;gap:.625rem;}
    .back-btn{display:inline-flex;align-items:center;gap:.5rem;font-family:var(--fr);font-size:.8125rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text2);text-decoration:none;padding:.5rem .875rem;border-radius:var(--r);border:1px solid var(--border);transition:all .2s;}
    .back-btn:hover{color:var(--text);border-color:var(--border-h);background:rgba(0,212,255,.04);}
    .menu-button{display:flex;align-items:center;gap:.625rem;background:transparent;border:1px solid var(--border);color:var(--text);cursor:pointer;padding:.5rem .875rem;border-radius:var(--r);font-family:var(--fmono),var(--fb);font-size:.875rem;letter-spacing:.06em;transition:border-color .2s,background .2s;overflow:hidden;}
    .menu-button:hover{border-color:var(--border-h);background:rgba(0,212,255,.04);}
    .menu-button-text{display:flex;flex-direction:column;align-items:flex-end;height:1.1em;overflow:hidden;}
    .menu-button-text p{font-size:.875em;letter-spacing:.08em;text-transform:uppercase;margin:0;line-height:1.1;}
    .menu-button-text p:nth-child(2){transform:translateY(100%);}
    .menu-button-icon{width:.9em;height:.9em;transition:transform .4s cubic-bezier(.65,.05,0,1);flex-shrink:0;}
    .menu-button:hover .menu-button-icon{transform:rotate(90deg);}

    /* ── NAV DRAWER ── */
    .nav-overlay{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:300;cursor:pointer;opacity:0;pointer-events:none;backdrop-filter:blur(2px);}
    .nav-drawer{position:fixed;right:0;top:0;bottom:0;width:38em;max-width:100vw;z-index:400;display:none;flex-direction:column;}
    .nav-drawer-bg{position:absolute;inset:0;z-index:0;}
    .nav-bg-panel{position:absolute;inset:0;border-top-left-radius:1.5em;border-bottom-left-radius:1.5em;}
    .nav-bg-panel.p1{background:var(--blue);}
    .nav-bg-panel.p2{background:#0a1a20;}
    .nav-bg-panel.p3{background:#000;border:1px solid rgba(0,212,255,.12);}
    .nav-drawer-inner{position:relative;z-index:1;display:flex;flex-direction:column;justify-content:space-between;height:100%;padding:4rem 0 2.5rem;}
    .nav-close-btn{position:absolute;top:1.5rem;right:2rem;background:none;border:1px solid rgba(255,255,255,.06);color:rgba(255,255,255,.5);width:2.5rem;height:2.5rem;border-radius:50%;cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;z-index:2;transition:all .2s;}
    .nav-close-btn:hover{border-color:var(--blue);color:var(--blue);}
    .nav-menu-list{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;width:100%;}
    .nav-menu-item{position:relative;overflow:hidden;}
    .nav-menu-link{display:flex;align-items:baseline;justify-content:flex-end;gap:.5em;width:100%;padding:.6em 2em;text-decoration:none;color:var(--text);position:relative;text-align:right;}
    .nav-menu-heading{font-family:var(--fn);font-size:4.5em;font-weight:700;line-height:.85;text-transform:uppercase;letter-spacing:-.02em;transition:transform .55s cubic-bezier(.65,.05,0,1);position:relative;z-index:1;color:var(--text);}
    .nav-menu-eyebrow{font-family:var(--fr);font-size:.75em;letter-spacing:.25em;text-transform:uppercase;color:var(--blue);position:relative;z-index:1;}
    .nav-menu-link-bg{position:absolute;inset:0;background:rgba(0,212,255,.06);transform:scale3d(1,0,1);transform-origin:50% 100%;transition:transform .55s cubic-bezier(.65,.05,0,1);z-index:0;}
    .nav-menu-link:hover .nav-menu-heading{transform:translateY(-1em);transition-delay:.08s;color:var(--blue);}
    .nav-menu-link:hover .nav-menu-link-bg{transform:scale3d(1,1,1);}
    .nav-drawer-footer{padding-top:1.5em;margin:0 2em;border-top:1px solid rgba(255,255,255,.06);display:flex;flex-direction:column;gap:1em;}
    .nav-footer-label{font-family:var(--fr);font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:var(--text3);}
    .nav-socials{display:flex;gap:1.5em;flex-wrap:wrap;}
    .nav-social-link{font-size:.875rem;color:var(--text2);text-decoration:none;position:relative;transition:color .2s;}
    .nav-social-link::after{content:'';position:absolute;left:0;bottom:0;width:100%;height:1px;background:var(--blue);transform:scaleX(0);transform-origin:right center;transition:transform .4s cubic-bezier(.65,.05,0,1);}
    .nav-social-link:hover{color:var(--text);}
    .nav-social-link:hover::after{transform:scaleX(1);transform-origin:left center;}

    /* ── PAGE HEADER ── */
    .page-header{padding-top:5.5rem;padding-bottom:2.5rem;position:relative;overflow:hidden;z-index:1;}
    .page-header::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(0,212,255,.3),transparent);}
    .page-eyebrow{display:inline-flex;align-items:center;gap:.5rem;font-family:var(--fr);font-size:.75rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--blue);margin-bottom:1rem;padding:.35rem 1rem;background:var(--blue-dim);border:1px solid rgba(0,212,255,.2);border-radius:100px;}
    .eyebrow-dot{width:6px;height:6px;border-radius:50%;background:var(--blue);box-shadow:0 0 8px var(--blue);animation:dotBlink 1.5s ease-in-out infinite;}
    @keyframes dotBlink{0%,100%{opacity:1;}50%{opacity:.3;}}
    .page-title{font-family:var(--fd);font-size:clamp(1.75rem,4vw,2.75rem);font-weight:800;letter-spacing:-.04em;line-height:1.1;margin-bottom:.375rem;}
    .page-desc{font-family:var(--fr);font-size:.9rem;color:var(--text2);letter-spacing:.05em;}

    /* ── LAYOUT ── */
    .docs-layout{flex:1;position:relative;z-index:1;padding:2.5rem 0 5rem;}
    .docs-inner{display:grid;grid-template-columns:260px 1fr;gap:2.5rem;align-items:start;min-width:0;}
    /* critical: prevents grid child overflow */
    .docs-content{min-width:0;width:100%;overflow:hidden;}

    /* ── SIDEBAR ── */
    .docs-sidebar{position:sticky;top:88px;display:flex;flex-direction:column;gap:.25rem;}
    .sidebar-label{font-family:var(--fr);font-size:.65rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--text3);padding:0 .75rem;margin-bottom:.5rem;}
    .sidebar-tab{display:flex;align-items:center;gap:.875rem;padding:.75rem .875rem;background:transparent;border:1px solid transparent;border-radius:var(--rl);cursor:pointer;transition:all .25s var(--easef);text-align:left;width:100%;position:relative;overflow:hidden;}
    .sidebar-tab::before{content:'';position:absolute;inset:0;background:rgba(0,212,255,.05);transform:scaleX(0);transform-origin:left center;transition:transform .3s var(--easef);border-radius:inherit;}
    .sidebar-tab:hover::before{transform:scaleX(1);}
    .sidebar-tab:hover{border-color:var(--border-h);}
    .sidebar-tab.active{background:var(--blue-dim);border-color:rgba(0,212,255,.22);box-shadow:0 0 20px rgba(0,212,255,.06),inset 0 0 0 1px rgba(0,212,255,.08);}
    .sidebar-tab.active::before{display:none;}
    .sidebar-tab.active::after{content:'';position:absolute;left:0;top:22%;bottom:22%;width:3px;background:var(--blue);border-radius:0 3px 3px 0;box-shadow:0 0 8px var(--blue);}
    .tab-icon{width:34px;height:34px;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:var(--surface);border:1px solid var(--border);border-radius:9px;font-size:.9rem;transition:all .25s;position:relative;z-index:1;}
    .sidebar-tab.active .tab-icon{background:var(--blue-dim);border-color:rgba(0,212,255,.3);box-shadow:0 0 10px rgba(0,212,255,.12);}
    .tab-text{position:relative;z-index:1;}
    .tab-name{font-family:var(--fd);font-size:.8125rem;font-weight:700;color:var(--text2);display:block;transition:color .2s;line-height:1.2;}
    .sidebar-tab.active .tab-name{color:var(--blue);}
    .sidebar-tab:hover:not(.active) .tab-name{color:var(--text);}
    .tab-hint{font-family:var(--fr);font-size:.7rem;letter-spacing:.04em;color:var(--text3);display:block;margin-top:.1rem;transition:color .2s;}
    .sidebar-tab.active .tab-hint{color:rgba(0,212,255,.55);}
    .sidebar-divider{height:1px;background:var(--border);margin:.5rem .75rem;}

    /* ── DOC SECTIONS ── */
    .doc-section{display:none;min-width:0;width:100%;}
    .doc-section.active{display:block;animation:contentFadeIn .35s var(--ease) both;}
    @keyframes contentFadeIn{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
    .doc-card{background:rgba(14,18,24,.78);backdrop-filter:blur(20px) saturate(1.3);border:1px solid var(--border);border-radius:var(--rxl);overflow:hidden;min-width:0;max-width:100%;width:100%;box-sizing:border-box;}
    .doc-card-header{padding:2rem 2.5rem 1.75rem;border-bottom:1px solid var(--border);background:linear-gradient(135deg,rgba(0,212,255,.04) 0%,transparent 55%);position:relative;overflow:hidden;}
    .doc-card-header::after{content:'';position:absolute;top:-80px;right:-80px;width:220px;height:220px;background:radial-gradient(ellipse,rgba(0,212,255,.07) 0%,transparent 70%);pointer-events:none;}
    .doc-badge{display:inline-flex;align-items:center;gap:.5rem;padding:.25rem .875rem;background:var(--blue-dim);color:var(--blue);border:1px solid rgba(0,212,255,.2);border-radius:100px;font-family:var(--fr);font-size:.7rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;margin-bottom:1rem;max-width:100%;flex-wrap:wrap;}
    .doc-title{font-family:var(--fd);font-size:clamp(1.2rem,5vw,1.875rem);font-weight:800;letter-spacing:-.03em;margin-bottom:.5rem;word-break:break-word;}
    .doc-meta{font-family:var(--fr);font-size:.75rem;color:var(--text3);letter-spacing:.08em;word-break:break-word;}
    .doc-body{padding:2rem 2.5rem;overflow:hidden;}

    /* ── DOC CONTENT TYPOGRAPHY ── */
    .doc-content{color:var(--text2);font-size:.9375rem;line-height:1.8;}
    .doc-content h2{font-family:var(--fd);font-size:1.0625rem;font-weight:700;color:var(--text);margin:2rem 0 .75rem;letter-spacing:-.02em;display:flex;align-items:center;gap:.75rem;}
    .doc-content h2::before{content:'';display:block;width:3px;height:1em;flex-shrink:0;background:var(--blue);border-radius:2px;box-shadow:0 0 8px var(--blue);}
    .doc-content h2:first-child{margin-top:0;}
    .doc-content p{margin-bottom:1rem;}
    .doc-content ul,.doc-content ol{padding-left:0;margin-bottom:1rem;list-style:none;}
    .doc-content li{margin-bottom:.5rem;padding-left:1.375rem;position:relative;}
    .doc-content ul li::before{content:'';position:absolute;left:0;top:.68em;width:5px;height:5px;border-radius:50%;background:var(--blue);opacity:.65;}
    .doc-content ol{counter-reset:ol-c;}
    .doc-content ol li{counter-increment:ol-c;}
    .doc-content ol li::before{content:counter(ol-c)'.';position:absolute;left:0;top:0;font-family:var(--fr);font-size:.75rem;font-weight:700;color:var(--blue);letter-spacing:.05em;line-height:1.8;}
    .doc-content strong{color:var(--text);font-weight:600;}
    .doc-content a{color:var(--blue);text-decoration:none;}
    .doc-content a:hover{text-decoration:underline;}
    code{font-family:'JetBrains Mono',var(--fmono),monospace;font-size:.78rem;background:rgba(0,212,255,.08);color:#00D4FF;padding:.1rem .4rem;border-radius:4px;}

    .highlight-box{background:var(--surface);border:1px solid rgba(0,212,255,.12);border-left:3px solid var(--blue);border-radius:var(--r);padding:1rem 1.25rem;margin:1.25rem 0;font-size:.875rem;color:var(--text2);line-height:1.7;}
    .highlight-box strong{color:var(--blue);}
    .warn-box{background:rgba(255,176,32,.07);border:1px solid rgba(255,176,32,.2);border-left:3px solid var(--amber);border-radius:var(--r);padding:1rem 1.25rem;margin:1.25rem 0;font-size:.875rem;color:var(--text2);line-height:1.7;}
    .warn-box strong{color:var(--amber);}
    .success-box{background:var(--green-dim);border:1px solid rgba(0,229,160,.2);border-left:3px solid var(--green);border-radius:var(--r);padding:1rem 1.25rem;margin:1.25rem 0;font-size:.875rem;color:var(--text2);line-height:1.7;}
    .success-box strong{color:var(--green);}

    /* ── DOWNLOAD BTN ── */
    .doc-download-btn{display:inline-flex;align-items:center;gap:.625rem;background:var(--blue-dim);color:var(--blue);border:1px solid rgba(0,212,255,.3);border-radius:var(--r);padding:.625rem 1.25rem;font-family:var(--fr);font-size:.8125rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;text-decoration:none;cursor:pointer;transition:all .2s;}
    .doc-download-btn:hover{background:rgba(0,212,255,.2);border-color:rgba(0,212,255,.5);text-decoration:none;}

    /* ── COOKIE TABLE ── */
    .cookie-table-wrap{overflow-x:auto;margin:1.25rem 0;border-radius:var(--r);border:1px solid var(--border);}
    .cookie-table{width:100%;border-collapse:collapse;font-size:.8125rem;}
    .cookie-table th{background:rgba(0,212,255,.06);color:var(--text2);font-family:var(--fr);font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:.75rem 1rem;text-align:left;border-bottom:1px solid rgba(0,212,255,.15);white-space:nowrap;}
    .cookie-table td{padding:.65rem 1rem;border-bottom:1px solid rgba(255,255,255,.03);color:var(--text2);vertical-align:top;line-height:1.5;}
    .cookie-table tr:last-child td{border-bottom:none;}
    .cookie-table tr:hover td{background:rgba(255,255,255,.02);}
    .ck-badge{display:inline-block;padding:.15rem .5rem;border-radius:4px;font-family:var(--fr);font-size:.68rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;}
    .ck-badge.necessary{background:rgba(0,212,255,.12);color:#00D4FF;}
    .ck-badge.functional{background:rgba(167,139,250,.12);color:#A78BFA;}
    .ck-badge.analytics{background:rgba(52,211,153,.12);color:#34D399;}

    /* ── FOOTER ── */
    .footer{background:var(--bg2);border-top:1px solid var(--border);padding:3rem 0 0;position:relative;z-index:1;}
    .footer-grid{display:grid;grid-template-columns:1.5fr repeat(3,1fr);gap:3rem;padding-bottom:3rem;}
    .footer-brand-desc{font-size:.875rem;color:var(--text2);line-height:1.7;margin-top:1rem;max-width:280px;}
    .footer-col-title{font-family:var(--fr);font-size:.7rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--text3);margin-bottom:1rem;}
    .footer-links{list-style:none;display:flex;flex-direction:column;gap:.5rem;}
    .footer-links a{font-size:.875rem;color:var(--text2);text-decoration:none;transition:color .2s;}
    .footer-links a:hover{color:var(--blue);}
    .footer-bottom{border-top:1px solid var(--border);padding:1.25rem 0;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;}
    .footer-bottom span,.footer-bottom a{font-family:var(--fr);font-size:.8rem;color:var(--text3);text-decoration:none;transition:color .2s;letter-spacing:.05em;}
    .footer-bottom a:hover{color:var(--blue);}
    .footer-legal{display:flex;gap:1.5rem;flex-wrap:wrap;}

    /* ── RESPONSIVE ── */
    @media(max-width:900px){
      .docs-inner{grid-template-columns:1fr;}
      .docs-sidebar{
        position:static;
        display:grid;
        grid-template-columns:1fr 1fr;
        gap:.5rem;
        margin-bottom:.25rem;
      }
      .sidebar-label{display:none;}
      .sidebar-tab{min-width:0;flex-shrink:unset;}
      .sidebar-tab.active::after{display:none;}
      .sidebar-divider{grid-column:1/-1;height:1px;margin:.1rem 0;align-self:stretch;}
    }
    @media(max-width:768px){
      .footer-grid{grid-template-columns:1fr 1fr;gap:2rem;}
      .doc-card-header{padding:1.25rem 1rem;}
      .doc-body{padding:1.25rem 1rem;}
      .doc-content{font-size:.875rem;}
      .nav-drawer{width:100%;}
      .nav-bg-panel{border-radius:0;}
      .nav-menu-heading{font-size:3.5em;}
      .nav-menu-link{padding:.5em 1.25em;}
    }
    @media(max-width:480px){
      .footer-grid{grid-template-columns:1fr;}
      .sidebar-tab{padding:.625rem .75rem;}
      .tab-hint{font-size:.65rem;}
      .doc-card-header{padding:1rem .875rem;}
      .doc-body{padding:1rem .875rem;}
      .cookie-table th,.cookie-table td{padding:.5rem .6rem;font-size:.7rem;}
      .highlight-box,.warn-box,.success-box{padding:.875rem 1rem;}
    }
  </style>
  <script src="/static/csrf-init.js"></script>
</head>
